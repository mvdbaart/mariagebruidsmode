PUBLIC_SUPABASE_URL=your-project-url
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_EMAILS=admin@example.com
SITE_URL=https://mariagebruidsmode.vercel.app  # public URL used for magic link redirect; must be whitelisted in Supabase Authentication → URL Configuration

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Mariage Bruidsmode <noreply@mariagebruidsmode.nl>

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Webhook signing secret (Stripe Dashboard → Webhooks → je endpoint → Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...

# Direct database connection (PostgreSQL connection string)
# Vind je in Supabase Dashboard → Project Settings → Database → Connection String (URI)
# Gebruik de "Session mode" URL (poort 5432) voor CLI-migraties
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
