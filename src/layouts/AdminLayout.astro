---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Mariage Admin</title>
    <meta name="robots" content="noindex, nofollow" />
    <style>
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-weight: 400;
      }
    </style>
  </head>
  <body class="admin-layout font-body">

    <!-- Sidebar (desktop: fixed left, mobile: slide-in overlay) -->
    <aside
      id="admin-sidebar"
      class="fixed top-0 left-0 h-full w-60 bg-charcoal z-50 flex flex-col
             -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out"
      aria-label="Admin navigatie"
    >
      <!-- Branding -->
      <div class="px-6 py-6 border-b border-white/5 shrink-0">
        <a href="/admin" class="block">
          <span class="font-laila font-semibold text-ivory text-xl tracking-wide">Mariage</span>
          <span class="block font-laila font-normal text-blush-deep text-sm lowercase tracking-[0.12em] opacity-85 mt-0.5 ml-1">bruidsmode admin</span>
        </a>
      </div>

      <!-- Navigation -->
      <nav class="flex-1 overflow-y-auto py-4 px-3 space-y-5">
        {navSections.map((section) => (
          <div>
            {section.label && (
              <p class="px-3 mb-1.5 text-[9px] tracking-[0.25em] uppercase text-white/25 font-body font-medium">
                {section.label}
              </p>
            )}
            <div class="space-y-0.5">
              {section.items.map(item => (
                <a
                  href={item.href}
                  class:list={[
                    'flex items-center gap-3 px-3 py-2 text-sm font-body transition-all duration-150 rounded-sm border-l-2',
                    isActive(item.href)
                      ? 'text-ivory bg-white/10 border-blush-deep font-medium'
                      : 'text-champagne/60 hover:text-ivory hover:bg-white/5 border-transparent'
                  ]}
                >
                  <span class:list={["shrink-0", isActive(item.href) ? 'text-blush-deep' : 'text-white/30']} set:html={item.icon} />
                  {item.label}
                </a>
              ))}
            </div>
          </div>
        ))}
      </nav>

      <!-- Footer actions -->
      <div class="px-3 py-4 border-t border-white/10 shrink-0 space-y-1">
        <a href="/" target="_blank" class="flex items-center gap-3 px-3 py-2 text-sm font-body text-champagne/70 hover:text-ivory hover:bg-white/5 transition-colors duration-150 rounded-sm">
          Bekijk Website ↗
        </a>
        <form action="/api/auth/logout" method="POST">
          <button type="submit" class="w-full text-left flex items-center gap-3 px-3 py-2 text-sm font-body text-champagne/70 hover:text-red-300 hover:bg-white/5 transition-colors duration-150 rounded-sm">
            Uitloggen
          </button>
        </form>
      </div>
    </aside>

    <!-- Mobile backdrop -->
    <div
      id="sidebar-backdrop"
      class="fixed inset-0 bg-charcoal/60 z-40 hidden md:hidden"
      aria-hidden="true"
    ></div>

    <!-- Mobile top bar -->
    <header class="fixed top-0 left-0 right-0 h-14 bg-charcoal flex items-center justify-between px-4 z-30 md:hidden border-b border-white/10">
      <button
        id="hamburger-btn"
        class="text-ivory p-2 -ml-2"
        aria-label="Menu openen"
        aria-expanded="false"
        aria-controls="admin-sidebar"
      >
        <svg id="hamburger-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <rect y="3" width="20" height="2" rx="1"/>
          <rect y="9" width="20" height="2" rx="1"/>
          <rect y="15" width="20" height="2" rx="1"/>
        </svg>
        <svg id="close-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="hidden">
          <path d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"/>
        </svg>
      </button>
      <span class="admin-heading text-ivory text-base absolute left-1/2 -translate-x-1/2">{title}</span>
    </header>

    <!-- Desktop top header bar -->
    <header class="hidden md:flex fixed top-0 left-60 right-0 h-16 bg-white border-b border-champagne items-center px-6 justify-between z-20">
      <h1 class="admin-heading text-charcoal text-base">{title}</h1>
      <div class="flex items-center gap-6">
        <a href="/" target="_blank" class="text-[10px] uppercase tracking-widest text-taupe hover:text-charcoal transition-colors">
          Bekijk Website ↗
        </a>
        <form action="/api/auth/logout" method="POST" class="inline">
          <button type="submit" class="text-[10px] uppercase tracking-widest text-taupe hover:text-red-400 transition-colors">
            Uitloggen
          </button>
        </form>
      </div>
    </header>

    <!-- Main content -->
    <main class="md:ml-60 min-h-screen pt-14 md:pt-16">
      <slot />
    </main>

    <script>
      const sidebar = document.getElementById('admin-sidebar')!;
      const backdrop = document.getElementById('sidebar-backdrop')!;
      const hamburgerBtn = document.getElementById('hamburger-btn')!;
      const hamburgerIcon = document.getElementById('hamburger-icon')!;
      const closeIcon = document.getElementById('close-icon')!;

      function openSidebar() {
        sidebar.classList.remove('-translate-x-full');
        backdrop.classList.remove('hidden');
        hamburgerIcon.classList.add('hidden');
        closeIcon.classList.remove('hidden');
        hamburgerBtn.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }

      function closeSidebar() {
        sidebar.classList.add('-translate-x-full');
        backdrop.classList.add('hidden');
        hamburgerIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        hamburgerBtn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }

      hamburgerBtn.addEventListener('click', () => {
        const isOpen = !sidebar.classList.contains('-translate-x-full');
        isOpen ? closeSidebar() : openSidebar();
      });

      backdrop.addEventListener('click', closeSidebar);

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeSidebar();
      });
    </script>
  </body>
</html>
