---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/admin') return currentPath === '/admin';
  return currentPath.startsWith(href);
}

const navGroups = [
  {
    label: null,
    items: [
      { label: 'Dashboard', href: '/admin' },
    ],
  },
  {
    label: 'Content',
    items: [
      { label: 'Homepage', href: '/admin/homepage' },
      { label: 'Collecties', href: '/admin/collecties' },
      { label: 'Producten', href: '/admin/producten' },
      { label: 'Blog', href: '/admin/blog' },
      { label: 'Inspiratie', href: '/admin/inspiratie' },
    ],
  },
  {
    label: 'Klanten & Verkoop',
    items: [
      { label: 'Afspraken', href: '/admin/afspraken' },
      { label: 'Klanten', href: '/admin/klanten' },
      { label: 'Leveranciers', href: '/admin/leveranciers' },
      { label: 'Bestellingen', href: '/admin/bestellingen' },
    ],
  },
  {
    label: 'Tools',
    items: [
      { label: 'Planning', href: '/admin/planner/medewerkers' },
      { label: 'Formulieren', href: '/admin/formulieren' },
      { label: 'Landingspagina\'s', href: '/admin/landingpages' },
      { label: 'A/B Testing', href: '/admin/landingpages' },
      { label: 'Gebruikers', href: '/admin/gebruikers' },
      { label: 'Instellingen', href: '/admin/instellingen' },
    ],
  },
  {
    label: 'Analytics',
    items: [
      { label: 'Bezoekersflow', href: '/admin/bezoekersflow' },
    ],
  },
];
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Jost:wght@300;400;500&family=Playball&display=swap" rel="stylesheet">
    <title>{title} | Mariage Admin</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body class="bg-ivory font-body">

    <!-- Sidebar (desktop: fixed left, mobile: slide-in overlay) -->
    <aside
      id="admin-sidebar"
      class="fixed top-0 left-0 h-full w-60 bg-charcoal z-50 flex flex-col
             -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out"
      aria-label="Admin navigatie"
    >
      <!-- Branding -->
      <div class="px-6 py-8 border-b border-white/5 shrink-0">
        <a href="/admin" class="block">
          <span class="font-display italic text-ivory text-xl">Mariage</span>
          <span class="block font-signature text-blush-deep text-lg lowercase opacity-90 -mt-1 ml-4">Control panel</span>
        </a>
      </div>

      <!-- Navigation -->
      <nav class="flex-1 overflow-y-auto py-4 px-3">
        {navGroups.map(group => (
          <div class="mb-4">
            {group.label && (
              <p class="text-[9px] tracking-[0.25em] uppercase text-champagne/40 font-body px-3 mb-2 mt-2">
                {group.label}
              </p>
            )}
            {group.items.map(item => (
              <a
                href={item.href}
                class:list={[
                  'flex items-center gap-3 px-3 py-2 text-sm font-body transition-colors duration-150 rounded-sm mb-0.5',
                  isActive(item.href)
                    ? 'bg-white/10 text-ivory border-l-2 border-blush-deep pl-[10px]'
                    : 'text-champagne/70 hover:text-ivory hover:bg-white/5'
                ]}
              >
                {item.label}
              </a>
            ))}
          </div>
        ))}
      </nav>

      <!-- Footer actions -->
      <div class="px-3 py-4 border-t border-white/10 shrink-0 space-y-1">
        <a href="/" target="_blank" class="flex items-center gap-3 px-3 py-2 text-sm font-body text-champagne/70 hover:text-ivory hover:bg-white/5 transition-colors duration-150 rounded-sm">
          Bekijk Website ↗
        </a>
        <form action="/api/auth/logout" method="POST">
          <button type="submit" class="w-full text-left flex items-center gap-3 px-3 py-2 text-sm font-body text-champagne/70 hover:text-red-300 hover:bg-white/5 transition-colors duration-150 rounded-sm">
            Uitloggen
          </button>
        </form>
      </div>
    </aside>

    <!-- Mobile backdrop -->
    <div
      id="sidebar-backdrop"
      class="fixed inset-0 bg-charcoal/60 z-40 hidden md:hidden"
      aria-hidden="true"
    ></div>

    <!-- Mobile top bar -->
    <header class="fixed top-0 left-0 right-0 h-14 bg-charcoal flex items-center justify-between px-4 z-30 md:hidden border-b border-white/10">
      <button
        id="hamburger-btn"
        class="text-ivory p-2 -ml-2"
        aria-label="Menu openen"
        aria-expanded="false"
        aria-controls="admin-sidebar"
      >
        <svg id="hamburger-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <rect y="3" width="20" height="2" rx="1"/>
          <rect y="9" width="20" height="2" rx="1"/>
          <rect y="15" width="20" height="2" rx="1"/>
        </svg>
        <svg id="close-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="hidden">
          <path d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"/>
        </svg>
      </button>
      <span class="font-display italic text-ivory text-lg absolute left-1/2 -translate-x-1/2">{title}</span>
    </header>

    <!-- Main content -->
    <main class="md:ml-60 min-h-screen pt-14 md:pt-0">
      <slot />
    </main>

    <script>
      const sidebar = document.getElementById('admin-sidebar')!;
      const backdrop = document.getElementById('sidebar-backdrop')!;
      const hamburgerBtn = document.getElementById('hamburger-btn')!;
      const hamburgerIcon = document.getElementById('hamburger-icon')!;
      const closeIcon = document.getElementById('close-icon')!;

      function openSidebar() {
        sidebar.classList.remove('-translate-x-full');
        backdrop.classList.remove('hidden');
        hamburgerIcon.classList.add('hidden');
        closeIcon.classList.remove('hidden');
        hamburgerBtn.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }

      function closeSidebar() {
        sidebar.classList.add('-translate-x-full');
        backdrop.classList.add('hidden');
        hamburgerIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        hamburgerBtn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }

      hamburgerBtn.addEventListener('click', () => {
        const isOpen = !sidebar.classList.contains('-translate-x-full');
        isOpen ? closeSidebar() : openSidebar();
      });

      backdrop.addEventListener('click', closeSidebar);

      // Close on escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeSidebar();
      });
    </script>
  </body>
</html>
