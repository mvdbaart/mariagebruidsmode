---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/admin') return currentPath === '/admin';
  return currentPath.startsWith(href);
}

const navGroups = [
  {
    label: 'Overview',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>`,
    items: [
      { label: 'Dashboard', href: '/admin' },
    ],
  },
  {
    label: 'Storefront',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><path d="M15 22v-4a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2v4"/><path d="M2 7h20"/><path d="M22 7v3a2 2 0 0 1-2 2v0a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 16 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 12 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 8 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 4 12v0a2 2 0 0 1-2-2V7"/></svg>`,
    items: [
      { label: 'Producten', href: '/admin/producten' },
      { label: 'Collecties', href: '/admin/collecties' },
      { label: 'Homepage', href: '/admin/homepage' },
    ],
  },
  {
    label: 'Sales & People',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    items: [
      { label: 'Afspraken', href: '/admin/afspraken' },
      { label: 'Klanten', href: '/admin/klanten' },
      { label: 'Leveranciers', href: '/admin/leveranciers' },
      { label: 'Bestellingen', href: '/admin/bestellingen' },
    ],
  },
  {
    label: 'Content',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
    items: [
      { label: 'Blog', href: '/admin/blog' },
      { label: 'Inspiratie', href: '/admin/inspiratie' },
      { label: 'Events', href: '/admin/events' },
    ],
  },
  {
    label: 'Marketing & Tools',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 11 18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg>`,
    items: [
      { label: 'Medewerkers', href: '/admin/planner/medewerkers' },
      { label: 'Formulieren', href: '/admin/formulieren' },
      { label: 'Landingspagina\'s', href: '/admin/landingpages' },
      { label: 'A/B Testing', href: '/admin/landingpages' },
    ],
  },
  {
    label: 'System',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>`,
    items: [
      { label: 'Gebruikers', href: '/admin/gebruikers' },
      { label: 'Instellingen', href: '/admin/instellingen' },
      { label: 'Bezoekersflow', href: '/admin/bezoekersflow' },
    ],
  },
];
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Jost:wght@300;400;500&family=Playball&display=swap" rel="stylesheet">
    <title>{title} | Mariage Admin</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body class="bg-ivory font-body">

    <!-- Sidebar (desktop: fixed left, mobile: slide-in overlay) -->
    <aside
      id="admin-sidebar"
      class="fixed top-0 left-0 h-full w-60 bg-charcoal z-50 flex flex-col
             -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out"
      aria-label="Admin navigatie"
    >
      <!-- Branding -->
      <div class="px-6 py-8 border-b border-white/5 shrink-0">
        <a href="/admin" class="block">
          <span class="font-display italic text-ivory text-xl">Mariage</span>
          <span class="block font-signature text-blush-deep text-lg lowercase opacity-90 -mt-1 ml-4">Control panel</span>
        </a>
      </div>

      <!-- Navigation -->
      <nav class="flex-1 overflow-y-auto py-2 px-3">
        {navGroups.map((group, groupIdx) => {
          const isGroupActive = group.items.some(item => isActive(item.href));
          return (
            <div class="mb-2">
              <button
                class="w-full flex items-center justify-between px-3 py-2.5 text-[10px] tracking-[0.2em] uppercase text-champagne/50 font-body hover:text-ivory transition-colors group/nav"
                data-collapse-trigger={groupIdx}
              >
                <div class="flex items-center gap-3">
                  <span class="opacity-50" set:html={group.icon} />
                  <span>{group.label}</span>
                </div>
                <svg 
                  class:list={["w-3 h-3 transition-transform duration-200", isGroupActive ? 'rotate-180' : '']} 
                  data-chevron={groupIdx}
                  xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                >
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </button>
              
              <div 
                id={`collapse-${groupIdx}`} 
                class:list={["space-y-0.5 mt-1 overflow-hidden transition-all duration-300", isGroupActive ? 'max-h-[500px]' : 'max-h-0']}
              >
                {group.items.map(item => (
                  <a
                    href={item.href}
                    class:list={[
                      'flex items-center gap-3 px-8 py-2 text-sm font-body transition-all duration-150 rounded-sm',
                      isActive(item.href)
                        ? 'text-ivory bg-white/5 border-l-2 border-blush-deep font-medium'
                        : 'text-champagne/60 hover:text-ivory hover:translate-x-1'
                    ]}
                  >
                    {item.label}
                  </a>
                ))}
              </div>
            </div>
          );
        })}
      </nav>

      <!-- Footer actions -->
      <div class="px-3 py-4 border-t border-white/10 shrink-0 space-y-1">
        <a href="/" target="_blank" class="flex items-center gap-3 px-3 py-2 text-sm font-body text-champagne/70 hover:text-ivory hover:bg-white/5 transition-colors duration-150 rounded-sm">
          Bekijk Website ↗
        </a>
        <form action="/api/auth/logout" method="POST">
          <button type="submit" class="w-full text-left flex items-center gap-3 px-3 py-2 text-sm font-body text-champagne/70 hover:text-red-300 hover:bg-white/5 transition-colors duration-150 rounded-sm">
            Uitloggen
          </button>
        </form>
      </div>
    </aside>

    <!-- Mobile backdrop -->
    <div
      id="sidebar-backdrop"
      class="fixed inset-0 bg-charcoal/60 z-40 hidden md:hidden"
      aria-hidden="true"
    ></div>

    <!-- Mobile top bar -->
    <header class="fixed top-0 left-0 right-0 h-14 bg-charcoal flex items-center justify-between px-4 z-30 md:hidden border-b border-white/10">
      <button
        id="hamburger-btn"
        class="text-ivory p-2 -ml-2"
        aria-label="Menu openen"
        aria-expanded="false"
        aria-controls="admin-sidebar"
      >
        <svg id="hamburger-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <rect y="3" width="20" height="2" rx="1"/>
          <rect y="9" width="20" height="2" rx="1"/>
          <rect y="15" width="20" height="2" rx="1"/>
        </svg>
        <svg id="close-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="hidden">
          <path d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"/>
        </svg>
      </button>
      <span class="font-display italic text-ivory text-lg absolute left-1/2 -translate-x-1/2">{title}</span>
    </header>

    <!-- Main content -->
    <main class="md:ml-60 min-h-screen pt-14 md:pt-0">
      <slot />
    </main>

    <script>
      const sidebar = document.getElementById('admin-sidebar')!;
      const backdrop = document.getElementById('sidebar-backdrop')!;
      const hamburgerBtn = document.getElementById('hamburger-btn')!;
      const hamburgerIcon = document.getElementById('hamburger-icon')!;
      const closeIcon = document.getElementById('close-icon')!;

      function openSidebar() {
        sidebar.classList.remove('-translate-x-full');
        backdrop.classList.remove('hidden');
        hamburgerIcon.classList.add('hidden');
        closeIcon.classList.remove('hidden');
        hamburgerBtn.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }

      function closeSidebar() {
        sidebar.classList.add('-translate-x-full');
        backdrop.classList.add('hidden');
        hamburgerIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        hamburgerBtn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }

      hamburgerBtn.addEventListener('click', () => {
        const isOpen = !sidebar.classList.contains('-translate-x-full');
        isOpen ? closeSidebar() : openSidebar();
      });

      backdrop.addEventListener('click', closeSidebar);

      // Close on escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeSidebar();
      });

      // Accordion Logic
      document.querySelectorAll('[data-collapse-trigger]').forEach(trigger => {
        trigger.addEventListener('click', () => {
          const idx = trigger.getAttribute('data-collapse-trigger');
          const panel = document.getElementById(`collapse-${idx}`);
          const chevron = document.querySelector(`[data-chevron="${idx}"]`);
          
          if (panel?.classList.contains('max-h-0')) {
            panel.classList.remove('max-h-0');
            panel.classList.add('max-h-[500px]');
            chevron?.classList.add('rotate-180');
          } else {
            panel?.classList.add('max-h-0');
            panel?.classList.remove('max-h-[500px]');
            chevron?.classList.remove('rotate-180');
          }
        });
      });
    </script>
  </body>
</html>
