---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import MobileTabBar from '../components/MobileTabBar.astro';
import { getSiteSettings } from '../lib/settings';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  ogType?: string;
}

const { title, description: propDescription, ogImage, canonical, ogType = 'website' } = Astro.props;
const siteUrl = import.meta.env.SITE || 'https://www.mariagebruidsmode.nl';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;

const settings = await getSiteSettings(Astro);

const colors = settings?.colors || {};
const typography = settings?.typography || {};
const ui = settings?.ui_styles || {};
const meta = settings?.site_metadata || {};
const contact = settings?.contact_info || {};

const pageDescription = propDescription || meta.description || 'Exclusieve bruidsmode in de regio Eindhoven. Trouwjurken, trouwpakken en accessoires. Persoonlijk advies in onze boutique in Geldrop.';
const pageOgImage = ogImage || meta.og_image || `${siteUrl}/images/og-default.jpg`;

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: contact.name || 'Mariage Bruidsmode',
  url: siteUrl,
  telephone: contact.phone || '+31402863673',
  email: contact.email || 'info@mariagebruidsmode.nl',
  address: {
    '@type': 'PostalAddress',
    streetAddress: contact.address || 'Langstraat 128',
    postalCode: contact.postal_code || '5664 GK',
    addressLocality: contact.city || 'Geldrop',
    addressCountry: 'NL',
  },
  openingHours: contact.opening_hours || undefined,
  image: pageOgImage,
};
---

<!doctype html>
<html lang="nl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href={`https://fonts.googleapis.com/css2?family=${typography.heading_font?.replace(/ /g, '+')}:wght@${typography.heading_weight}&family=${typography.body_font?.replace(/ /g, '+')}:wght@${typography.body_weight}&display=swap`} rel="stylesheet">
		<title>{title} | {meta.title || 'Mariage Bruidsmode'}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={meta.title || 'Mariage Bruidsmode'} />
    <meta property="og:title" content={`${title} | ${meta.title || 'Mariage Bruidsmode'}`} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={pageOgImage} />
    <meta property="og:locale" content="nl_NL" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | ${meta.title || 'Mariage Bruidsmode'}`} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={pageOgImage} />

    <!-- JSON-LD: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />

    <style define:vars={{
      colorPrimary: colors.primary,
      colorSecondary: colors.secondary,
      colorAccent: colors.accent,
      colorBlush: colors.blush,
      colorTaupe: colors.taupe,
      colorChampagne: colors.champagne,
      colorLinen: colors.linen,
      colorCharcoal: colors.charcoal,
      colorCream: colors.cream,
      colorBlushDeep: colors.blush_deep,
      fontHeading: typography.heading_font,
      fontBody: typography.body_font,
      baseSize: typography.base_size,
      borderRadius: ui.border_radius,
      buttonPadding: ui.button_padding,
      headingWeight: typography.heading_weight,
    }}>
      :root {
        --color-primary-dynamic: var(--colorPrimary);
        --color-secondary-dynamic: var(--colorSecondary);
        --color-accent-dynamic: var(--colorAccent);
        --color-blush-dynamic: var(--colorBlush);
        --color-taupe-dynamic: var(--colorTaupe);
        --color-champagne-dynamic: var(--colorChampagne);
        --color-linen-dynamic: var(--colorLinen);
        --color-charcoal-dynamic: var(--colorCharcoal);
        --color-cream-dynamic: var(--colorCream);
        --color-blush-deep-dynamic: var(--colorBlushDeep);
        
        --font-heading-dynamic: var(--fontHeading);
        --font-body-dynamic: var(--fontBody);
        --base-font-size-dynamic: var(--baseSize);
        --heading-weight-dynamic: var(--headingWeight);
        
        --radius-base-dynamic: var(--borderRadius);
        --button-padding-dynamic: var(--buttonPadding);
      }

      body {
        font-family: var(--font-body-dynamic), var(--font-body), sans-serif;
        font-size: var(--base-font-size-dynamic, 16px);
      }

      h1, h2, h3, h4, h5, h6, .font-serif {
        font-family: var(--font-heading-dynamic), var(--font-display), serif;
        font-weight: var(--heading-weight-dynamic, 400);
      }
    </style>
	</head>
	<body>
    <script>document.documentElement.style.setProperty('--announcement-height', '36px');</script>
    <a href="#main-content" class="skip-link">Direct naar inhoud</a>
    <AnnouncementBar />
    <Header />
    <main id="main-content" tabindex="-1" class="pb-[60px] md:pb-0" style="padding-top: calc(72px + var(--announcement-height, 36px))">
		  <slot />
    </main>
    <Footer />

    <!-- Back-to-top button -->
    <button
      id="back-to-top"
      aria-label="Terug naar boven"
      class="fixed bottom-[76px] right-4 md:bottom-6 z-40 w-10 h-10 bg-charcoal text-warm-white flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 shadow-card"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>

    <MobileTabBar />

    <!-- Floating mobile CTA -->
    <div
      id="mobile-cta"
      class="fixed bottom-[60px] left-0 right-0 z-40 md:hidden px-4 pb-4 pt-2 bg-gradient-to-t from-ivory to-transparent opacity-0 pointer-events-none transition-opacity duration-300"
    >
      <a href="/afspraak-maken" class="btn-blush w-full flex items-center justify-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        Afspraak maken
      </a>
    </div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>

<script>
  const backToTop = document.getElementById('back-to-top');
  const mobileCta = document.getElementById('mobile-cta');

  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY;

    // Back-to-top: show after 400px
    if (scrolled > 400) {
      backToTop?.classList.remove('opacity-0', 'pointer-events-none');
    } else {
      backToTop?.classList.add('opacity-0', 'pointer-events-none');
    }

    // Mobile CTA: show after 300px
    if (scrolled > 300) {
      mobileCta?.classList.remove('opacity-0', 'pointer-events-none');
    } else {
      mobileCta?.classList.add('opacity-0', 'pointer-events-none');
    }
  }, { passive: true });

  backToTop?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>

<script>
  // Visitor tracking — skip admin and landing pages
  (function () {
    const path = window.location.pathname;
    if (path.startsWith('/admin') || path.startsWith('/lp/')) return;

    // Session ID (tab-scoped via sessionStorage)
    let sessionId = sessionStorage.getItem('mb_session_id');
    if (!sessionId) {
      try {
        sessionId = crypto.randomUUID();
      } catch {
        sessionId = Date.now().toString(36) + Math.random().toString(36).slice(2);
      }
      sessionStorage.setItem('mb_session_id', sessionId);
    }

    function sendEvent(eventType: string, metadata?: Record<string, string>) {
      fetch('/api/track', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          session_id: sessionId,
          page_path: window.location.pathname,
          page_title: document.title,
          referrer: document.referrer || null,
          event_type: eventType,
          metadata: metadata || {},
        }),
        keepalive: true,
      }).catch(() => {});
    }

    // Pageview
    document.addEventListener('DOMContentLoaded', () => {
      sendEvent('pageview');
    });

    // CTA click tracking
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const el = target.closest('a, button') as HTMLElement | null;
      if (!el) return;

      const href = (el as HTMLAnchorElement).href || '';
      const isCta =
        el.hasAttribute('data-track') ||
        href.includes('/afspraak-maken') ||
        href.includes('savviihq.com') ||
        el.classList.contains('btn-premium') ||
        el.classList.contains('btn-gold') ||
        el.classList.contains('btn-blush');

      if (isCta) {
        const label = el.textContent?.trim().slice(0, 100) || '';
        const hrefVal = href ? new URL(href).pathname + new URL(href).search : '';
        sendEvent('cta_click', { href: hrefVal, label, element: el.tagName.toLowerCase() });
      }
    }, { passive: true });

    // Form tracking
    const trackedFormStarts = new Set<HTMLFormElement>();
    document.addEventListener('focusin', (e) => {
      const form = (e.target as HTMLElement).closest('form') as HTMLFormElement | null;
      if (!form || trackedFormStarts.has(form)) return;
      trackedFormStarts.add(form);
      sendEvent('form_start', { form_action: form.action || '' });
    }, { passive: true });

    document.addEventListener('submit', (e) => {
      const form = e.target as HTMLFormElement;
      sendEvent('form_submit', { form_action: form.action || '' });
    }, { passive: true });
  })();
</script>
