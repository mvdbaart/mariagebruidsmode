  </section>

  <!-- Product Grid -->
  <section class="pb-16 bg-white">
    <div class="container mx-auto px-4 lg:px-8 max-w-[1400px]">
      <div class="grid grid-cols-2 md:grid-cols-3 gap-1 md:gap-4">
