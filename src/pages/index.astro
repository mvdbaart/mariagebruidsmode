---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';
import { CATEGORIEEN } from '../lib/productAttributes';
import { normalizeHomepageSettings, type HomepageSectionId } from '../lib/homepageSections';
import {
  getDefaultHomepageCategorySliderItems,
  normalizeHomepageCategorySliderItems,
} from '../lib/homepageCategorySlider';
import HomepageVirtualTryOnIllustration from '../components/HomepageVirtualTryOnIllustration.astro';

const [
  { data: latestProducts },
  { data: featuredWedding },
  { data: latestWeddings },
  { data: latestPosts },
  { data: settings },
  { data: employees },
] = await Promise.all([
  supabase.from('products').select('id, name, slug, brand, images, collections(title, type)').order('created_at', { ascending: false }).limit(8),
  supabase.from('real_weddings').select('id, slug, bride_name, groom_name, cover_image, wedding_date').order('wedding_date', { ascending: false }).limit(1).maybeSingle(),
  supabase.from('real_weddings').select('id, slug, bride_name, groom_name, cover_image').order('wedding_date', { ascending: false }).limit(3),
  supabase.from('blog_posts').select('id, slug, title, excerpt, cover_image, published_at').order('published_at', { ascending: false }).limit(3),
  supabase.from('site_settings').select('homepage').eq('id', 'current').single(),
  supabase
    .from('employees')
    .select('id, first_name, last_name, role, bio, profile_photo_url, specialisms, sort_order, show_on_team, team_sort_order')
    .eq('is_active', true)
    .eq('show_on_team', true)
    .order('team_sort_order', { ascending: true, nullsFirst: true })
    .order('first_name', { ascending: true }),
]);

const hp = normalizeHomepageSettings(settings?.homepage ?? {});
const parseIntSetting = (value: unknown, fallback: number, min: number, max: number) => {
  const parsed = Number.parseInt(String(value ?? ''), 10);
  if (!Number.isFinite(parsed)) return fallback;
  return Math.min(max, Math.max(min, parsed));
};
const sectionContent = hp.sections_content;
const sectionOrderMap = hp.sections_order.reduce((acc, sectionId, index) => {
  acc[sectionId] = index;
  return acc;
}, {} as Record<HomepageSectionId, number>);
const isSectionVisible = (sectionId: HomepageSectionId) => hp.sections_visibility[sectionId] !== false;
const sectionStyle = (sectionId: HomepageSectionId) => `order:${sectionOrderMap[sectionId] ?? 999};`;
const buildUrl = (path: string, params: Record<string, string | undefined>) => {
  const url = new URL(path, 'https://www.mariagebruidsmode.nl');
  for (const [key, value] of Object.entries(params)) {
    if (value && value.trim().length > 0) {
      url.searchParams.set(key, value.trim());
    }
  }
  return `${url.pathname}${url.search}`;
};

// Fallback hero: pick a suit product image
const heroFallbackImage = '/wp-content/uploads/2023/07/Home-Hero-img.jpg';

const collectionCardMeta: Record<string, { subtitle: string; image: string }> = {
  romantisch: {
    subtitle: 'Bianco Evento, San Patrick, Ladybird',
    image: '/images/bruid/Bianco Evento/model-kerena/bianco-evento-trouwjurk-kerena_0.webp',
  },
  bohemian: {
    subtitle: 'Libelle Bridal, Morilee, Cosmobella',
    image: '/images/bruid/Cosmobella/model-8208/cosmobella-trouwjurk-8208_0.webp',
  },
  klassiek: {
    subtitle: 'Demetrios, White One, Modeca',
    image: '/images/bruid/White One/model-maitai/white-one-trouwjurk-maitai_0.webp',
  },
  strak: {
    subtitle: 'Etoile, Enzoani, Daniela di Marino',
    image: '/images/bruid/Daniela di Marino/model-6342/trouwjurk-daniela-di-marino-6342_0.webp',
  },
  vintage: {
    subtitle: 'Dany Tabet, Oksana Mukha, Maggie Sottero',
    image: '/images/bruid/Dany Tabet/model-helena/dany-tabet-trouwjurk-helena_0.webp',
  },
  outlet: {
    subtitle: 'Showroom- en samplemodellen',
    image: '/images/bruid/White One/model-gentian/trouwjurk-outlet-white-one-gentian_0.webp',
  },
};

const collectionCards = CATEGORIEEN.map(({ key, label }) => ({
  categoryKey: key,
  title: label,
  subtitle: collectionCardMeta[key]?.subtitle ?? '',
  image: collectionCardMeta[key]?.image ?? '/images/jurkvormen/a-lijn.png',
})).filter((card) => card.image && card.subtitle);

const mensBrandCards = [
  {
    brandKey: 'Immediate',
    kind: 'brand',
    title: 'Immediate',
    subtitle: 'Modern & veelzijdig',
  },
  {
    brandKey: 'Crinoligne',
    kind: 'brand',
    title: 'Crinoligne',
    subtitle: 'Klassiek & Italiaans',
  },
  {
    brandKey: 'Roberto Vicentti',
    kind: 'brand',
    title: 'Roberto Vicentti',
    subtitle: 'Mediterraans & elegant',
  },
  {
    brandKey: 'Cleofe Finati',
    kind: 'brand',
    title: 'Cleofe Finati',
    subtitle: 'Hoog couture herenmode',
  },
  {
    categoryKey: 'modern',
    kind: 'service',
    title: 'Maatwerk',
    subtitle: 'Persoonlijke afstemming & pasvorm',
  },
  {
    categoryKey: 'klassiek',
    kind: 'service',
    title: 'Ceremonie',
    subtitle: 'Feestelijk & volledig gestyled',
  },
];

const styleChips = [
  { label: String(sectionContent.style_chips.chip1_label), href: String(sectionContent.style_chips.chip1_url) },
  { label: String(sectionContent.style_chips.chip2_label), href: String(sectionContent.style_chips.chip2_url) },
  { label: String(sectionContent.style_chips.chip3_label), href: String(sectionContent.style_chips.chip3_url) },
  { label: String(sectionContent.style_chips.chip4_label), href: String(sectionContent.style_chips.chip4_url) },
  { label: String(sectionContent.style_chips.chip5_label), href: String(sectionContent.style_chips.chip5_url) },
].filter((chip) => chip.label.trim().length > 0 && chip.href.trim().length > 0);

const homepageCategorySliderItems = normalizeHomepageCategorySliderItems(
  hp.category_slider_items ?? getDefaultHomepageCategorySliderItems(),
);

const virtualTryOnSteps = [
  {
    number: '01',
    title: 'Kies je favoriete stijl of merk',
    text: 'Begin met de sfeer die bij jou past en selecteer de collectie waarin je wilt rondkijken.',
  },
  {
    number: '02',
    title: 'Kies je favoriete jurk',
    text: 'Open een jurk op de productpagina en gebruik de virtuele pasfunctie als extra eerste indruk.',
  },
  {
    number: '03',
    title: 'Upload een geschikte foto van jezelf',
    text: 'Gebruik een foto van voren, met goed licht en liefst full-body, zodat de preview zo realistisch mogelijk wordt.',
  },
  {
    number: '04',
    title: 'Bekijk direct hoe het je staat',
    text: 'Je krijgt een AI-preview als voorbereiding op je echte pasmoment in de bruidszaak.',
  },
];

const virtualTryOnPills = [
  'Geen standaard slider',
  'Volledig virtueel',
  'Voor je winkelbezoek',
];

const featuredWeddingCard = {
  slug: featuredWedding?.slug ?? '',
  bride_name: featuredWedding?.bride_name ?? 'Mariage',
  groom_name: featuredWedding?.groom_name ?? 'Bruidsmode',
  cover_image: featuredWedding?.cover_image ?? '/images/jurkvormen/a-lijn-1.png',
};

const galleryFallbacks = [
  '/images/jurkvormen/a-lijn.png',
  '/images/jurkvormen/a-lijn-1.png',
  '/images/jurkvormen/a-lijn-silhouet.png',
  '/images/jurkvormen/photoshop-silhouet2.png',
  '/wp-content/uploads/2023/07/Home-Hero-img.jpg',
  '/images/logo/Social-Media-profielfoto.jpg',
];

const blogFallbacks = [
  '/images/jurkvormen/a-lijn.png',
  '/images/jurkvormen/a-lijn-1.png',
  '/images/jurkvormen/photoshop-silhouet2.png',
];

const galleryImages = (latestProducts ?? [])
  .map((p) => {
    const img = p.images?.[0];
    return {
      src: (img && img.length > 0) ? img : null,
      alt: p.name,
      href: `/product/${p.slug}`,
    };
  })
  .filter((item) => item.src)
  .slice(0, 6);

const galleryItems = galleryImages.length
  ? galleryImages
  : galleryFallbacks.slice(0, 6).map((src, i) => ({ src, alt: `Galerij foto ${i + 1}`, href: '/trouwjurken' }));
const maxGridItems = parseIntSetting(sectionContent.product_grid.max_items, 6, 3, 12);
const featuredEmployees = ((employees ?? []) as Array<{
  id: string;
  first_name: string;
  last_name: string;
  role?: string;
  bio?: string;
  profile_photo_url?: string;
  specialisms?: string[];
  sort_order?: number;
  show_on_team?: boolean;
  team_sort_order?: number;
}>).slice(0, 2);
---

<Layout title="Home">
  <div class="flex flex-col">

  <!-- ===== HERO ===== -->
  <section id="hero" class={`relative overflow-hidden bg-gradient-to-b from-ivory via-white to-ivory/70${isSectionVisible('hero') ? '' : ' hidden'}`} style={sectionStyle('hero')}>
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-24 left-1/2 h-72 w-72 -translate-x-1/2 rounded-full bg-blush/15 blur-3xl"></div>
      <div class="absolute bottom-0 right-[-8rem] h-80 w-80 rounded-full bg-champagne/35 blur-3xl"></div>
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-champagne/60 to-transparent"></div>
    </div>

    <div class="container mx-auto px-4 sm:px-6 py-16 md:py-24 lg:py-28 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-[1.08fr_0.92fr] gap-10 lg:gap-14 items-center">
        <div class="max-w-2xl">
          <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-5">{String(sectionContent.hero.eyebrow)}</p>
          <h1 class="font-display font-normal text-charcoal leading-[0.95] mb-6" style="font-size: clamp(42px, 7vw, 84px);">
            {String(sectionContent.hero.title)}
          </h1>
          <p class="text-base md:text-lg text-taupe font-light leading-relaxed max-w-xl mb-8">
            {String(sectionContent.hero.subtitle)}
          </p>

          <div class="flex flex-wrap gap-3 mb-8">
            {virtualTryOnPills.map((pill) => (
              <span class="inline-flex items-center rounded-full border border-champagne bg-white px-4 py-2 text-[10px] tracking-[0.22em] uppercase text-taupe font-body shadow-soft">
                {pill}
              </span>
            ))}
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 mb-8">
            {virtualTryOnSteps.map((step) => (
              <article class="border border-champagne bg-white/85 p-4 shadow-soft">
                <p class="text-[9px] tracking-[0.35em] uppercase text-blush-deep font-body mb-3">{step.number}</p>
                <h2 class="font-display text-charcoal text-lg leading-tight mb-2">{step.title}</h2>
                <p class="text-sm text-taupe font-light leading-relaxed">{step.text}</p>
              </article>
            ))}
          </div>

          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 md:gap-4">
            <a href={String(sectionContent.hero.button1_url)} class="btn-blush w-full sm:w-auto px-8 md:px-10 py-4">
              {String(sectionContent.hero.button1_text)}
            </a>
            <a href={String(sectionContent.hero.button2_url)} class="btn-gold w-full sm:w-auto px-8 md:px-10 py-4">
              {String(sectionContent.hero.button2_text)}
            </a>
          </div>
        </div>

        <HomepageVirtualTryOnIllustration />
      </div>
    </div>
  </section>

  <section
    class={`bg-white border-b border-champagne/60 py-8 md:py-10 overflow-hidden${isSectionVisible('category_slider') ? '' : ' hidden'}`}
    style={sectionStyle('category_slider')}
  >
    <div class="container mx-auto px-4 sm:px-6 max-w-7xl">
      <h2 class="font-display text-2xl md:text-4xl text-charcoal text-center mb-6 md:mb-8">Ontdek jouw stijl</h2>
      <div class="category-slider-track-wrap">
        <div class="category-slider-track" aria-label="Categorie slider">
          {[...homepageCategorySliderItems, ...homepageCategorySliderItems].map((item, index) => (
            <a
              href={buildUrl('/trouwjurken', { categorie: item.id })}
              class="category-slider-card group"
              aria-label={`Bekijk ${item.label}`}
              data-clone={index >= homepageCategorySliderItems.length ? 'true' : 'false'}
            >
              <div class="aspect-[4/5] bg-ivory overflow-hidden">
                <img
                  src={item.image_url}
                  alt={item.label}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
              <div class="flex items-center justify-between gap-2 pt-3">
                <span class="font-display text-base md:text-lg text-charcoal">{item.label}</span>
                <span aria-hidden="true" class="text-taupe group-hover:text-charcoal transition-colors">→</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Shop by Style (Mobile only) -->
  <section class={`lg:hidden bg-[#FAF9F6] py-5 border-b border-champagne overflow-x-auto no-scrollbar${isSectionVisible('style_chips') ? '' : ' hidden'}`} style={sectionStyle('style_chips')}>
    <div class="flex items-center gap-7 px-5 min-w-max">
      {styleChips.map((style) => (
        <a href={style.href} class="flex flex-col items-center gap-2 group">
          <div class="w-10 h-10 flex items-center justify-center text-charcoal/30">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="w-full h-full group-hover:text-blush-deep transition-colors"><path d="M12 4L4 20H20L12 4Z"/></svg>
          </div>
          <span class="text-[9px] tracking-widest uppercase font-body text-charcoal/60 group-hover:text-blush-deep transition-colors">{style.label}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- The Collections Grid -->
  <section class={`py-20 md:py-28 bg-gradient-to-b from-white to-ivory/40 reveal-fade-up${isSectionVisible('collections') ? '' : ' hidden'}`} style={sectionStyle('collections')}>
    <div class="container mx-auto px-4 sm:px-6 max-w-7xl">
      <div class="text-center max-w-3xl mx-auto mb-12 md:mb-16">
        <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-4">Collecties</p>
        <h2 class="font-display text-4xl md:text-6xl text-charcoal leading-tight mb-4">
          {String(sectionContent.collections.heading)}
        </h2>
        <p class="romance-copy">
          {String(sectionContent.collections.subheading)}
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {collectionCards.map((card) => (
          <a href={buildUrl('/trouwjurken', { categorie: card.categoryKey })} class="group flex flex-col bg-white border border-champagne shadow-soft overflow-hidden transition-all duration-300 hover:border-blush-deep hover:shadow-card">
            <div class="aspect-[4/5] bg-ivory p-3 sm:p-4 overflow-hidden">
              <img
                src={card.image}
                alt={card.title}
                class="w-full h-full object-contain transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="flex flex-col gap-2 px-5 py-5 text-center">
              <p class="text-[10px] tracking-[0.3em] uppercase text-taupe font-body">Bruidscollectie</p>
              <h3 class="font-display text-2xl text-charcoal">{card.title}</h3>
              <p class="text-xs text-taupe leading-relaxed">{card.subtitle}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Herenmodemerken -->
  <section class={`py-20 md:py-28 bg-ivory border-t border-champagne reveal-fade-up${isSectionVisible('mens_brands') ? '' : ' hidden'}`} style={sectionStyle('mens_brands')}>
    <div class="container mx-auto px-4 sm:px-6 max-w-7xl">
      <div class="text-center max-w-3xl mx-auto mb-12 md:mb-16">
        <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-4">Herenmode</p>
        <h2 class="font-display text-4xl md:text-6xl text-charcoal leading-tight mb-4">
          Herenmodemerken
        </h2>
        <p class="romance-copy">
          Een selectie van herenmerken en pasvormopties voor het complete trouwpak, in dezelfde visuele stijl als onze bruidscategorieën.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {mensBrandCards.map((card) => (
          <a
            href={card.brandKey
              ? buildUrl('/trouwpakken', { merk: card.brandKey })
              : buildUrl('/trouwpakken', { categorie: card.categoryKey })}
            class="group flex flex-col bg-white border border-champagne shadow-soft overflow-hidden transition-all duration-300 hover:border-blush-deep hover:shadow-card"
          >
            <div class="aspect-[4/5] bg-ivory p-4 sm:p-6 flex items-center justify-center overflow-hidden">
              <div class="w-full h-full border border-champagne/60 bg-white/70 flex flex-col items-center justify-center text-center px-4">
                <p class="text-[9px] tracking-[0.35em] uppercase text-taupe font-body mb-4">
                  {card.kind === 'brand' ? 'Herenmerk' : 'Pasvorm'}
                </p>
                <h3 class="font-display text-charcoal leading-tight text-[2rem] sm:text-[2.2rem] md:text-[2.6rem] max-w-[10ch]">
                  {card.title}
                </h3>
                <div class="mt-5 h-px w-12 bg-champagne"></div>
              </div>
            </div>
            <div class="flex flex-col gap-2 px-5 py-5 text-center">
              <p class="text-xs text-taupe leading-relaxed">{card.subtitle}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Product Grid -->
  <section class={`pb-14 md:pb-16 bg-white${isSectionVisible('product_grid') ? '' : ' hidden'}`} style={sectionStyle('product_grid')}>
    <div class="container mx-auto px-4 lg:px-8 max-w-[1400px]">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 md:gap-4">
        {galleryItems.slice(0, maxGridItems).map((item, index) => (
          <article class="flex flex-col mb-4 romance-panel p-2 md:p-3">
            <a href={item.href} class="block relative overflow-hidden aspect-[3/4] group mb-3">
              <img src={item.src!} alt={item.alt} class={`w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 ${index % 3 === 0 ? 'animate-pan-right' : index % 3 === 1 ? 'animate-pan-left' : 'animate-zoom'}`} loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-charcoal/70 via-charcoal/20 to-transparent flex flex-col justify-end items-center pb-7 opacity-95 transition-opacity">
                <span class="text-white font-display text-xl mb-1 text-center px-3">{item.alt.split(' ')[0] || 'Merk'}</span>
                <span class="text-white/85 text-[10px] uppercase tracking-widest border-t border-white/40 pt-1 px-4 text-center">{item.alt}</span>
              </div>
            </a>
            <div class="flex items-start justify-between px-1">
              <div class="flex items-center gap-2 group cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-gray-400 group-hover:text-red-500 transition-colors">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                </svg>
                <span class="text-xs text-gray-500 font-light">Sla jurk op</span>
              </div>
              <a href={item.href} class="text-xs text-gray-500 font-light hover:text-black">Bekijk merk &nbsp;›</a>
            </div>
            <p class="text-[11px] text-gray-400 font-light mt-3 px-1 leading-relaxed">
              {String(sectionContent.product_grid.description)}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Real Bride & Stories (Asymmetric & Premium) -->
  <section class={`py-20 md:py-32 bg-white relative overflow-hidden reveal-fade-up${isSectionVisible('stories') ? '' : ' hidden'}`} style={sectionStyle('stories')}>
    <div class="container mx-auto px-4 sm:px-6 relative z-10">
      <div class="flex flex-col md:flex-row items-start md:items-end justify-between mb-12 md:mb-16 gap-6 md:gap-8">
        <div class="max-w-2xl text-left">
          <p class="font-signature text-blush-deep text-3xl md:text-4xl mb-3 md:mb-4 lowercase opacity-80">{String(sectionContent.stories.eyebrow)}</p>
          <h2 class="font-display text-4xl md:text-7xl text-charcoal leading-[0.95] md:leading-[0.9] italic">
            {String(sectionContent.stories.heading)}
          </h2>
        </div>
        <p class="text-[10px] tracking-[0.25em] uppercase text-taupe font-body max-w-xs md:text-right leading-relaxed mb-1">
          {String(sectionContent.stories.description)}
        </p>
      </div>

      <!-- Asymmetric Story Grid -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 h-auto md:h-[600px]">
        <div class="md:col-span-5 relative group overflow-hidden bg-ivory aspect-[4/5] md:aspect-auto">
          <img src="https://images.unsplash.com/photo-1546193430-c2d20544977a?auto=format&fit=crop&q=80&w=800" alt="Real Bride" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
          <div class="absolute inset-0 bg-charcoal/30 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-10">
            <p class="font-signature text-white text-3xl mb-3 lowercase line-clamp-2 italic">"De jurk van mijn dromen, het voelde als een sprookje."</p>
            <p class="text-white/80 text-[10px] tracking-[0.3em] uppercase font-body border-t border-white/20 pt-3 inline-block">Emma & Marc</p>
          </div>
        </div>
        <div class="md:col-span-3 grid grid-rows-2 gap-4 md:gap-6">
          <div class="relative group overflow-hidden aspect-[4/5] md:aspect-auto">
            <img src="https://images.unsplash.com/photo-1511795409834-ef04bbd61622?auto=format&fit=crop&q=80&w=600" alt="Wedding detail" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
          </div>
          <div class="relative group overflow-hidden aspect-[4/5] md:aspect-auto">
            <img src="https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&q=80&w=600" alt="Ceremony" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
          </div>
        </div>
