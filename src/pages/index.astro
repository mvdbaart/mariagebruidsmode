<script>
  // ===== HERO SLIDER =====
  const track = document.getElementById('hero-track') as HTMLElement | null;
  const slider = document.getElementById('hero-slider') as HTMLElement | null;
  const dots = document.querySelectorAll<HTMLButtonElement>('.hero-dot');
  const total = track?.children.length ?? 0;

  if (track && total > 0) {
    const autoplayMsRaw = Number.parseInt(slider?.dataset.autoplayMs ?? '', 10);
    const transitionMsRaw = Number.parseInt(slider?.dataset.transitionMs ?? '', 10);
    const autoplayMs = Number.isFinite(autoplayMsRaw) ? autoplayMsRaw : 5000;
    const transitionMs = Number.isFinite(transitionMsRaw) ? transitionMsRaw : 700;
    const pauseOnHover = slider?.dataset.pauseOnHover === 'true';

    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    let isHoverPaused = false;

    track.style.transition = `transform ${transitionMs}ms ease`;

    // Use pixel offsets so % is not relative to track's own (= N×slide) width
    function slideWidth() {
      return slider?.clientWidth ?? window.innerWidth;
    }

    function goTo(index: number) {
      current = ((index % total) + total) % total;
      track!.style.transform = `translateX(${-current * slideWidth()}px)`;
      if (dots.length > 0) {
        dots.forEach((d, i) => {
          d.classList.toggle('bg-white', i === current);
          d.classList.toggle('bg-white/40', i !== current);
        });
      }
    }

    // Re-snap on resize (no transition flash)
    window.addEventListener('resize', () => {
      track!.style.transition = 'none';
      track!.style.transform = `translateX(${-current * slideWidth()}px)`;
      requestAnimationFrame(() => { track!.style.transition = ''; });
    }, { passive: true });

    function startTimer() {
      if (timer) clearInterval(timer);
      if (total > 1) {
        timer = setInterval(() => {
          if (!isHoverPaused) goTo(current + 1);
        }, autoplayMs);
      }
    }

    document.getElementById('hero-prev')?.addEventListener('click', () => { goTo(current - 1); startTimer(); });
    document.getElementById('hero-next')?.addEventListener('click', () => { goTo(current + 1); startTimer(); });
    dots.forEach((dot, i) => dot.addEventListener('click', () => { goTo(i); startTimer(); }));

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { goTo(current - 1); startTimer(); }
      if (e.key === 'ArrowRight') { goTo(current + 1); startTimer(); }
    });

    let touchStartX = 0;
    track.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', (e) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) { goTo(current + (diff > 0 ? 1 : -1)); startTimer(); }
    }, { passive: true });

    if (pauseOnHover && slider) {
      slider.addEventListener('mouseenter', () => { isHoverPaused = true; });
      slider.addEventListener('mouseleave', () => { isHoverPaused = false; });
    }

    startTimer();
  }

  // ===== CONTACT FORM =====
  const quickForm = document.getElementById('quick-contact-form') as HTMLFormElement | null;
  const quickStatus = document.getElementById('quick-contact-status');
  const quickSubmitBtn = document.getElementById('quick-submit-btn') as HTMLButtonElement | null;

  quickForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!quickStatus || !quickForm) return;

    if (quickSubmitBtn) {
      quickSubmitBtn.disabled = true;
      quickSubmitBtn.textContent = 'BEZIG...';
    }
    quickStatus.textContent = '';
    quickStatus.className = 'text-xs text-taupe mt-3 hidden';

    const formData = new FormData(quickForm);
    const payload = {
      full_name: formData.get('full_name'),
      email: formData.get('email'),
      preferred_date: formData.get('preferred_date'),
      appointment_type: formData.get('appointment_type'),
      phone: null,
      message: 'Snelle aanvraag vanaf homepage',
    };

    try {
      const response = await fetch('/api/appointments', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!response.ok) throw new Error('request failed');
      quickStatus.textContent = 'Bedankt, we nemen snel contact op.';
      quickStatus.className = 'text-xs text-green-700 mt-3 block';
      quickForm.reset();
      if (quickSubmitBtn) {
        quickSubmitBtn.disabled = false;
        quickSubmitBtn.textContent = 'VERSTUREN';
      }
    } catch {
      quickStatus.textContent = 'Versturen mislukt. Probeer opnieuw.';
      quickStatus.className = 'text-xs text-red-600 mt-3 block';
      if (quickSubmitBtn) {
        quickSubmitBtn.disabled = false;
        quickSubmitBtn.textContent = 'VERSTUREN';
      }
    }
  });
</script>
