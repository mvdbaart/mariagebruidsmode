          <h2 class="font-display text-4xl md:text-5xl text-charcoal">De mensen achter <em class="italic font-light text-taupe">Mariage</em></h2>
        </div>
        <a href="/het-team" class="text-[10px] tracking-[0.3em] uppercase text-charcoal border-b border-charcoal/20 pb-1 hover:text-blush-deep hover:border-blush-deep transition-all self-start">Bekijk het volledige team</a>
      </div>

      {featuredEmployees.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {featuredEmployees.map((employee) => (
            <article class="bg-white/80 border border-champagne rounded-[28px] p-6 md:p-8 shadow-soft">
              <div class="flex items-start gap-5">
                <div class="w-24 h-24 rounded-full overflow-hidden bg-champagne/30 flex items-center justify-center flex-shrink-0">
                  {employee.profile_photo_url
                    ? <img src={employee.profile_photo_url} alt={`${employee.first_name} ${employee.last_name}`} class="w-full h-full object-cover" loading="lazy" />
                    : <span class="text-2xl font-display text-charcoal/40">{employee.first_name.charAt(0)}{employee.last_name.charAt(0)}</span>}
                </div>
                <div class="min-w-0">
                  <p class="text-[10px] tracking-[0.3em] uppercase text-blush-deep font-body mb-2">{employee.role || 'Teamlid'}</p>
                  <h3 class="font-display text-2xl text-charcoal mb-3">{employee.first_name} {employee.last_name}</h3>
                  {employee.bio && <p class="text-sm leading-relaxed text-taupe mb-4">{employee.bio}</p>}
                  {employee.specialisms && employee.specialisms.length > 0 && (
                    <div class="flex flex-wrap gap-2">
                      {employee.specialisms.map((specialism) => (
                        <span class="inline-flex items-center rounded-full border border-blush-deep/15 bg-blush-deep/5 px-3 py-1 text-[9px] uppercase tracking-[0.18em] text-blush-deep">
                          {specialism}
