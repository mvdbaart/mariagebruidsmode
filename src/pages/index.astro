  <!-- The Mariage Experience -->
  <section class="py-24 bg-white reveal-fade-up">
    <div class="container mx-auto px-6 max-w-6xl text-center">
      <div class="mb-16">
        <span class="font-signature text-2xl text-blush-deep block mb-[-8px] lowercase opacity-60">the</span>
        <h2 class="font-display text-4xl text-charcoal">Mariage Experience</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        {[
          { name: 'Sanne', quote: 'Ik zou Mariage iedereen aanraden. De aandacht en de service is van ongekende klasse.', img: '/images/jurkvormen/a-lijn.png' },
          { name: 'Bruid Barbara', quote: 'De passie voor bruidsmode straalt ervan af bij alle medewerkers van Mariage.', img: '/images/jurkvormen/a-lijn-1.png' },
