---
import Layout from '../../layouts/Layout.astro';

const methoden = [
  {
    naam: 'iDEAL',
    beschrijving: 'Betaal eenvoudig en veilig via uw eigen bank. iDEAL is de meest gebruikte betaalmethode in Nederland.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>`,
  },
  {
    naam: 'Creditcard',
    beschrijving: 'Wij accepteren Visa en Mastercard. Betaal veilig met uw creditcard, zowel in de winkel als bij reserveringen.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/><path d="M6 15h4"/></svg>`,
  },
  {
    naam: 'Bankoverschrijving',
    beschrijving: 'Maak uw betaling over via een directe bankoverschrijving. U ontvangt onze bankgegevens na het plaatsen van uw bestelling.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
  {
    naam: 'PayPal',
    beschrijving: 'Betaal snel en veilig met uw PayPal-account. Geen bankgegevens nodig — uw betaling is altijd beschermd.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8"><path d="M7 11C7 11 6 17 12 17H17L18 11H7Z"/><path d="M10 7C10 7 9 13 15 13H19L20 7H10Z"/></svg>`,
  },
];
---

<Layout title="Betalingsopties | Mariage Bruidsmode">

  <!-- Hero -->
  <section class="pt-40 pb-20 bg-ivory">
    <div class="container mx-auto px-6 text-center max-w-3xl">
      <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-6">Betalingsopties</p>
      <h1 class="font-display text-charcoal leading-tight mb-6" style="font-size: clamp(36px, 6vw, 64px); font-weight: 300;">
        Veilig & eenvoudig <br/><em class="italic font-light text-taupe">betalen</em>
      </h1>
      <p class="text-taupe font-light leading-relaxed text-base max-w-xl mx-auto">
        Bij Mariage Bruidsmode doen we er alles aan om jouw winkelervaring zo eenvoudig en veilig mogelijk te maken. Het gaat immers om één van de belangrijkste aankopen van je leven.
      </p>
    </div>
  </section>

  <!-- Betaalmethoden -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-6 max-w-4xl">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {methoden.map(({ naam, beschrijving, icon }) => (
          <div class="border border-champagne bg-ivory/40 p-8 space-y-4">
            <div class="text-blush-deep" set:html={icon} />
            <h2 class="font-display text-charcoal text-2xl">{naam}</h2>
            <p class="text-taupe font-light text-sm leading-relaxed">{beschrijving}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Extra info -->
  <section class="py-20 bg-ivory border-t border-champagne">
    <div class="container mx-auto px-6 max-w-3xl space-y-10">
      <div>
        <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-4">Aanbetaling</p>
        <h2 class="font-display text-charcoal text-3xl mb-4">Aanbetaling <em class="italic font-light text-taupe">bij bestelling</em></h2>
        <p class="text-taupe font-light text-sm leading-relaxed">
          Bij het bestellen van een trouwjurk of trouwpak vragen wij een aanbetaling van 50% van de totale aankoopprijs. Het resterende bedrag dient te worden voldaan bij het ophalen van uw bestelling.
        </p>
      </div>
      <div class="w-full h-px bg-champagne"></div>
      <div>
        <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-4">Veiligheid</p>
        <h2 class="font-display text-charcoal text-3xl mb-4">Uw betaling is <em class="italic font-light text-taupe">veilig</em></h2>
        <p class="text-taupe font-light text-sm leading-relaxed">
          Alle betalingen via onze website worden beveiligd verwerkt. Wij slaan geen betaalgegevens op. Bij vragen over uw betaling kunt u altijd contact met ons opnemen.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-charcoal text-center">
    <div class="container mx-auto px-6 max-w-xl">
      <h2 class="font-display text-warm-white text-3xl mb-4">Vragen over betalen?</h2>
      <p class="text-warm-white/60 font-light text-sm mb-8">Neem gerust contact met ons op — wij helpen je graag verder.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="btn-gold">Contact opnemen</a>
        <a href="/ruilen-retourneren" class="btn-gold">Ruilen & retourneren</a>
      </div>
    </div>
  </section>

</Layout>
