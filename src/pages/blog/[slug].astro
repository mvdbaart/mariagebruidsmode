---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';

export const prerender = false;

const { slug } = Astro.params;

const { data: post } = await supabase
  .from('blog_posts')
  .select('*')
  .eq('slug', slug)
  .single();

if (!post) {
  return Astro.redirect('/404');
}

// Related products: 3 random products to cross-link to the shop
const { data: relatedProducts } = await supabase
  .from('products')
  .select('id, name, slug, brand, images, price_range')
  .limit(3);

const blogFallbackImage = '/images/team/TKF_9303-scaled-scaled.jpg';
const dressFallback = '/wp-content/uploads/2023/11/trouwjurk-ladybird-amariah-bruidsmode-2-scaled-1-scaled.jpg';
---

<Layout title={`${post.title} | Mariage Blog`}>
  <article class="pt-32 pb-24 bg-white">
    <div class="container mx-auto px-6 max-w-4xl">
      <nav class="mb-12 flex items-center gap-4 text-[10px] tracking-[0.2em] uppercase text-accent/40">
        <a href="/" class="hover:text-secondary whitespace-nowrap">Home</a>
        <span>/</span>
        <a href="/blog" class="hover:text-secondary whitespace-nowrap">Blog</a>
        <span>/</span>
        <span class="text-secondary truncate">{post.title}</span>
      </nav>

      <header class="mb-16 text-center">
        <div class="flex items-center justify-center gap-4 text-[10px] tracking-widest uppercase text-accent/40 font-medium mb-6">
          <span>{new Date(post.published_at).toLocaleDateString()}</span>
          <span class="w-1 h-1 bg-secondary rounded-full"></span>
          <span>By {post.author}</span>
        </div>
        <h1 class="text-5xl md:text-6xl font-serif text-accent italic leading-tight mb-12">{post.title}</h1>
        <div class="aspect-[21/9] overflow-hidden bg-ivory shadow-2xl p-2">
          <img src={post.cover_image || blogFallbackImage} alt={post.title} onerror={`this.onerror=null;this.src='${blogFallbackImage}'`} class="w-full h-full object-contain" loading="lazy" />
        </div>
      </header>

      <div class="prose prose-accent mx-auto font-light text-accent/70 leading-relaxed space-y-6">
        {post.content.split('\n').map((para: string) => (
          <p>{para}</p>
        ))}
      </div>

      <footer class="mt-24 pt-12 border-t border-secondary/10 text-center">
        <h3 class="text-2xl font-serif italic mb-8 text-accent">Klaar om jouw droomjurk te vinden?</h3>
        <a href="/afspraak-maken" class="btn-premium">Maak een pasafspraak</a>
      </footer>
    </div>
  </article>

  <!-- Related products strip -->
  {relatedProducts && relatedProducts.length > 0 && (
    <section class="py-16 bg-cream border-t border-champagne">
      <div class="container mx-auto px-6 max-w-5xl">
        <div class="text-center mb-10">
          <p class="text-[10px] tracking-[0.3em] uppercase text-blush-deep font-body mb-2">Bekijk ook</p>
          <h2 class="font-display font-normal text-charcoal" style="font-size: clamp(20px, 2.5vw, 30px);">
            Onze <em class="italic font-light">collectie</em>
          </h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {relatedProducts.map((prod) => (
            <a href={`/product/${prod.slug}`} class="group bg-white shadow-soft hover:shadow-card transition-all duration-300 overflow-hidden hover:-translate-y-1 block">
              <div class="aspect-[3/4] bg-ivory overflow-hidden p-2">
                <img
                  src={prod.images?.[0] || dressFallback}
                  alt={prod.name}
                  onerror={`this.onerror=null;this.src='${dressFallback}'`}
                  class="w-full h-full object-contain transition-transform duration-500"
                  loading="lazy"
                />
              </div>
              <div class="p-4 border-t border-champagne">
                <p class="text-[9px] tracking-widest uppercase text-blush-deep font-body mb-1">{prod.brand}</p>
                <h3 class="font-display text-charcoal text-base leading-tight">{prod.name}</h3>
                {prod.price_range && <p class="text-xs text-taupe font-body mt-1">{prod.price_range}</p>}
              </div>
            </a>
          ))}
        </div>
        <div class="text-center mt-8">
          <a href="/trouwjurken" class="btn-gold text-[11px]">Bekijk alle trouwjurken →</a>
        </div>
      </div>
    </section>
  )}
</Layout>
