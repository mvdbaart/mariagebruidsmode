---
import Layout from '../layouts/Layout.astro';
const today = new Date().toISOString().split('T')[0];
---

<Layout title="Maak een Afspraak">
  <div class="pt-32 pb-24 bg-primary/20">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16">
          <span class="text-xs tracking-[0.3em] uppercase text-secondary mb-4 block">Vind jouw droomjurk</span>
          <h1 class="text-5xl font-serif text-accent mb-8 leading-tight italic font-light text-secondary">Plan jouw ervaring</h1>
          <p class="text-lg text-accent/70 font-light leading-relaxed max-w-2xl mx-auto">
            Kies voor een persoonlijke pasafspraak of een luxe VIP ervaring voor jou en je gasten.
          </p>
        </div>

        <div class="bg-white p-8 md:p-16 shadow-xl border border-secondary/5">
          <form id="appointment-form" class="space-y-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div class="space-y-2">
                <label for="full_name" class="text-[10px] tracking-widest uppercase text-accent font-medium">Volledige Naam</label>
                <input type="text" id="full_name" name="full_name" required class="w-full border-b border-accent/20 py-3 focus:border-secondary outline-none transition-colors font-light bg-transparent" placeholder="Bijv. Anna van Veen" />
              </div>
              <div class="space-y-2">
                <label for="email" class="text-[10px] tracking-widest uppercase text-accent font-medium">Email Adres</label>
                <input type="email" id="email" name="email" required class="w-full border-b border-accent/20 py-3 focus:border-secondary outline-none transition-colors font-light bg-transparent" placeholder="anna@voorbeeld.nl" />
              </div>
              <div class="space-y-2">
                <label for="phone" class="text-[10px] tracking-widest uppercase text-accent font-medium">Telefoonnummer</label>
                <input type="tel" id="phone" name="phone" class="w-full border-b border-accent/20 py-3 focus:border-secondary outline-none transition-colors font-light bg-transparent" placeholder="06 12345678" />
              </div>
              <div class="space-y-2">
                <label for="preferred_date" class="text-[10px] tracking-widest uppercase text-accent font-medium">Voorkeursdatum</label>
                <input type="date" id="preferred_date" name="preferred_date" required min={today} class="w-full border-b border-accent/20 py-3 focus:border-secondary outline-none transition-colors font-light bg-transparent" />
              </div>
            </div>

            <fieldset class="space-y-4">
              <legend class="text-[10px] tracking-widest uppercase text-accent font-medium">Type Afspraak</legend>
              <div class="flex flex-col sm:flex-row gap-6">
                <label class="flex items-center gap-3 cursor-pointer group">
                  <input type="radio" name="appointment_type" value="standard" checked class="accent-secondary" />
                  <span class="text-sm font-light text-accent group-hover:text-secondary transition-colors">Standaard pasafspraak (90 min)</span>
                </label>
                <label class="flex items-center gap-3 cursor-pointer group">
                  <input type="radio" name="appointment_type" value="vip" class="accent-secondary" />
                  <span class="text-sm font-light text-accent group-hover:text-secondary transition-colors">Luxe VIP ervaring (120 min)</span>
                </label>
              </div>
            </fieldset>

            <div class="space-y-2">
              <label for="message" class="text-[10px] tracking-widest uppercase text-accent font-medium">Bericht (Optioneel)</label>
              <textarea id="message" name="message" rows="4" class="w-full border border-accent/10 p-4 focus:border-secondary outline-none transition-colors font-light bg-primary/10 resize-none" placeholder="Heb je al een specifiek merk of model in gedachten?"></textarea>
            </div>

            <div class="text-center pt-8">
              <button type="submit" class="btn-premium w-full md:w-auto px-12">Afspraak aanvragen</button>
            </div>
            
            <p id="form-status" class="text-center text-sm font-light hidden" role="status" aria-live="polite"></p>
          </form>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('appointment-form') as HTMLFormElement;
  const status = document.getElementById('form-status');
  const submitButton = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status || !form) return;

    status.textContent = 'Bezig met verzenden...';
    status.className = 'text-center text-sm font-light text-accent block';
    if (submitButton) submitButton.disabled = true;

    const formData = new FormData(form);
    const payload = {
      full_name: formData.get('full_name'),
      email: formData.get('email'),
      phone: formData.get('phone'),
      preferred_date: formData.get('preferred_date'),
      appointment_type: formData.get('appointment_type'),
      message: formData.get('message'),
    };

    try {
      const response = await fetch('/api/appointments', {
        method: 'POST',
        headers: {
          'content-type': 'application/json',
        },
        body: JSON.stringify(payload),
      });

      const result = await response.json().catch(() => ({ error: 'Er is iets misgegaan. Probeer het later opnieuw.' }));
      if (!response.ok) {
        status.textContent = result.error || 'Er is iets misgegaan. Probeer het later opnieuw.';
        status.className = 'text-center text-sm font-light text-red-500 block';
      } else {
        status.textContent = 'Bedankt! We nemen zo spoedig mogelijk contact met je op.';
        status.className = 'text-center text-sm font-light text-green-600 block';
        form.reset();
      }
    } catch {
      status.textContent = 'Er is iets misgegaan. Probeer het later opnieuw.';
      status.className = 'text-center text-sm font-light text-red-500 block';
    } finally {
      if (submitButton) submitButton.disabled = false;
    }
  });
</script>
