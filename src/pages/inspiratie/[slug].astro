---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';

export const prerender = false;

const { slug } = Astro.params;

const { data: wedding } = await supabase
  .from('real_weddings')
  .select('*')
  .eq('slug', slug)
  .single();

if (!wedding) {
  return Astro.redirect('/404');
}

const weddingFallbackImage = '/images/team/TKF_9422-scaled.jpg';
---

<Layout title={`${wedding.bride_name} & ${wedding.groom_name} | Real Marriage Wedding`}>
  <div class="pt-32 pb-24 bg-white">
    <div class="container mx-auto px-6">
      <nav class="mb-12 flex items-center gap-4 text-[10px] tracking-[0.2em] uppercase text-accent/40">
        <a href="/" class="hover:text-secondary whitespace-nowrap">Home</a>
        <span>/</span>
        <a href="/inspiratie" class="hover:text-secondary whitespace-nowrap">Inspiratie</a>
        <span>/</span>
        <span class="text-secondary truncate">{wedding.bride_name} & {wedding.groom_name}</span>
      </nav>

      <div class="max-w-4xl mx-auto mb-20 text-center">
        <h1 class="text-5xl md:text-7xl font-serif text-accent mb-6 italic font-light">{wedding.bride_name} & {wedding.groom_name}</h1>
        <div class="flex items-center justify-center gap-4 text-[10px] tracking-widest uppercase text-secondary font-medium">
          <span>{wedding.wedding_date ? new Date(wedding.wedding_date).toLocaleDateString('nl-NL', { year: 'numeric', month: 'long', day: 'numeric' }) : ''}</span>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-20">
        <div class="space-y-8">
          <div class="overflow-hidden shadow-2xl">
            <img src={wedding.cover_image || weddingFallbackImage} alt={`${wedding.bride_name} & ${wedding.groom_name}`} onerror={`this.onerror=null;this.src='${weddingFallbackImage}'`} class="w-full h-auto" loading="lazy" />
          </div>
          {wedding.gallery_images?.map((img: string, index: number) => (
             index % 2 === 0 && (
                <div class="overflow-hidden shadow-2xl">
                  <img src={img || weddingFallbackImage} alt={`Wedding photo ${index + 1}`} onerror={`this.onerror=null;this.src='${weddingFallbackImage}'`} class="w-full h-auto" loading="lazy" />
                </div>
             )
          ))}
        </div>
        <div class="space-y-8">
           <div class="prose prose-accent font-light text-accent/70 text-lg leading-relaxed italic mb-12">
            <p>{wedding.story}</p>
          </div>
          {wedding.gallery_images?.map((img: string, index: number) => (
             index % 2 !== 0 && (
                <div class="overflow-hidden shadow-2xl">
                  <img src={img || weddingFallbackImage} alt={`Wedding photo ${index + 1}`} onerror={`this.onerror=null;this.src='${weddingFallbackImage}'`} class="w-full h-auto" loading="lazy" />
                </div>
             )
          ))}
        </div>
      </div>

      <div class="pt-24 border-t border-secondary/10 text-center">
        <h3 class="text-3xl font-serif text-accent mb-8 italic">Wil jij ook stralen op je bruiloft?</h3>
        <a href="/afspraak-maken" class="btn-premium">Plan jouw pasafspraak</a>
      </div>
    </div>
  </div>
</Layout>
