---
import Layout from '../../layouts/Layout.astro';
import ProductFilter from '../../components/ProductFilter';
import { supabase } from '../../lib/supabase';

const { data: collections } = await supabase
  .from('collections')
  .select('id, title, slug, type')
  .eq('type', 'dress')
  .order('title', { ascending: true });

const collectionIds = (collections ?? []).map((col) => col.id);

const { data: dressProducts } = await supabase
  .from('products')
  .select('id, name, slug, brand, price_range, features, images, collection_id')
  .in('collection_id', collectionIds.length ? collectionIds : ['00000000-0000-0000-0000-000000000000'])
  .order('created_at', { ascending: false });

const dressFallbackImage = '/images/jurkvormen/a-lijn.png';
const collectionsForFilter = (collections ?? []).map(({ id, title, slug }) => ({ id, title, slug }));
---

<Layout title="Trouwjurken | Mariage Bruidsmode">
  <div class="pt-40 pb-20 bg-ivory border-b border-champagne">
    <div class="container mx-auto px-6">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
        <div class="max-w-2xl">
          <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-6">Collecties</p>
          <h1 class="font-display font-normal text-charcoal leading-tight mb-8" style="font-size: clamp(40px, 6vw, 64px);">
            De nieuwste <em class="italic font-light text-taupe">trouwjurken</em>
          </h1>
          <p class="text-taupe font-light leading-relaxed max-w-xl">
            Stap binnen in de wereld van Mariage Bruidsmode. Een zorgvuldig geselecteerde collectie van de meest gerenommeerde merken voor elke type bruid.
          </p>
        </div>
        <div class="pb-2">
          <a href="/trouwjurken/vormen" class="inline-block bg-white border border-champagne text-charcoal px-8 py-4 text-[10px] tracking-[0.3em] uppercase hover:bg-ivory transition-all shadow-soft group">
            Vind jouw <em class="italic group-hover:text-blush-deep transition-colors">silhouet</em>
          </a>
        </div>
      </div>
    </div>
  </div>

  <ProductFilter
    client:load
    products={dressProducts ?? []}
    collections={collectionsForFilter}
    fallbackImage={dressFallbackImage}
  />

  <section class="py-24 bg-charcoal text-center">
    <div class="container mx-auto px-6 max-w-xl">
      <p class="text-[10px] tracking-[0.3em] uppercase text-gold-light font-body mb-4">Persoonlijk advies</p>
      <h2 class="font-display font-normal text-warm-white mb-6" style="font-size: clamp(24px, 3vw, 40px);">
        Niet gevonden wat je zocht?
      </h2>
      <p class="text-taupe-light font-light text-sm leading-relaxed mb-10">
        Onze collectie in de winkel is nog uitgebreider dan online. Maak een afspraak voor persoonlijk advies.
      </p>
      <a href="/afspraak-maken" class="btn-blush">Maak een pasafspraak</a>
    </div>
  </section>
</Layout>
