---
import Layout from '../../layouts/Layout.astro';

const silhouettes = [
  {
    name: 'A-lijn',
    image: '/images/jurkvormen/a-lijn.png',
    description: 'De A-lijn is een klassieke keuze die nauw aansluit bij de taille en geleidelijk uitloopt naar beneden in de vorm van een "A". Dit silhouet is flatterend voor bijna elk figuur.',
    features: ['Flatteert elk figuur', 'Tijdloze uitstraling', 'Comfortabel en zwierig']
  },
  {
    name: 'Strak / Kokermodel',
    image: '/images/jurkvormen/a-lijn-silhouet.png',
    description: 'De strakke trouwjurk sluit nauw aan langs het hele lichaam en benadrukt elke curve. Dit silhouet straalt moderniteit en zelfvertrouwen uit — ideaal voor de bruid die haar figuur wil tonen.',
    features: ['Slank en gestroomlijnd', 'Modern en gedurfd', 'Benadrukt je figuur']
  },
  {
    name: 'Prinsessen',
    image: '/images/jurkvormen/a-lijn-silhouet.png',
    description: 'De prinsessenstijl (of baljurk) heeft een strak lijfje en een zeer volle rok. Dit silhouet creëert een echt sprookjesgevoel en is ideaal voor een formele bruiloft.',
    features: ['Groots en dramatisch', 'Accentueert de taille', 'Sprookjesachtige look']
  },
  {
    name: 'Bohemian',
    image: '/images/jurkvormen/a-lijn.png',
    description: 'De bohemian trouwjurk heeft een vrije, romantische uitstraling met vloeiende stoffen, kanten details en een ongedwongen silhouet. Perfect voor een bruiloft buiten of in de natuur.',
    features: ['Vrij en romantisch', 'Vloeiende stoffen', 'Ideaal voor buiten bruiloften']
  },
  {
    name: 'Vintage',
    image: '/images/jurkvormen/photoshop-silhouet2.png',
    description: 'Vintage trouwjurken zijn geïnspireerd op stijlen uit vervlogen tijden — denk aan kanten mouwen, geknopte ruggen en retro silhouetten. Ze ademen karakter en nostalgie.',
    features: ['Tijdloze charme', 'Unieke detaillering', 'Kanten en retro accenten']
  },
  {
    name: 'Zeemeermin',
    image: '/images/jurkvormen/photoshop-silhouet2.png',
    description: 'Dit silhouet volgt de contouren van het lichaam van de buste tot de knieën, waarna de rok dramatisch uitloopt. Perfect voor de bruid die haar rondingen wil laten zien.',
    features: ['Sexy en elegant', 'Accentueert rondingen', 'Modern en chic']
  },
  {
    name: 'Simpel & Minimalistisch',
    image: '/images/jurkvormen/a-lijn.png',
    description: 'Minder is meer. De simpele trouwjurk spreekt door haar zuiverheid en elegantie — geen overdreven details, maar strakke lijnen en prachtige stoffen die voor zichzelf spreken.',
    features: ['Tijdloos en verfijnd', 'Kwaliteit staat centraal', 'Veelzijdig te stylen']
  },
  {
    name: 'Grote Maat',
    image: '/images/jurkvormen/a-lijn-silhouet.png',
    description: 'Elke bruid verdient een jurk die haar doet stralen. Onze grote maten collectie biedt prachtige silhouetten die speciaal zijn ontworpen om flatteuse en comfortabel te zijn voor een vol figuur.',
    features: ['Inclusief en flatterend', 'Speciaal ontworpen pasvorm', 'Breed aanbod in alle stijlen']
  },
  {
    name: 'Kort',
    image: '/images/jurkvormen/a-lijn.png',
    description: 'De korte trouwjurk is perfect voor het burgerlijk huwelijk, een feestelijke borgerlijke trouw of een bruid die van een speelse, moderne look houdt. Luchtig, eigentijds en heel elegant.',
    features: ['Speels en modern', 'Ideaal voor een klein feest', 'Comfortabel en stijlvol']
  }
];
---

<Layout title="Jurkvormen Gids | Mariage Bruidsmode">
  <div class="pt-40 pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6 max-w-5xl">
      <div class="text-center mb-20">
        <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-4">Inspiratie & Advies</p>
        <h1 class="font-display text-charcoal leading-tight mb-8" style="font-size: clamp(32px, 5vw, 56px); font-weight: 300;">
          Vind jouw perfecte <em class="italic font-light text-taupe">silhouet</em>
        </h1>
        <p class="text-taupe leading-relaxed max-w-2xl mx-auto font-light">
          Elk lichaam is uniek. Onze gids helpt je de verschillende vormen te begrijpen, zodat je met vertrouwen kunt komen passen in onze boutique.
        </p>
      </div>

      <div class="space-y-32">
        {silhouettes.map((s, i) => (
          <div class={`flex flex-col ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} gap-12 md:gap-20 items-center`}>
            <div class="w-full md:w-1/2">
              <div class="bg-white border border-champagne shadow-soft p-12 aspect-square flex items-center justify-center group overflow-hidden">
                <img 
                  src={s.image} 
                  alt={s.name} 
                  class="max-h-full max-w-full object-contain transition-transform duration-700 group-hover:scale-110" 
                  loading="lazy"
                />
              </div>
            </div>
            <div class="w-full md:w-1/2 space-y-6">
              <h2 class="font-display text-charcoal text-4xl">{s.name}</h2>
              <p class="text-taupe font-light leading-relaxed">
                {s.description}
              </p>
              <ul class="space-y-3 pt-4">
                {s.features.map(f => (
                  <li class="flex items-center gap-3 text-xs text-taupe tracking-wide">
                    <span class="w-1.5 h-1.5 rounded-full bg-blush-deep"></span>
                    {f}
                  </li>
                ))}
              </ul>
              <div class="pt-8">
                <a href="/afspraak-maken" class="inline-block bg-charcoal text-warm-white px-10 py-4 text-[10px] tracking-[0.3em] uppercase hover:bg-taupe transition-all font-medium">
                  Kom deze vorm passen
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-40 bg-white border border-champagne p-16 text-center shadow-soft">
        <h3 class="font-display text-charcoal text-3xl mb-6">Persoonlijk advies nodig?</h3>
        <p class="text-taupe font-light mb-10 max-w-xl mx-auto">
          Cijfers en plaatjes vertellen maar een deel van het verhaal. Tijdens een pasafspraak kijken we echt naar wat bij jóú past.
        </p>
        <a href="/afspraak-maken" class="btn-premium">Maak nu een afspraak</a>
      </div>
    </div>
  </div>
</Layout>
