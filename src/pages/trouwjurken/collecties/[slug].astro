---
import Layout from '../../../layouts/Layout.astro';
import { supabase } from '../../../lib/supabase';
import { getAdminAuthFromCookies } from '../../../lib/serverAuth';

export const prerender = false;

const { slug } = Astro.params;
const adminAuth = await getAdminAuthFromCookies(Astro.cookies);
const isAdmin = Boolean(adminAuth);

const { data: collection } = await supabase
  .from('collections')
  .select('*, products(*)')
  .eq('slug', slug)
  .single();

if (!collection) {
  return Astro.redirect('/404');
}

const dressFallbackImage = '/images/jurkvormen/a-lijn.png';
---

<Layout title={`${collection.title} Collectie`}>
  <div class="pt-32 pb-24 bg-primary/10">
    <div class="container mx-auto px-6">
      <nav class="mb-12 flex items-center gap-4 text-[10px] tracking-[0.2em] uppercase text-accent/40">
        <a href="/" class="hover:text-secondary whitespace-nowrap">Home</a>
        <span>/</span>
        <a href="/trouwjurken" class="hover:text-secondary whitespace-nowrap">Trouwjurken</a>
        <span>/</span>
        <span class="text-secondary truncate">{collection.title}</span>
      </nav>

      <div class="max-w-4xl mb-20 text-center mx-auto">
        <h1 class="text-5xl md:text-6xl font-serif text-accent mb-6 leading-tight italic font-light">{collection.title}</h1>
        <p class="text-lg text-accent/70 font-light leading-relaxed">
          {collection.description}
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
        {collection.products?.map((product: any) => (
          <div class="group relative">
            <div class="aspect-[3/4] overflow-hidden bg-ivory mb-6 relative p-2">
              <img
                src={product.images?.[0] || dressFallbackImage}
                alt={product.name}
                onerror={`this.onerror=null;this.src='${dressFallbackImage}'`}
                class="w-full h-full object-contain transition-transform duration-700"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-500"></div>
              <button
                class="wishlist-btn absolute top-3 right-3 z-10 w-9 h-9 flex items-center justify-center bg-white/85 backdrop-blur-sm hover:bg-white transition-colors shadow-soft"
                data-slug={product.slug}
                data-name={product.name}
                data-image={product.images?.[0] || ''}
                aria-label={`${product.name} toevoegen aan verlanglijst`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="heart-icon transition-colors text-taupe" fill="none">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                </svg>
              </button>
            </div>
            <span class="text-[10px] tracking-[0.3em] uppercase text-secondary block mb-2">{product.brand}</span>
            <h3 class="text-xl font-serif text-accent mb-2">{product.name}</h3>
            <p class="text-sm text-accent/60 font-light italic truncate mb-4">{product.description}</p>
            <div class="flex items-center gap-4">
              <a href={`/product/${product.slug}`} class="text-[10px] tracking-widest uppercase border-b border-accent/20 pb-1 hover:border-secondary transition-colors">Details bekijken</a>
              {isAdmin && (
                <a href={`/admin/product/${product.id}/edit`} class="text-[10px] tracking-widest uppercase border-b border-secondary/40 pb-1 text-secondary hover:border-secondary transition-colors">Specificaties invullen</a>
              )}
            </div>
          </div>
        ))}
      </div>

      {(!collection.products || collection.products.length === 0) && (
        <div class="py-20 text-center border border-dashed border-secondary/20 rounded-lg">
          <p class="text-accent/40 font-light italic">Binnenkort meer jurken in deze collectie.</p>
        </div>
      )}
    </div>
  </div>
</Layout>

<script>
  function initWishlistButtons() {
    const wl = (window as any).mariageWishlist;
    if (!wl) return;

    document.querySelectorAll<HTMLButtonElement>('.wishlist-btn').forEach(btn => {
      const slug = btn.dataset.slug!;
      const name = btn.dataset.name!;
      const image = btn.dataset.image || undefined;
      const icon = btn.querySelector<SVGElement>('.heart-icon');

      function updateIcon(inWishlist: boolean) {
        if (!icon) return;
        if (inWishlist) {
          icon.setAttribute('fill', 'currentColor');
          icon.classList.remove('text-taupe');
          icon.classList.add('text-blush-deep');
        } else {
          icon.setAttribute('fill', 'none');
          icon.classList.add('text-taupe');
          icon.classList.remove('text-blush-deep');
        }
      }

      updateIcon(wl.has(slug));

      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const added = wl.toggle({ slug, name, image, url: `/product/${slug}` });
        updateIcon(added);
      });
    });
  }

  if ((window as any).mariageWishlist) {
    initWishlistButtons();
  } else {
    window.addEventListener('load', initWishlistButtons);
  }
</script>
