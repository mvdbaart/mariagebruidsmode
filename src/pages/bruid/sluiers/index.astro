---
import Layout from '../../../layouts/Layout.astro';

const stijlen = [
  { naam: 'Vingertiplenge sluier', beschrijving: 'Reikt tot de vingertips als de armen gestrekt langs het lichaam hangen. Elegant en veelzijdig.' },
  { naam: 'Ellebooglengte sluier', beschrijving: 'Een kortere, speelse sluier die perfect is voor moderne en romantische bruiden.' },
  { naam: 'Vloerlengte sluier', beschrijving: 'Raakt de vloer en creëert een klassieke, bruidse uitstraling voor elke jurk.' },
  { naam: 'Kathedraallengte sluier', beschrijving: 'De meest dramatische keuze: sleept meters achter de bruid aan voor een onvergetelijke entree.' },
  { naam: 'Blusher sluier', beschrijving: 'Een korte sluier die over het gezicht wordt gedragen bij de ingang en daarna omhoog wordt geslagen.' },
  { naam: 'Mantilla', beschrijving: 'Traditionele Spaanse sluier met kantrand, gedragen direct op het hoofd zonder kam.' },
];
---

<Layout title="Bruidssluiers | Mariage Bruidsmode">

  <!-- Hero -->
  <section class="pt-40 pb-24 bg-ivory">
    <div class="container mx-auto px-6">
      <div class="max-w-3xl">
        <nav class="text-[10px] tracking-[0.2em] uppercase text-taupe/60 font-body mb-8 flex items-center gap-2">
          <a href="/bruid/accessoires" class="hover:text-taupe transition-colors">Accessoires</a>
          <span>›</span>
          <span class="text-taupe">Sluiers</span>
        </nav>
        <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-6">Accessoires</p>
        <h1 class="font-display text-charcoal leading-tight mb-8" style="font-size: clamp(40px, 8vw, 72px); font-weight: 300;">
          Bruidssluiers
        </h1>
        <p class="text-taupe font-light leading-relaxed text-base max-w-xl mb-10">
          Een sluier voegt een tijdloze romantiek toe aan elke bruidslook. Of je nu kiest voor een delicate vingertiplengte of een dramatische kathedraallengte — wij helpen je de perfecte match te vinden.
        </p>
        <a href="/afspraak-maken" class="btn-premium">Sluier passen</a>
      </div>
    </div>
  </section>

  <!-- Stijlen -->
  <section class="py-24 bg-white border-t border-champagne">
    <div class="container mx-auto px-6 max-w-5xl">
      <div class="text-center mb-16">
        <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-4">Lengtes & stijlen</p>
        <h2 class="font-display text-charcoal text-4xl mb-4">Elke stijl, <em class="italic font-light text-taupe">elke lengte</em></h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
        {stijlen.map(({ naam, beschrijving }) => (
          <div class="border border-champagne bg-ivory/40 p-6 space-y-3">
            <div class="w-px h-6 bg-blush"></div>
            <h3 class="font-display text-charcoal text-lg">{naam}</h3>
            <p class="text-taupe font-light text-sm leading-relaxed">{beschrijving}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tips -->
  <section class="py-20 bg-ivory border-t border-champagne">
    <div class="container mx-auto px-6 max-w-3xl">
      <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-6 text-center">Stylingtips</p>
      <h2 class="font-display text-charcoal text-3xl text-center mb-10">Hoe kies je de <em class="italic font-light text-taupe">juiste sluier?</em></h2>
      <div class="space-y-6 text-taupe font-light text-sm leading-relaxed">
        <p><strong class="text-charcoal font-body">Pas de lengte aan op je jurk:</strong> Een A-lijn of ballerinajurk combineert mooi met elke sluierlengte. Een stijljurk vraagt om een langere, elegante sluier. Een princessenjurk wint bij een dramatische kathedraallengte.</p>
        <p><strong class="text-charcoal font-body">Denk aan je haarstyling:</strong> Wil je je haar los of in een updo? Een opgestoken kapsel toont de sluierbevestiging en vraagt om een mooie kam of speldje. Los haar combineert goed met een hoofdbandsluier of mantilla.</p>
        <p><strong class="text-charcoal font-body">Kant of effen?:</strong> Een kanten sluier sluit mooi aan bij een romantische of vintage jurk. Een effen tule sluier past bij zowel moderne als klassieke stijlen.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-charcoal text-center">
    <div class="container mx-auto px-6 max-w-xl">
      <h2 class="font-display text-warm-white text-3xl mb-4">Sluier <em class="italic text-blush font-light">passen?</em></h2>
      <p class="text-warm-white/60 font-light text-sm mb-8">
        Breng je sluier mee naar je pasafspraak of bekijk onze collectie in de winkel.
      </p>
      <a href="/afspraak-maken" class="btn-gold">Afspraak maken</a>
    </div>
  </section>

</Layout>
