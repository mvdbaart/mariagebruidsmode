---
import Layout from '../../../layouts/Layout.astro';

const categorieën = [
  {
    naam: 'Sluiers',
    href: '/bruid/sluiers',
    beschrijving: 'Van delicate vingerlengte tot dramatische kathedraallengte — de perfecte sluier voor elke bruidsstijl.',
    icon: '✦',
  },
  {
    naam: 'Haaraccessoires',
    href: '/bruid/haaraccessoires',
    beschrijving: 'Haarbanden, haarspelden, tiara\'s en kransen die jouw look compleet maken.',
    icon: '✦',
  },
  {
    naam: 'Sieraden',
    href: '/bruid/sieraden',
    beschrijving: 'Oorbellen, kettingen en armbanden afgestemd op jouw jurk en stijl.',
    icon: '✦',
  },
  {
    naam: 'Bruidsschoenen',
    href: '/bruidsschoenen',
    beschrijving: 'Elegante pumps, sandalen en ballerina\'s voor de meest bijzondere dag van je leven.',
    icon: '✦',
  },
];

const punten = [
  'Uitgebreid assortiment van gerenommeerde merken',
  'Accessoires afgestemd op jouw jurk',
  'Persoonlijk advies van onze stylisten',
  'Aanpasbaar op maat door onze coupeuses',
  'Bezichtigen mogelijk tijdens pasafspraak',
];
---

<Layout title="Bruidsaccessoires | Mariage Bruidsmode">

  <!-- Hero -->
  <section class="pt-40 pb-24 bg-ivory">
    <div class="container mx-auto px-6">
      <div class="max-w-3xl">
        <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-6">Bruid</p>
        <h1 class="font-display text-charcoal leading-tight mb-8" style="font-size: clamp(40px, 8vw, 72px); font-weight: 300;">
          Bruids<em class="italic font-light text-taupe">accessoires</em>
        </h1>
        <p class="text-taupe font-light leading-relaxed text-base max-w-xl mb-10">
          De details maken het verschil. Van de perfecte sluier tot de juiste sieraden — onze accessoirecollectie is zorgvuldig samengesteld om jouw bruidslook te completeren.
        </p>
        <a href="/afspraak-maken" class="btn-premium">Afspraak maken</a>
      </div>
    </div>
  </section>

  <!-- Categorieën -->
  <section class="py-24 bg-white border-t border-champagne">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="text-center mb-16">
        <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-4">Collectie</p>
        <h2 class="font-display text-charcoal text-4xl mb-4">Alles voor de <em class="italic font-light text-taupe">complete look</em></h2>
        <p class="text-taupe font-light max-w-xl mx-auto text-sm leading-relaxed">
          Ontdek onze accessoires per categorie en laat je inspireren voor jouw perfecte bruidsstyling.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {categorieën.map(({ naam, href, beschrijving }) => (
          <a href={href} class="group border border-champagne bg-ivory/40 hover:bg-white hover:border-blush-deep hover:shadow-soft transition-all duration-300 p-8 text-center">
            <div class="w-px h-8 bg-blush mx-auto mb-6"></div>
            <h3 class="font-display text-charcoal text-xl mb-3 group-hover:text-blush-deep transition-colors">{naam}</h3>
            <p class="text-taupe font-light text-xs leading-relaxed">{beschrijving}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Waarom Mariage -->
  <section class="py-24 bg-ivory border-t border-champagne">
    <div class="container mx-auto px-6 max-w-5xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-6">Onze aanpak</p>
          <h2 class="font-display text-charcoal text-4xl mb-6">De <em class="italic font-light text-taupe">perfecte afwerking</em></h2>
          <p class="text-taupe font-light text-sm leading-relaxed mb-4">
            Een bruidslook is meer dan de jurk. Wij helpen je bij het vinden van accessoires die perfect aansluiten op jouw jurk, stijl en persoonlijkheid — en die de look tot een geheel maken.
          </p>
          <p class="text-taupe font-light text-sm leading-relaxed">
            Tijdens je pasafspraak nemen we ook de accessoires door. Zo verlaat je onze winkel met een complete bruidsstyling die klaar is voor de mooiste dag van je leven.
          </p>
          <div class="mt-8">
            <a href="/afspraak-maken" class="btn-gold">Afspraak plannen</a>
          </div>
        </div>
        <div class="space-y-4 text-sm font-body">
          {punten.map(punt => (
            <div class="flex items-center gap-3 border-b border-champagne pb-4">
              <div class="w-1.5 h-1.5 rounded-full bg-blush-deep shrink-0"></div>
              <span class="text-charcoal">{punt}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-charcoal text-center">
    <div class="container mx-auto px-6 max-w-2xl">
      <p class="text-[10px] tracking-[0.4em] uppercase text-blush font-body mb-4">Jouw complete look</p>
      <h2 class="font-display text-warm-white text-4xl mb-6">Accessoires <em class="italic text-blush font-light">op maat</em></h2>
      <p class="text-warm-white/60 font-light mb-10 text-sm leading-relaxed">
        Maak een afspraak en ontdek hoe de juiste accessoires jouw bruidslook compleet maken.
      </p>
      <a href="/afspraak-maken" class="btn-gold">Afspraak maken</a>
    </div>
  </section>

</Layout>
