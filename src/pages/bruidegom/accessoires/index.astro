---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Bruidegom Accessoires — Mariage Bruidsmode">
  <section class="min-h-[70vh] flex items-center justify-center bg-ivory px-6">
    <div class="text-center max-w-lg">
      <p class="ds-eyebrow mb-4">Binnenkort</p>
      <h1 class="font-display text-4xl md:text-5xl text-charcoal mb-6">Bruidegom Accessoires</h1>
      <p class="font-body text-taupe text-base leading-relaxed mb-10">
        Deze pagina is binnenkort beschikbaar. Binnenkort vindt u hier ons volledige aanbod accessoires voor de bruidegom.
      </p>
      <a href="/trouwpakken" class="btn-gold">Bekijk trouwkostuums</a>
    </div>
  </section>
</Layout>
