---
import Layout from '../../../../layouts/Layout.astro';
import { getServiceRoleClient } from '../../../../lib/serverAuth';

const { id } = Astro.params;
const supabase = getServiceRoleClient();
const { data: post, error } = await supabase.from('blog_posts').select('*').eq('id', id).single();

if (error || !post) return Astro.redirect('/admin/blog');

const publishedDate = post.published_at ? new Date(post.published_at).toISOString().split('T')[0] : '';
---

<Layout title={`Bewerk: ${post.title}`}>
  <div class="pt-32 pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6 max-w-3xl">
      <nav class="mb-10 flex items-center gap-3 text-[10px] tracking-[0.2em] uppercase text-taupe font-body">
        <a href="/admin" class="hover:text-blush-deep transition-colors">Dashboard</a>
        <span class="text-champagne">/</span>
        <a href="/admin/blog" class="hover:text-blush-deep transition-colors">Blog Beheer</a>
        <span class="text-champagne">/</span>
        <span class="text-charcoal truncate max-w-[160px]">{post.title}</span>
      </nav>

      <div class="bg-white border border-champagne p-10 shadow-soft">
        <h1 class="font-display font-normal text-charcoal text-3xl mb-10">Bewerk <em class="italic font-light text-blush-deep">{post.title}</em></h1>

        <form id="edit-blog-form" class="space-y-8">
          <input type="hidden" name="id" value={post.id} />
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Titel *</label>
              <input type="text" name="title" value={post.title} required class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" />
            </div>
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Slug *</label>
              <input type="text" name="slug" value={post.slug} required class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" />
            </div>
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Auteur</label>
              <input type="text" name="author" value={post.author} class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" />
            </div>
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Publicatiedatum</label>
              <input type="date" name="published_at" value={publishedDate} class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" />
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Samenvatting</label>
            <input type="text" name="excerpt" value={post.excerpt ?? ''} class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" />
          </div>
          <div class="space-y-2">
            <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Cover Afbeelding URL</label>
            <input type="url" name="cover_image" value={post.cover_image ?? ''} class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" />
          </div>
          <div class="space-y-2">
            <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Inhoud *</label>
            <textarea name="content" rows="12" required class="w-full border border-champagne p-4 focus:border-charcoal outline-none transition-colors font-body font-light bg-cream/30 resize-none">{post.content}</textarea>
          </div>
          <div class="flex gap-4 pt-4">
            <button type="submit" class="btn-premium text-[10px]">Wijzigingen Opslaan</button>
            <a href="/admin/blog" class="btn-gold text-[10px]">Annuleren</a>
          </div>
          <p id="form-status" class="text-sm font-body font-light hidden"></p>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('edit-blog-form') as HTMLFormElement;
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;
    status.textContent = 'Bezig met opslaan...';
    status.className = 'text-sm font-body font-light text-taupe block';

    const data = new FormData(form);
    const id = data.get('id');
    const response = await fetch(`/api/admin/blog/${id}`, {
      method: 'PUT',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({
        title: data.get('title'),
        slug: data.get('slug'),
        author: data.get('author'),
        excerpt: data.get('excerpt') || null,
        cover_image: data.get('cover_image') || null,
        content: data.get('content'),
        published_at: data.get('published_at') || new Date().toISOString(),
      }),
    });
    const result = await response.json().catch(() => ({ error: 'Onbekende fout.' }));

    if (!response.ok) {
      status.textContent = 'Fout: ' + result.error;
      status.className = 'text-sm font-body font-light text-red-500 block';
    } else {
      status.textContent = 'Opgeslagen!';
      status.className = 'text-sm font-body font-light text-green-600 block';
      setTimeout(() => { window.location.href = '/admin/blog'; }, 1200);
    }
  });
</script>
