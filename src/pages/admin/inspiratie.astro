---
import Layout from '../../layouts/Layout.astro';
import { getServiceRoleClient } from '../../lib/serverAuth';

const supabase = getServiceRoleClient();
const { data: weddings } = await supabase
  .from('real_weddings')
  .select('*')
  .order('wedding_date', { ascending: false });
---

<Layout title="Admin Inspiratie Beheer">
  <div class="pt-32 pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6">
      <div class="flex justify-between items-center mb-12">
        <h1 class="font-display font-normal text-charcoal text-3xl italic">Real Weddings <span class="text-blush-deep opacity-60">Beheer</span></h1>
        <div class="flex gap-4 items-center">
          <a href="/admin/inspiratie/new" class="btn-premium text-[10px]">+ Nieuw Verhaal</a>
          <a href="/admin" class="text-[10px] uppercase tracking-widest text-taupe hover:text-blush-deep transition-colors">← Dashboard</a>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {weddings?.map((wedding) => (
          <div class="bg-white border border-champagne group overflow-hidden shadow-soft" data-id={wedding.id}>
            <div class="aspect-video overflow-hidden bg-linen">
              <img src={wedding.cover_image} alt={`${wedding.bride_name} & ${wedding.groom_name}`} class="w-full h-full object-cover transition-transform group-hover:scale-105" loading="lazy" />
            </div>
            <div class="p-6">
              <h3 class="font-display italic text-charcoal text-xl mb-1">{wedding.bride_name} & {wedding.groom_name}</h3>
              <p class="text-[10px] font-body text-taupe uppercase tracking-widest mb-4">
                {wedding.wedding_date ? new Date(wedding.wedding_date).getFullYear() : '—'}
              </p>
              <div class="flex gap-4 border-t border-champagne pt-4">
                <a href={`/admin/inspiratie/${wedding.id}/edit`} class="text-[10px] uppercase tracking-widest font-body text-blush-deep hover:underline font-medium">Bewerken</a>
                <button
                  class="delete-wedding-btn text-[10px] uppercase tracking-widest font-body text-red-400 hover:underline font-medium"
                  data-id={wedding.id}
                  data-name={`${wedding.bride_name} & ${wedding.groom_name}`}
                >Verwijderen</button>
              </div>
            </div>
          </div>
        ))}
      </div>

      {!weddings?.length && (
        <div class="py-24 text-center">
          <p class="font-italic italic text-taupe-light mb-4">Nog geen bruidsverhalen. <a href="/admin/inspiratie/new" class="text-blush-deep hover:underline">Voeg het eerste verhaal toe.</a></p>
        </div>
      )}
    </div>
  </div>
</Layout>

<dialog id="delete-dialog" class="bg-white border border-champagne shadow-card p-8 max-w-sm w-full">
  <h2 class="font-display text-charcoal text-xl mb-3">Verhaal verwijderen?</h2>
  <p id="delete-dialog-msg" class="text-sm font-body text-taupe mb-6"></p>
  <div class="flex gap-4">
    <button id="confirm-delete" class="btn-premium text-[10px]" style="background-color: rgb(239,68,68); border-color: rgb(239,68,68)">Verwijderen</button>
    <button id="cancel-delete" class="btn-gold text-[10px]">Annuleren</button>
  </div>
</dialog>

<script>
  const dialog = document.getElementById('delete-dialog') as HTMLDialogElement | null;
  const confirmBtn = document.getElementById('confirm-delete');
  const cancelBtn = document.getElementById('cancel-delete');
  const dialogMsg = document.getElementById('delete-dialog-msg');
  let pendingDeleteId: string | null = null;

  document.querySelectorAll<HTMLButtonElement>('.delete-wedding-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      pendingDeleteId = btn.getAttribute('data-id');
      const name = btn.getAttribute('data-name') ?? 'dit verhaal';
      if (dialogMsg) dialogMsg.textContent = `Weet je zeker dat je het verhaal van "${name}" wilt verwijderen?`;
      dialog?.showModal();
    });
  });

  cancelBtn?.addEventListener('click', () => { dialog?.close(); pendingDeleteId = null; });
  dialog?.addEventListener('click', (e) => { if (e.target === dialog) { dialog.close(); pendingDeleteId = null; } });

  confirmBtn?.addEventListener('click', async () => {
    if (!pendingDeleteId) return;
    const id = pendingDeleteId;
    dialog?.close();

    const response = await fetch(`/api/admin/inspiratie/${id}`, { method: 'DELETE' });
    if (response.ok) {
      document.querySelector(`[data-id="${id}"]`)?.remove();
    } else {
      alert('Fout bij verwijderen. Probeer opnieuw.');
    }
    pendingDeleteId = null;
  });
</script>

<style>
  #delete-dialog { border: 1px solid var(--color-champagne); }
  #delete-dialog::backdrop { background: rgba(44,42,40,0.5); }
</style>
