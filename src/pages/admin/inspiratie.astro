---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';

const { data: weddings } = await supabase
  .from('real_weddings')
  .select('*')
  .order('wedding_date', { ascending: false });
---

<Layout title="Admin Inspiratie Beheer">
  <div class="pt-32 pb-24 bg-primary/20 min-h-screen">
    <div class="container mx-auto px-6">
      <div class="flex justify-between items-center mb-12">
        <h1 class="text-3xl font-serif text-accent italic">Real Weddings <span class="text-secondary opacity-50">Beheer</span></h1>
        <a href="/admin" class="text-xs uppercase tracking-widest text-accent/60 hover:text-secondary underline decoration-secondary/20">Terug naar Dashboard</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {weddings?.map((wedding) => (
          <div class="bg-white border border-secondary/10 group overflow-hidden">
            <div class="aspect-video overflow-hidden">
              <img src={wedding.cover_image} alt={wedding.bride_name} class="w-full h-full object-cover transition-transform group-hover:scale-105" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-serif text-accent italic mb-2">{wedding.bride_name} & {wedding.groom_name}</h3>
              <p class="text-xs text-accent/40 mb-4 uppercase tracking-widest">{new Date(wedding.wedding_date).getFullYear()}</p>
              <div class="flex gap-4 border-t border-secondary/10 pt-4">
                <button class="text-[10px] uppercase tracking-widest text-secondary hover:underline font-medium">Bewerken</button>
                <button class="text-[10px] uppercase tracking-widest text-red-400 hover:underline font-medium">Verwijderen</button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>
