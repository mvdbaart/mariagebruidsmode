---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getAdminAuthFromCookies, getServiceRoleClient } from '../../../lib/serverAuth';

const adminAuth = await getAdminAuthFromCookies(Astro.cookies);
if (!adminAuth) return Astro.redirect('/login');

const supabase = getServiceRoleClient();
const { data: orders } = await supabase
  .from('customer_orders')
  .select('*, products(slug)')
  .order('created_at', { ascending: false });

const total = orders?.length ?? 0;
const totalRevenue = orders?.reduce((sum, o) => sum + (o.amount_paid ?? 0), 0) ?? 0;
const newOrders = orders?.filter(o => o.status === 'betaald').length ?? 0;

const statusLabels: Record<string, string> = {
  betaald: 'Betaald',
  in_behandeling: 'In behandeling',
  verzonden: 'Verzonden',
  afgehaald: 'Afgehaald',
  geannuleerd: 'Geannuleerd',
};

const statusColors: Record<string, string> = {
  betaald: 'bg-green-100 text-green-800',
  in_behandeling: 'bg-blue-100 text-blue-800',
  verzonden: 'bg-purple-100 text-purple-800',
  afgehaald: 'bg-gray-100 text-gray-600',
  geannuleerd: 'bg-red-100 text-red-700',
};

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('nl-NL', { day: '2-digit', month: 'short', year: 'numeric' });
}

function formatEuro(amount: number) {
  return new Intl.NumberFormat('nl-NL', { style: 'currency', currency: 'EUR' }).format(amount);
}
---

<AdminLayout title="Online Bestellingen">
  <div class="pt-8 pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6">
      <nav class="mb-10 flex items-center gap-3 text-[10px] tracking-[0.2em] uppercase text-taupe font-body">
        <a href="/admin" class="hover:text-charcoal transition-colors">Dashboard</a>
        <span class="text-champagne">›</span>
        <span class="text-charcoal">Online bestellingen</span>
      </nav>

      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="text-[10px] tracking-[0.3em] uppercase text-blush-deep font-body mb-2">Stripe</p>
          <h1 class="font-display font-normal text-charcoal text-4xl leading-tight">
            Online <em class="font-normal italic text-taupe">Bestellingen</em>
          </h1>
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-6 mb-10">
        <div class="glass-card p-6">
          <p class="text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-1">Totaal</p>
          <p class="font-display text-3xl text-charcoal">{total}</p>
        </div>
        <div class="glass-card p-6">
          <p class="text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-1">Nieuw (betaald)</p>
          <p class="font-display text-3xl text-charcoal">{newOrders}</p>
        </div>
        <div class="glass-card p-6">
          <p class="text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-1">Totale omzet</p>
          <p class="font-display text-3xl text-charcoal">{formatEuro(totalRevenue)}</p>
        </div>
      </div>

      <!-- Orders table -->
      {orders && orders.length > 0 ? (
        <div class="glass-card overflow-hidden">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-linen">
                <th class="text-left p-4 text-[10px] tracking-[0.2em] uppercase text-taupe font-body font-normal">Datum</th>
                <th class="text-left p-4 text-[10px] tracking-[0.2em] uppercase text-taupe font-body font-normal">Klant</th>
                <th class="text-left p-4 text-[10px] tracking-[0.2em] uppercase text-taupe font-body font-normal">Product</th>
                <th class="text-left p-4 text-[10px] tracking-[0.2em] uppercase text-taupe font-body font-normal">Maat</th>
                <th class="text-left p-4 text-[10px] tracking-[0.2em] uppercase text-taupe font-body font-normal">Betaling</th>
                <th class="text-right p-4 text-[10px] tracking-[0.2em] uppercase text-taupe font-body font-normal">Bedrag</th>
                <th class="text-left p-4 text-[10px] tracking-[0.2em] uppercase text-taupe font-body font-normal">Status</th>
                <th class="text-left p-4 text-[10px] tracking-[0.2em] uppercase text-taupe font-body font-normal"></th>
              </tr>
            </thead>
            <tbody>
              {orders.map((order) => (
                <tr class="border-b border-linen/50 hover:bg-cream/30 transition-colors" data-id={order.id}>
                  <td class="p-4 text-taupe text-xs">{formatDate(order.created_at)}</td>
                  <td class="p-4">
                    <p class="font-medium text-charcoal">{order.first_name} {order.last_name}</p>
                    <p class="text-xs text-taupe">{order.email}</p>
                    {order.phone && <p class="text-xs text-taupe">{order.phone}</p>}
                  </td>
                  <td class="p-4">
                    <p class="text-charcoal">{order.product_name}</p>
                  </td>
                  <td class="p-4 text-taupe">{order.size ?? '—'}</td>
                  <td class="p-4 text-xs text-taupe capitalize">{order.payment_type === 'aanbetaling' ? '50% aanbetaling' : 'Volledig'}</td>
                  <td class="p-4 text-right font-medium text-charcoal">{formatEuro(order.amount_paid)}</td>
                  <td class="p-4">
                    <select
                      class="status-select text-xs border border-linen rounded px-2 py-1 bg-white focus:outline-none focus:border-gold cursor-pointer"
                      data-id={order.id}
                      value={order.status}
                    >
                      {Object.entries(statusLabels).map(([val, label]) => (
                        <option value={val} selected={order.status === val}>{label}</option>
                      ))}
                    </select>
                  </td>
                  <td class="p-4">
                    <span class={`inline-block px-2 py-0.5 rounded-full text-xs font-medium ${statusColors[order.status] ?? 'bg-gray-100 text-gray-600'}`}>
                      {statusLabels[order.status] ?? order.status}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="glass-card p-16 text-center">
          <p class="font-display text-2xl text-taupe mb-2">Nog geen bestellingen</p>
          <p class="text-sm text-taupe/70">Bestellingen via Stripe verschijnen hier zodra klanten een product kopen.</p>
        </div>
      )}
    </div>
  </div>
</AdminLayout>

<script>
  document.querySelectorAll<HTMLSelectElement>('.status-select').forEach((select) => {
    select.addEventListener('change', async () => {
      const id = select.dataset.id;
      const status = select.value;
      try {
        const res = await fetch(`/api/admin/online-bestellingen/${id}`, {
          method: 'PATCH',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ status }),
        });
        if (!res.ok) {
          alert('Status bijwerken mislukt.');
          // Reset to original
          location.reload();
        }
      } catch {
        alert('Verbindingsfout.');
        location.reload();
      }
    });
  });
</script>
