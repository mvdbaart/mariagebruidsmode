---
import Layout from '../../../layouts/Layout.astro';
import { getServiceRoleClient } from '../../../lib/serverAuth';

const supabase = getServiceRoleClient();
const { data: collections } = await supabase
  .from('collections')
  .select('id, title, type')
  .order('title', { ascending: true });
---

<Layout title="Nieuw Product">
  <div class="pt-32 pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6 max-w-3xl">
      <nav class="mb-10 flex items-center gap-3 text-[10px] tracking-[0.2em] uppercase text-taupe font-body">
        <a href="/admin" class="hover:text-blush-deep transition-colors">Dashboard</a>
        <span class="text-champagne">/</span>
        <a href="/admin/producten" class="hover:text-blush-deep transition-colors">Beheer Producten</a>
        <span class="text-champagne">/</span>
        <span class="text-charcoal">Nieuw Product</span>
      </nav>

      <div class="bg-white border border-champagne p-10 shadow-soft">
        <h1 class="font-display font-normal text-charcoal text-3xl mb-10">Nieuw <em class="italic font-light">product</em></h1>

        <form id="new-product-form" class="space-y-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Product Naam *</label>
              <input type="text" name="name" required id="product-name" class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" />
            </div>
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Brand</label>
              <input type="text" name="brand" class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" />
            </div>
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Collectie</label>
              <select name="collection_id" class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent">
                <option value="">— Geen collectie —</option>
                {collections?.map((col) => (
                  <option value={col.id}>{col.title} ({col.type === 'dress' ? 'Jurken' : col.type === 'suit' ? 'Pakken' : 'Accessoires'})</option>
                ))}
              </select>
            </div>
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Slug *</label>
              <input type="text" name="slug" required id="product-slug" class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" />
            </div>
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Prijs (bijv. € 1.500 – € 2.500)</label>
              <input type="text" name="price_range" class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" placeholder="€ 1.000 – € 2.000" />
            </div>
          </div>

          <div class="space-y-2">
            <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Beschrijving</label>
            <textarea name="description" rows="4" class="w-full border border-champagne p-4 focus:border-charcoal outline-none transition-colors font-body font-light bg-cream/30 resize-none"></textarea>
          </div>

          <div class="space-y-2">
            <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Kenmerken (komma gescheiden)</label>
            <input type="text" name="features" class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" placeholder="A-lijn, Kanten details, Sleeptrain" />
          </div>

          <div class="space-y-2">
            <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Afbeelding URL</label>
            <input type="url" name="image_url" class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" placeholder="https://..." />
          </div>

          <div class="flex gap-4 pt-4">
            <button type="submit" class="btn-premium text-[10px]">Product Toevoegen</button>
            <a href="/admin/producten" class="btn-gold text-[10px]">Annuleren</a>
          </div>
          <p id="form-status" class="text-sm font-body font-light hidden"></p>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Auto-generate slug from name
  const nameInput = document.getElementById('product-name') as HTMLInputElement;
  const slugInput = document.getElementById('product-slug') as HTMLInputElement;
  let slugManuallyEdited = false;

  slugInput?.addEventListener('input', () => { slugManuallyEdited = true; });
  nameInput?.addEventListener('input', () => {
    if (!slugManuallyEdited) {
      slugInput.value = nameInput.value.toLowerCase()
        .replace(/[^a-z0-9\s-]/g, '')
        .trim()
        .replace(/\s+/g, '-');
    }
  });

  const form = document.getElementById('new-product-form') as HTMLFormElement;
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;
    status.textContent = 'Bezig met opslaan...';
    status.className = 'text-sm font-body font-light text-taupe block';

    const data = new FormData(form);
    const featuresLine = data.get('features') as string;
    const imageUrl = data.get('image_url') as string;

    const response = await fetch('/api/admin/products', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({
        name: data.get('name'),
        slug: data.get('slug'),
        brand: data.get('brand') || null,
        collection_id: data.get('collection_id') || null,
        description: data.get('description') || null,
        price_range: data.get('price_range') || null,
        features: featuresLine ? featuresLine.split(',').map(f => f.trim()).filter(Boolean) : [],
        images: imageUrl ? [imageUrl] : [],
      }),
    });
    const result = await response.json().catch(() => ({ error: 'Onbekende fout.' }));

    if (!response.ok) {
      status.textContent = 'Fout: ' + result.error;
      status.className = 'text-sm font-body font-light text-red-500 block';
    } else {
      status.textContent = 'Product toegevoegd!';
      status.className = 'text-sm font-body font-light text-green-600 block';
      setTimeout(() => { window.location.href = '/admin/producten'; }, 1200);
    }
  });
</script>
