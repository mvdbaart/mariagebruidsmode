---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Nieuw Product">
  <div class="pt-32 pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6 max-w-2xl">
      <nav class="mb-10 flex items-center gap-3 text-[10px] tracking-[0.2em] uppercase text-taupe font-body">
        <a href="/admin" class="hover:text-blush-deep transition-colors">Dashboard</a>
        <span class="text-champagne">/</span>
        <a href="/admin/producten" class="hover:text-blush-deep transition-colors">Beheer Producten</a>
        <span class="text-champagne">/</span>
        <span class="text-charcoal">Nieuw Product</span>
      </nav>

      <div class="bg-white border border-champagne p-10 shadow-soft">
        <h1 class="font-display font-normal text-charcoal text-3xl mb-4">Nieuw product</h1>
        <p class="text-taupe font-body font-light leading-relaxed">
          Deze pagina is nog niet ingericht. Gebruik voorlopig de seed scripts of voeg eerst producten toe in Supabase.
        </p>
        <a href="/admin/producten" class="btn-premium text-[10px] mt-8">Terug naar producten</a>
      </div>
    </div>
  </div>
</Layout>

