---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getServiceRoleClient } from '../../../lib/serverAuth';
import { PRODUCT_QUALITIES } from '../../../lib/productQualities';

const supabase = getServiceRoleClient();
const { data: collections } = await supabase
  .from('collections')
  .select('id, title, type')
  .order('title', { ascending: true });
---

<AdminLayout title="Nieuw Product">
  <div class="pt-8 pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6 max-w-3xl">
      <nav class="mb-10 flex items-center gap-3 text-[10px] tracking-[0.2em] uppercase text-taupe font-body">
        <a href="/admin" class="hover:text-blush-deep transition-colors">Dashboard</a>
        <span class="text-champagne">/</span>
        <a href="/admin/producten" class="hover:text-blush-deep transition-colors">Beheer Producten</a>
        <span class="text-champagne">/</span>
        <span class="text-charcoal">Nieuw Product</span>
      </nav>

      <div class="bg-white border border-champagne p-10 shadow-soft">
        <h1 class="font-display font-normal text-charcoal text-3xl mb-10">Nieuw <em class="italic font-light">product</em></h1>

        <form id="new-product-form" class="space-y-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Product Naam *</label>
              <input type="text" name="name" required id="product-name" class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" />
            </div>
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Brand</label>
              <input type="text" name="brand" class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" />
            </div>
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Collectie</label>
              <select name="collection_id" class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent">
                <option value="">— Geen collectie —</option>
                {collections?.map((col) => (
                  <option value={col.id}>{col.title} ({col.type === 'dress' ? 'Jurken' : col.type === 'suit' ? 'Pakken' : 'Accessoires'})</option>
                ))}
              </select>
            </div>
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Slug *</label>
              <input type="text" name="slug" required id="product-slug" class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" />
            </div>
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Prijs (bijv. € 1.500 – € 2.500)</label>
              <input type="text" name="price_range" class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" placeholder="€ 1.000 – € 2.000" />
            </div>
          </div>

          <div class="space-y-2">
            <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Beschrijving</label>
            <textarea name="description" rows="4" class="w-full border border-champagne p-4 focus:border-charcoal outline-none transition-colors font-body font-light bg-cream/30 resize-none"></textarea>
          </div>

          <div class="space-y-2">
            <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Kenmerken (komma gescheiden)</label>
            <input type="text" name="features" class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" placeholder="A-lijn, Kanten details, Sleeptrain" />
          </div>

          <!-- Product Qualities -->
          <div class="space-y-4">
            <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium block">Product Kwaliteiten</label>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {PRODUCT_QUALITIES.map((q) => (
                <label class="quality-checkbox-label flex items-center gap-4 p-4 border border-champagne hover:border-charcoal/30 bg-white cursor-pointer select-none transition-all" data-id={q.id}>
                  <input type="checkbox" name="qualities" value={q.id} class="sr-only quality-checkbox" />
                  <svg viewBox="0 0 80 80" class="w-10 h-10 shrink-0 text-charcoal/60" fill="none" stroke="currentColor" stroke-width="1.5" set:html={q.svgContent} />
                  <div>
                    <p class="text-[11px] uppercase tracking-[0.12em] font-medium text-charcoal">{q.label}</p>
                    <p class="text-[10px] text-taupe font-light leading-snug mt-0.5">{q.description}</p>
                  </div>
                </label>
              ))}
            </div>
          </div>

          <div class="space-y-6" id="file-uploader">
            <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium block">Product Media (Afbeeldingen & Video)</label>
            
            <!-- Drop Zone -->
            <div id="drop-zone" class="border-2 border-dashed border-champagne p-12 text-center hover:bg-cream/10 transition-all cursor-pointer rounded-lg group">
              <input type="file" id="file-input" multiple accept="image/*,video/*" class="hidden" />
              <div class="flex flex-col items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-taupe/30 group-hover:text-charcoal transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                </svg>
                <p class="text-[11px] uppercase tracking-widest text-taupe group-hover:text-charcoal transition-colors">Sleep bestanden hierheen of klik om te uploaden</p>
                <p class="text-[10px] text-taupe/40 italic">Ondersteunt: JPG, PNG, WEBP, MP4</p>
              </div>
            </div>

            <!-- Uploading Progress -->
            <div id="upload-status" class="hidden space-y-2">
              <div class="flex justify-between text-[10px] uppercase tracking-wider text-blush-deep">
                <span>Uploaden...</span>
                <span id="upload-progress">0%</span>
              </div>
              <div class="w-full bg-champagne/20 h-1 rounded-full overflow-hidden">
                <div id="progress-bar" class="bg-blush-deep h-full transition-all duration-300" style="width: 0%"></div>
              </div>
            </div>

            <!-- Gallery -->
            <div id="file-gallery" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6 pt-4">
              <!-- Files will be injected here -->
            </div>
            
            <p class="text-[10px] text-taupe/50 uppercase tracking-wider italic">De eerste afbeelding in de rij wordt gebruikt als preview image.</p>
          </div>

          <script>
            const dropZone = document.getElementById('drop-zone');
            const fileInput = document.getElementById('file-input');
            const gallery = document.getElementById('file-gallery');
            const statusDiv = document.getElementById('upload-status');
            const progressBar = document.getElementById('progress-bar');
            const progressText = document.getElementById('upload-progress');

            let files = [];

            function renderGallery() {
              if (!gallery) return;
              gallery.innerHTML = '';
              
              files.forEach((url, index) => {
                const item = document.createElement('div');
                item.className = 'relative aspect-[3/4] bg-cream/20 border border-champagne group overflow-hidden rounded-md shadow-soft';
                
                const isVideo = url.toLowerCase().endsWith('.mp4');
                
                item.innerHTML = `
                  <div class="w-full h-full">
                    ${isVideo 
                      ? `<div class="w-full h-full flex flex-col items-center justify-center bg-linen">
                           <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-taupe/30" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                           <span class="text-[8px] uppercase tracking-tighter text-taupe/50 mt-2 truncate max-w-full px-2">Video</span>
                         </div>`
                      : `<img src="${url}" class="w-full h-full object-cover" />`
                    }
                  </div>
                  
                  <!-- Preview Badge -->
                  ${index === 0 ? `<div class="absolute top-2 left-2 bg-blush-deep text-white text-[8px] uppercase tracking-wider px-2 py-0.5 rounded-full z-10 shadow-sm">Preview</div>` : ''}

                  <!-- Actions Overlay -->
                  <div class="absolute inset-x-0 bottom-0 bg-charcoal/80 backdrop-blur-sm p-3 flex justify-between items-center opacity-0 group-hover:opacity-100 transition-all transform translate-y-2 group-hover:translate-y-0">
                    <div class="flex gap-1">
                      <button type="button" class="move-up-btn p-1.5 bg-white/10 hover:bg-white/20 text-white rounded transition-colors disabled:opacity-20" data-index="${index}" ${index === 0 ? 'disabled' : ''}>
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                      </button>
                      <button type="button" class="move-down-btn p-1.5 bg-white/10 hover:bg-white/20 text-white rounded transition-colors disabled:opacity-20" data-index="${index}" ${index === files.length - 1 ? 'disabled' : ''}>
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                      </button>
                    </div>
                    <button type="button" class="remove-btn p-1.5 bg-red-500/20 hover:bg-red-500 text-white rounded transition-colors" data-index="${index}">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                  </div>
                `;
                gallery.appendChild(item);
              });

              // Add event listeners
              document.querySelectorAll('.move-up-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                  e.stopPropagation();
                  const idx = parseInt(btn.dataset.index);
                  if (idx > 0) {
                    [files[idx], files[idx-1]] = [files[idx-1], files[idx]];
                    renderGallery();
                  }
                });
              });

              document.querySelectorAll('.move-down-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                  e.stopPropagation();
                  const idx = parseInt(btn.dataset.index);
                  if (idx < files.length - 1) {
                    [files[idx], files[idx+1]] = [files[idx+1], files[idx]];
                    renderGallery();
                  }
                });
              });

              document.querySelectorAll('.remove-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                  e.stopPropagation();
                  const idx = parseInt(btn.dataset.index);
                  files.splice(idx, 1);
                  renderGallery();
                });
              });
            }

            async function uploadFiles(newFiles) {
              if (!statusDiv || !progressBar || !progressText) return;
              statusDiv.classList.remove('hidden');
              
              const total = newFiles.length;
              let uploaded = 0;

              for (const file of newFiles) {
                const formData = new FormData();
                formData.append('file', file);
                formData.append('bucket', 'products');

                try {
                  const response = await fetch('/api/admin/upload', {
                    method: 'POST',
                    body: formData
                  });
                  const result = await response.json();
                  if (result.url) {
                    files.push(result.url);
                  }
                } catch (err) {
                  console.error('Upload failed:', err);
                }

                uploaded++;
                const percent = Math.round((uploaded / total) * 100);
                progressBar.style.width = `${percent}%`;
                progressText.textContent = `${percent}%`;
              }

              setTimeout(() => {
                statusDiv.classList.add('hidden');
                progressBar.style.width = '0%';
                renderGallery();
              }, 1000);
            }

            // Drag & Drop
            dropZone?.addEventListener('click', () => fileInput.click());
            
            dropZone?.addEventListener('dragover', (e) => {
              e.preventDefault();
              dropZone.classList.add('bg-cream/10', 'border-charcoal');
            });

            ['dragleave', 'dragend'].forEach(type => {
              dropZone?.addEventListener(type, () => {
                dropZone.classList.remove('bg-cream/10', 'border-charcoal');
              });
            });

            dropZone?.addEventListener('drop', (e) => {
              e.preventDefault();
              dropZone.classList.remove('bg-cream/10', 'border-charcoal');
              const droppedFiles = Array.from(e.dataTransfer.files);
              if (droppedFiles.length) uploadFiles(droppedFiles);
            });

            fileInput?.addEventListener('change', () => {
              const selectedFiles = Array.from(fileInput.files);
              if (selectedFiles.length) uploadFiles(selectedFiles);
              fileInput.value = ''; // Reset
            });

            renderGallery();

            (window as any).getCurrentImages = () => files;
          </script>

          <div class="flex gap-4 pt-4">
            <button type="submit" class="btn-premium text-[10px]">Product Toevoegen</button>
            <a href="/admin/producten" class="btn-gold text-[10px]">Annuleren</a>
          </div>
          <p id="form-status" class="text-sm font-body font-light hidden"></p>
        </form>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  // Quality checkbox toggle styling
  document.querySelectorAll<HTMLLabelElement>('.quality-checkbox-label').forEach((label) => {
    const cb = label.querySelector<HTMLInputElement>('.quality-checkbox');
    if (!cb) return;
    label.addEventListener('click', () => {
      requestAnimationFrame(() => {
        if (cb.checked) {
          label.classList.add('border-charcoal', 'bg-cream/30');
          label.classList.remove('border-champagne', 'bg-white');
        } else {
          label.classList.remove('border-charcoal', 'bg-cream/30');
          label.classList.add('border-champagne', 'bg-white');
        }
      });
    });
  });

  // Auto-generate slug from name
  const nameInput = document.getElementById('product-name') as HTMLInputElement;
  const slugInput = document.getElementById('product-slug') as HTMLInputElement;
  let slugManuallyEdited = false;

  slugInput?.addEventListener('input', () => { slugManuallyEdited = true; });
  nameInput?.addEventListener('input', () => {
    if (!slugManuallyEdited) {
      slugInput.value = nameInput.value.toLowerCase()
        .replace(/[^a-z0-9\s-]/g, '')
        .trim()
        .replace(/\s+/g, '-');
    }
  });

  const form = document.getElementById('new-product-form') as HTMLFormElement;
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;
    status.textContent = 'Bezig met opslaan...';
    status.className = 'text-sm font-body font-light text-taupe block';

    const data = new FormData(form);
    const featuresLine = data.get('features') as string;
    const imageUrl = data.get('image_url') as string;

    const response = await fetch('/api/admin/products', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({
        name: data.get('name'),
        slug: data.get('slug'),
        brand: data.get('brand') || null,
        collection_id: data.get('collection_id') || null,
        description: data.get('description') || null,
        price_range: data.get('price_range') || null,
        features: featuresLine ? featuresLine.split(',').map(f => f.trim()).filter(Boolean) : [],
        qualities: data.getAll('qualities'),
        images: (window as any).getCurrentImages ? (window as any).getCurrentImages() : [],
      }),
    });
    const result = await response.json().catch(() => ({ error: 'Onbekende fout.' }));

    if (!response.ok) {
      status.textContent = 'Fout: ' + result.error;
      status.className = 'text-sm font-body font-light text-red-500 block';
    } else {
      status.textContent = 'Product toegevoegd!';
      status.className = 'text-sm font-body font-light text-green-600 block';
      setTimeout(() => { window.location.href = '/admin/producten'; }, 1200);
    }
  });
</script>
