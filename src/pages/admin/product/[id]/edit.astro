---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { supabase } from '../../../../lib/supabase';
import { PRODUCT_QUALITIES } from '../../../../lib/productQualities';
import { DRESS_STYLES } from '../../../../lib/productStyles';

const { id } = Astro.params;

const { data: product, error } = await supabase
  .from('products')
  .select('*, collections(title)')
  .eq('id', id)
  .single();

if (error || !product) {
  return Astro.redirect('/admin/producten');
}

const { data: collections } = await supabase
  .from('collections')
  .select('id, title')
  .order('title', { ascending: true });

const previewFallbackImage = '/images/jurkvormen/a-lijn.png';

function encodeImagePath(url: string | null | undefined): string {
  if (!url) return previewFallbackImage;
  if (/^https?:\/\//.test(url)) return url;
  return url.split('/').map((s) => encodeURIComponent(s)).join('/');
}

const styleKeys = new Set(DRESS_STYLES.map((s) => s.key));
const productFeatures: string[] = Array.isArray(product.features) ? product.features : [];
const productStyleKeys = productFeatures.filter((f) => styleKeys.has(f as any));
const productCustomTags = productFeatures.filter((f) => !styleKeys.has(f as any)).join(', ');
---

<AdminLayout title={`Bewerk ${product.name}`}>
  <div class="pt-8 pb-24 bg-accent/5 min-h-screen">
    <div class="container mx-auto px-6">
      <nav class="mb-12 flex items-center gap-4 text-[10px] tracking-[0.2em] uppercase text-accent/40">
        <a href="/admin" class="hover:text-secondary">Dashboard</a>
        <span>/</span>
        <a href="/admin/producten" class="hover:text-secondary">Beheer Producten</a>
        <span>/</span>
        <span class="text-secondary">Bewerk Product</span>
      </nav>

      <div class="max-w-7xl grid grid-cols-1 xl:grid-cols-[minmax(0,1fr)_360px] gap-8 items-start">
        <div class="bg-white border border-secondary/10 shadow-sm p-12">
        <h1 class="text-3xl font-serif text-accent italic mb-12">Bewerk <span class="text-secondary opacity-50">{product.name}</span></h1>

        <form id="edit-product-form" class="space-y-8">
          <input type="hidden" name="id" value={product.id} />
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-accent font-medium">Product Naam</label>
              <input type="text" name="name" value={product.name} required class="w-full border-b border-accent/20 py-3 focus:border-secondary outline-none transition-colors font-light bg-transparent" />
            </div>
            
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-accent font-medium">Brand</label>
              <input type="text" name="brand" value={product.brand} class="w-full border-b border-accent/20 py-3 focus:border-secondary outline-none transition-colors font-light bg-transparent" />
            </div>

            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-accent font-medium">Collectie</label>
              <select name="collection_id" class="w-full border-b border-accent/20 py-3 focus:border-secondary outline-none transition-colors font-light bg-transparent">
                {collections?.map((col) => (
                  <option value={col.id} selected={col.id === product.collection_id}>{col.title}</option>
                ))}
              </select>
            </div>

            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-accent font-medium">Slug</label>
              <input type="text" name="slug" value={product.slug} required class="w-full border-b border-accent/20 py-3 focus:border-secondary outline-none transition-colors font-light bg-transparent" />
            </div>

            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-accent font-medium">Prijsrange</label>
              <input type="text" name="price_range" value={product.price_range ?? ''} class="w-full border-b border-accent/20 py-3 focus:border-secondary outline-none transition-colors font-light bg-transparent" placeholder="€ 1.500 - € 2.500" />
            </div>
          </div>

          <div class="space-y-2">
            <label class="text-[10px] tracking-widest uppercase text-accent font-medium">Beschrijving</label>
            <textarea name="description" rows="4" class="w-full border border-accent/10 p-4 focus:border-secondary outline-none transition-colors font-light bg-primary/10 resize-none">{product.description}</textarea>
          </div>

          <!-- Stijlkenmerken (predefined styles) -->
          <div class="space-y-4">
            <label class="text-[10px] tracking-widest uppercase text-accent font-medium block">Stijlkenmerken</label>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {DRESS_STYLES.map((style) => {
                const checked = productStyleKeys.includes(style.key);
                return (
                  <label class={`style-checkbox-label flex items-center gap-3 px-4 py-3 border cursor-pointer select-none transition-all text-[11px] uppercase tracking-[0.1em] font-body ${checked ? 'border-secondary bg-secondary/5 text-accent' : 'border-accent/10 hover:border-accent/30 bg-white text-accent/60'}`} data-key={style.key}>
                    <input type="checkbox" name="style_keys" value={style.key} checked={checked} class="sr-only style-checkbox" />
                    <span class={`w-4 h-4 border flex-shrink-0 flex items-center justify-center transition-colors ${checked ? 'border-secondary bg-secondary' : 'border-accent/20 bg-white'}`}>
                      {checked && (
                        <svg width="10" height="8" viewBox="0 0 10 8" fill="none">
                          <path d="M1 4l3 3 5-6" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      )}
                    </span>
                    {style.label}
                  </label>
                );
              })}
            </div>
          </div>

          <!-- Custom tags -->
          <div class="space-y-2">
            <label class="text-[10px] tracking-widest uppercase text-accent font-medium">Overige tags (komma gescheiden)</label>
            <input type="text" id="custom-tags-input" value={productCustomTags} class="w-full border-b border-accent/20 py-3 focus:border-secondary outline-none transition-colors font-light bg-transparent" placeholder="bijv. kant, #bohemian, #2026" />
            <p class="text-[9px] text-accent/40 font-light">Vrij tekstveld voor extra kenmerken. Gebruik # voor hashtags.</p>
          </div>

          <!-- Product Qualities -->
          <div class="space-y-4">
            <label class="text-[10px] tracking-widest uppercase text-accent font-medium block">Product Kwaliteiten</label>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {PRODUCT_QUALITIES.map((q) => {
                const checked = Array.isArray(product.qualities) && product.qualities.includes(q.id);
                return (
                  <label class={`quality-checkbox-label flex items-center gap-4 p-4 border cursor-pointer select-none transition-all ${checked ? 'border-secondary bg-secondary/5' : 'border-accent/10 hover:border-accent/30 bg-white'}`} data-id={q.id}>
                    <input type="checkbox" name="qualities" value={q.id} checked={checked} class="sr-only quality-checkbox" />
                    <svg viewBox="0 0 80 80" class="w-10 h-10 shrink-0 text-accent/70" fill="none" stroke="currentColor" stroke-width="1.5" set:html={q.svgContent} />
                    <div>
                      <p class="text-[11px] uppercase tracking-[0.12em] font-medium text-accent">{q.label}</p>
                      <p class="text-[10px] text-accent/50 font-light leading-snug mt-0.5">{q.description}</p>
                    </div>
                  </label>
                );
              })}
            </div>
          </div>

          <div class="space-y-6" id="file-uploader">
            <label class="text-[10px] tracking-widest uppercase text-accent font-medium block">Product Media (Afbeeldingen & Video)</label>
            
            <!-- Drop Zone -->
            <div id="drop-zone" class="border-2 border-dashed border-accent/20 p-12 text-center hover:bg-accent/5 transition-all cursor-pointer rounded-lg group">
              <input type="file" id="file-input" multiple accept="image/*,video/*" class="hidden" />
              <div class="flex flex-col items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-accent/30 group-hover:text-secondary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                </svg>
                <p class="text-[11px] uppercase tracking-widest text-accent/60 group-hover:text-accent transition-colors">Sleep bestanden hierheen of klik om te uploaden</p>
                <p class="text-[10px] text-accent/40 italic">Ondersteunt: JPG, PNG, WEBP, MP4</p>
              </div>
            </div>

            <!-- Uploading Progress -->
            <div id="upload-status" class="hidden space-y-2">
              <div class="flex justify-between text-[10px] uppercase tracking-wider text-secondary">
                <span>Uploaden...</span>
                <span id="upload-progress">0%</span>
              </div>
              <div class="w-full bg-accent/10 h-1 rounded-full overflow-hidden">
                <div id="progress-bar" class="bg-secondary h-full transition-all duration-300" style="width: 0%"></div>
              </div>
            </div>

            <!-- Gallery -->
            <div id="file-gallery" class="grid grid-cols-2 sm:grid-cols-3 gap-4 pt-2">
              <!-- Filled by renderGallery() -->
            </div>
            
            <p class="text-[10px] text-accent/50 uppercase tracking-wider italic">De eerste afbeelding in de rij wordt gebruikt als preview image.</p>
          </div>

          <script define:vars={{ initialImages: product.images }}>
            const dropZone = document.getElementById('drop-zone');
            const fileInput = document.getElementById('file-input');
            const gallery = document.getElementById('file-gallery');
            const statusDiv = document.getElementById('upload-status');
            const progressBar = document.getElementById('progress-bar');
            const progressText = document.getElementById('upload-progress');
            const fallbackSrc = '/images/jurkvormen/a-lijn.png';

            // Encode spaces/special chars in local paths so the browser resolves them correctly.
            // Leave absolute http(s) URLs untouched (Supabase storage etc.).
            function toSrc(url) {
              if (!url) return fallbackSrc;
              if (/^https?:\/\//.test(url)) return url;
              return url.split('/').map((seg) => encodeURIComponent(seg)).join('/');
            }

            let files = Array.isArray(initialImages) ? [...initialImages] : [];

            function renderGallery() {
              if (!gallery) return;
              gallery.innerHTML = '';

              if (files.length === 0) {
                gallery.innerHTML = '<p class="col-span-full text-[11px] text-taupe italic font-body py-4">Nog geen afbeeldingen toegevoegd.</p>';
                document.dispatchEvent(new CustomEvent('product-images-changed'));
                return;
              }

              files.forEach((url, index) => {
                const isVideo = typeof url === 'string' && url.toLowerCase().endsWith('.mp4');
                const isFirst = index === 0;

                const item = document.createElement('div');
                item.className = 'border border-champagne bg-white overflow-hidden';

                // Thumbnail
                const thumb = document.createElement('div');
                thumb.className = 'relative aspect-[3/4] bg-linen overflow-hidden';

                if (isVideo) {
                  thumb.innerHTML = `
                    <div class="w-full h-full flex flex-col items-center justify-center gap-2 bg-charcoal/5">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-taupe" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <span class="text-[9px] uppercase tracking-widest text-taupe font-body">Video</span>
                    </div>`;
                } else {
                  const img = document.createElement('img');
                  img.src = toSrc(url);
                  img.alt = 'Product afbeelding ' + (index + 1);
                  img.className = 'w-full h-full object-cover';
                  img.onerror = () => { img.onerror = null; img.src = fallbackSrc; };
                  thumb.appendChild(img);
                }

                // Main badge
                if (isFirst) {
                  const badge = document.createElement('div');
                  badge.className = 'absolute top-2 left-2 bg-charcoal text-white text-[8px] uppercase tracking-[0.15em] font-body px-2 py-1 z-10';
                  badge.textContent = 'Hoofdafbeelding';
                  thumb.appendChild(badge);
                }

                item.appendChild(thumb);

                // Controls bar below image
                const controls = document.createElement('div');
                controls.className = 'flex items-center justify-between px-3 py-2 border-t border-champagne bg-ivory';

                // Position label
                const pos = document.createElement('span');
                pos.className = 'text-[10px] tracking-[0.1em] uppercase font-body text-taupe';
                pos.textContent = isFirst ? '1 — Hoofd' : String(index + 1);
                controls.appendChild(pos);

                // Arrow buttons + remove
                const btnGroup = document.createElement('div');
                btnGroup.className = 'flex items-center gap-1';

                const upBtn = document.createElement('button');
                upBtn.type = 'button';
                upBtn.title = 'Omhoog';
                upBtn.disabled = index === 0;
                upBtn.className = 'move-up-btn p-1.5 border border-champagne text-taupe hover:border-charcoal hover:text-charcoal transition-colors disabled:opacity-25 disabled:cursor-not-allowed';
                upBtn.dataset.index = String(index);
                upBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 15l-7-7-7 7"/></svg>`;

                const downBtn = document.createElement('button');
                downBtn.type = 'button';
                downBtn.title = 'Omlaag';
                downBtn.disabled = index === files.length - 1;
                downBtn.className = 'move-down-btn p-1.5 border border-champagne text-taupe hover:border-charcoal hover:text-charcoal transition-colors disabled:opacity-25 disabled:cursor-not-allowed';
                downBtn.dataset.index = String(index);
                downBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 9l7 7 7-7"/></svg>`;

                const removeBtn = document.createElement('button');
                removeBtn.type = 'button';
                removeBtn.title = 'Verwijderen';
                removeBtn.className = 'remove-btn p-1.5 border border-champagne text-red-400 hover:border-red-400 hover:text-red-600 transition-colors ml-1';
                removeBtn.dataset.index = String(index);
                removeBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>`;

                upBtn.addEventListener('click', () => {
                  const idx = parseInt(upBtn.dataset.index);
                  if (idx > 0) { [files[idx], files[idx - 1]] = [files[idx - 1], files[idx]]; renderGallery(); }
                });
                downBtn.addEventListener('click', () => {
                  const idx = parseInt(downBtn.dataset.index);
                  if (idx < files.length - 1) { [files[idx], files[idx + 1]] = [files[idx + 1], files[idx]]; renderGallery(); }
                });
                removeBtn.addEventListener('click', () => {
                  const idx = parseInt(removeBtn.dataset.index);
                  files.splice(idx, 1);
                  renderGallery();
                });

                btnGroup.appendChild(upBtn);
                btnGroup.appendChild(downBtn);
                btnGroup.appendChild(removeBtn);
                controls.appendChild(btnGroup);
                item.appendChild(controls);
                gallery.appendChild(item);
              });

              document.dispatchEvent(new CustomEvent('product-images-changed'));
            }

            async function uploadFiles(newFiles) {
              if (!statusDiv || !progressBar || !progressText) return;
              statusDiv.classList.remove('hidden');
              
              const total = newFiles.length;
              let uploaded = 0;

              for (const file of newFiles) {
                const formData = new FormData();
                formData.append('file', file);
                formData.append('bucket', 'products');

                try {
                  const response = await fetch('/api/admin/upload', {
                    method: 'POST',
                    body: formData
                  });
                  const result = await response.json();
                  if (result.url) {
                    files.push(result.url);
                  }
                } catch (err) {
                  console.error('Upload failed:', err);
                }

                uploaded++;
                const percent = Math.round((uploaded / total) * 100);
                progressBar.style.width = `${percent}%`;
                progressText.textContent = `${percent}%`;
              }

              setTimeout(() => {
                statusDiv.classList.add('hidden');
                progressBar.style.width = '0%';
                renderGallery();
              }, 1000);
            }

            // Drag & Drop
            dropZone?.addEventListener('click', () => fileInput.click());
            
            dropZone?.addEventListener('dragover', (e) => {
              e.preventDefault();
              dropZone.classList.add('bg-accent/5', 'border-secondary');
            });

            ['dragleave', 'dragend'].forEach(type => {
              dropZone?.addEventListener(type, () => {
                dropZone.classList.remove('bg-accent/5', 'border-secondary');
              });
            });

            dropZone?.addEventListener('drop', (e) => {
              e.preventDefault();
              dropZone.classList.remove('bg-accent/5', 'border-secondary');
              const droppedFiles = Array.from(e.dataTransfer.files);
              if (droppedFiles.length) uploadFiles(droppedFiles);
            });

            fileInput?.addEventListener('change', () => {
              const selectedFiles = Array.from(fileInput.files);
              if (selectedFiles.length) uploadFiles(selectedFiles);
              fileInput.value = ''; // Reset
            });

            (window as any).getCurrentImages = () => files;
            renderGallery();
          </script>

          <div class="flex gap-6 pt-8">
            <button type="submit" class="bg-accent text-white px-10 py-3 text-xs tracking-[0.2em] uppercase hover:opacity-80 transition-all font-medium">Opslaan Wijzigingen</button>
            <a href="/admin/producten" class="px-10 py-3 text-xs tracking-[0.2em] uppercase border border-accent/20 text-accent hover:border-accent transition-all font-medium flex items-center">Annuleren</a>
          </div>

          <p id="form-status" class="text-sm font-light hidden"></p>
        </form>
        </div>

        <aside class="xl:sticky xl:top-28">
          <div class="bg-white border border-secondary/10 shadow-sm overflow-hidden">
            <div class="aspect-[3/4] bg-primary/5 border-b border-secondary/10">
              <img
                id="preview-image"
                src={encodeImagePath(product.images?.[0])}
                alt={product.name}
                class="w-full h-full object-cover"
                onerror={`this.onerror=null;this.src='${previewFallbackImage}'`}
              />
            </div>
            <div class="p-6 space-y-4">
              <p class="text-[9px] tracking-[0.25em] uppercase text-secondary font-body">Live Preview</p>
              <p id="preview-brand" class="text-[10px] tracking-[0.2em] uppercase text-accent/70 font-body">{product.brand ?? ''}</p>
              <h2 id="preview-name" class="text-2xl font-serif text-accent leading-tight">{product.name}</h2>
              <p id="preview-price" class="text-sm text-accent/70 font-light">{product.price_range ?? ''}</p>
              <p id="preview-description" class="text-sm text-accent/70 font-light leading-relaxed whitespace-pre-line">{product.description ?? 'Nog geen omschrijving ingevuld.'}</p>
              <div>
                <p class="text-[9px] tracking-[0.2em] uppercase text-accent/50 mb-2">Specificaties</p>
                <div id="preview-specs" class="flex flex-wrap gap-2"></div>
              </div>
              <div>
                <p class="text-[9px] tracking-[0.2em] uppercase text-accent/50 mb-2">Tags</p>
                <div id="preview-tags" class="flex flex-wrap gap-2"></div>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  const form = document.getElementById('edit-product-form') as HTMLFormElement;
  const status = document.getElementById('form-status');
  const previewImage = document.getElementById('preview-image') as HTMLImageElement | null;
  const previewName = document.getElementById('preview-name');
  const previewBrand = document.getElementById('preview-brand');
  const previewPrice = document.getElementById('preview-price');
  const previewDescription = document.getElementById('preview-description');
  const previewSpecs = document.getElementById('preview-specs');
  const previewTags = document.getElementById('preview-tags');
  const previewFallback = '/images/jurkvormen/a-lijn.png';

  function parseFeatures(raw: string) {
    return raw.split(',').map((s) => s.trim()).filter(Boolean);
  }

  function renderFeatureChips() {
    if (!form || !previewSpecs || !previewTags) return;
    const styleKeys = Array.from(form.querySelectorAll<HTMLInputElement>('input[name="style_keys"]:checked')).map((cb) => cb.value);
    const customRaw = (document.getElementById('custom-tags-input') as HTMLInputElement)?.value ?? '';
    const customParts = customRaw.split(',').map((s) => s.trim()).filter(Boolean);
    const all = [...styleKeys, ...customParts];
    const specs = all.filter((item) => !item.startsWith('#'));
    const tags = all.filter((item) => item.startsWith('#'));

    previewSpecs.innerHTML = specs.length
      ? specs.map((s) => `<span class="text-[10px] uppercase tracking-[0.08em] border border-secondary/30 px-2 py-1">${s}</span>`).join('')
      : '<span class="text-xs text-accent/50 font-light">Geen specificaties.</span>';
    previewTags.innerHTML = tags.length
      ? tags.map((t) => `<span class="text-[10px] uppercase tracking-[0.08em] border border-accent/20 bg-primary/10 px-2 py-1">${t}</span>`).join('')
      : '<span class="text-xs text-accent/50 font-light">Geen tags.</span>';
  }

  function refreshPreview() {
    if (!form) return;
    const data = new FormData(form);
    const name = String(data.get('name') ?? '').trim();
    const brand = String(data.get('brand') ?? '').trim();
    const price = String(data.get('price_range') ?? '').trim();
    const description = String(data.get('description') ?? '').trim();
    const images: string[] = (window as any).getCurrentImages?.() ?? [];
    if (previewImage && Array.isArray(images) && images.length > 0) {
      const url = images[0];
      previewImage.src = /^https?:\/\//.test(url) ? url : url.split('/').map((s) => encodeURIComponent(s)).join('/');
    }
    if (previewName) previewName.textContent = name || 'Naam ontbreekt';
    if (previewBrand) previewBrand.textContent = brand || 'Merk';
    if (previewPrice) previewPrice.textContent = price || 'Prijs op aanvraag';
    if (previewDescription) previewDescription.textContent = description || 'Nog geen omschrijving ingevuld.';

    renderFeatureChips();
  }

  // Style checkbox toggle styling
  document.querySelectorAll<HTMLLabelElement>('.style-checkbox-label').forEach((label) => {
    const cb = label.querySelector<HTMLInputElement>('.style-checkbox');
    if (!cb) return;
    label.addEventListener('click', () => {
      requestAnimationFrame(() => {
        const box = label.querySelector<HTMLSpanElement>('span');
        if (cb.checked) {
          label.classList.add('border-secondary', 'bg-secondary/5', 'text-accent');
          label.classList.remove('border-accent/10', 'hover:border-accent/30', 'bg-white', 'text-accent/60');
          if (box) { box.classList.add('border-secondary', 'bg-secondary'); box.classList.remove('border-accent/20', 'bg-white'); box.innerHTML = '<svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4l3 3 5-6" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>'; }
        } else {
          label.classList.remove('border-secondary', 'bg-secondary/5', 'text-accent');
          label.classList.add('border-accent/10', 'hover:border-accent/30', 'bg-white', 'text-accent/60');
          if (box) { box.classList.remove('border-secondary', 'bg-secondary'); box.classList.add('border-accent/20', 'bg-white'); box.innerHTML = ''; }
        }
      });
    });
  });

  // Quality checkbox toggle styling
  document.querySelectorAll<HTMLLabelElement>('.quality-checkbox-label').forEach((label) => {
    const cb = label.querySelector<HTMLInputElement>('.quality-checkbox');
    if (!cb) return;
    label.addEventListener('click', () => {
      // toggle happens after click naturally; we just update styling
      requestAnimationFrame(() => {
        if (cb.checked) {
          label.classList.add('border-secondary', 'bg-secondary/5');
          label.classList.remove('border-accent/10', 'hover:border-accent/30', 'bg-white');
        } else {
          label.classList.remove('border-secondary', 'bg-secondary/5');
          label.classList.add('border-accent/10', 'hover:border-accent/30', 'bg-white');
        }
      });
    });
  });

  form?.addEventListener('input', refreshPreview);
  document.getElementById('custom-tags-input')?.addEventListener('input', refreshPreview);
  document.addEventListener('product-images-changed', refreshPreview);

  // Initial preview: if getCurrentImages is already set (inline script ran first), refresh now.
  // If not, the 'product-images-changed' event from renderGallery() will trigger it.
  if (typeof (window as any).getCurrentImages === 'function') {
    refreshPreview();
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;

    status.textContent = 'Bezig met opslaan...';
    status.className = 'text-sm font-light text-accent block mt-4';

    const formData = new FormData(form);
    const id = formData.get('id');
    const name = formData.get('name');
    const brand = formData.get('brand');
    const collection_id = formData.get('collection_id');
    const slug = formData.get('slug');
    const price_range = formData.get('price_range');
    const description = formData.get('description');
    const styleKeys = formData.getAll('style_keys') as string[];
    const customTagsRaw = (document.getElementById('custom-tags-input') as HTMLInputElement)?.value ?? '';
    const customTags = customTagsRaw.split(',').map((t) => t.trim()).filter(Boolean);
    const features = [...styleKeys, ...customTags];
    const qualities = formData.getAll('qualities') as string[];
    const images = (window as any).getCurrentImages ? (window as any).getCurrentImages() : [];

    const response = await fetch(`/api/admin/products/${id}`, {
      method: 'PUT',
      headers: {
        'content-type': 'application/json',
      },
      body: JSON.stringify({
        name,
        brand,
        collection_id,
        slug,
        price_range,
        description,
        features,
        qualities,
        images,
      }),
    });
    const result = await response.json().catch(() => ({ error: 'Onbekende fout.' }));

    if (!response.ok) {
      status.textContent = 'Fout bij opslaan: ' + result.error;
      status.className = 'text-sm font-light text-red-500 block mt-4';
    } else {
      status.textContent = 'Wijzigingen succesvol opgeslagen!';
      status.className = 'text-sm font-light text-green-600 block mt-4';
      setTimeout(() => {
        window.location.href = '/admin/producten';
      }, 1500);
    }
  });
</script>
