---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';

const { data: settings } = await supabase
  .from('site_settings')
  .select('*');

const settingsMap = Object.fromEntries(
  (settings || []).map(s => [s.key, s.value])
);
---

<Layout title="Instellingen | Mariage Control">
  <div class="pt-32 pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6 max-w-4xl">
      <nav class="mb-10 flex items-center gap-3 text-[10px] tracking-[0.2em] uppercase text-taupe font-body">
        <a href="/admin" class="hover:text-charcoal transition-colors">Dashboard</a>
        <span class="text-champagne">›</span>
        <span class="text-charcoal">Instellingen</span>
      </nav>

      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="text-[10px] tracking-[0.3em] uppercase text-blush-deep font-body mb-2">Configuratie</p>
          <h1 class="font-display font-normal text-charcoal text-4xl leading-tight">
            Site <em class="font-normal italic text-taupe">Instellingen</em>
          </h1>
        </div>
      </div>

      <div class="bg-white border border-champagne shadow-soft p-10">
        <form id="settings-form" class="space-y-12">
          
          <!-- BridalLive Section -->
          <div>
            <div class="flex items-center gap-4 mb-8 pb-4 border-b border-linen">
              <h2 class="text-2xl font-display text-charcoal">BridalLive <em class="italic font-light">Integratie</em></h2>
            </div>
            
            <div class="grid grid-cols-1 gap-8">
              <div class="space-y-2">
                <label for="bridallive_api_key" class="text-[10px] tracking-[0.2em] uppercase text-taupe block font-medium">BridalLive API Key</label>
                <input 
                  type="password" 
                  id="bridallive_api_key" 
                  name="bridallive_api_key" 
                  value={settingsMap.bridallive_api_key || ''} 
                  placeholder="Voer je API key in..."
                  class="w-full bg-ivory border border-champagne px-5 py-3 text-sm text-charcoal focus:border-blush-deep outline-none transition-colors"
                />
                <p class="text-[9px] text-taupe-light italic">Wordt gebruikt voor real-time synchronisatie van voorraad en afspraken.</p>
              </div>

              <div class="space-y-2">
                <label for="bridallive_embed_appointment" class="text-[10px] tracking-[0.2em] uppercase text-taupe block font-medium">Afspraakformulier Embed Code</label>
                <textarea 
                  id="bridallive_embed_appointment" 
                  name="bridallive_embed_appointment" 
                  rows="4"
                  placeholder="Plak hier de BridalLive script code..."
                  class="w-full bg-ivory border border-champagne px-5 py-3 text-sm text-charcoal focus:border-blush-deep outline-none transition-colors font-mono"
                >{settingsMap.bridallive_embed_appointment || ''}</textarea>
                <p class="text-[9px] text-taupe-light italic">Het script dat het afspraakformulier op de website toont.</p>
              </div>

              <div class="space-y-2">
                <label for="bridallive_embed_smartbook" class="text-[10px] tracking-[0.2em] uppercase text-taupe block font-medium">Smart Book Widget Code</label>
                <textarea 
                  id="bridallive_embed_smartbook" 
                  name="bridallive_embed_smartbook" 
                  rows="4"
                  placeholder="Plak hier de Smart Book widget code..."
                  class="w-full bg-ivory border border-champagne px-5 py-3 text-sm text-charcoal focus:border-blush-deep outline-none transition-colors font-mono"
                >{settingsMap.bridallive_embed_smartbook || ''}</textarea>
                <p class="text-[9px] text-taupe-light italic">Voor directe online boekingen via de Smart Book scheduler.</p>
              </div>
            </div>
          </div>

          <div class="pt-8 border-t border-linen flex justify-between items-center">
            <p id="status-message" class="text-xs font-body text-taupe italic"></p>
            <button 
              type="submit" 
              class="bg-charcoal text-warm-white px-10 py-4 text-[10px] tracking-[0.3em] uppercase hover:bg-taupe transition-all font-medium shadow-xl"
            >
              Instellingen opslaan
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('settings-form') as HTMLFormElement;
  const status = document.getElementById('status-message');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;

    status.textContent = 'Bezig met opslaan...';
    status.className = 'text-xs font-body text-taupe italic';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const response = await fetch('/api/admin/settings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (!response.ok) {
        const result = await response.json();
        throw new Error(result.error || 'Opslaan mislukt');
      }

      status.textContent = 'Instellingen succesvol bijgewerkt.';
      status.className = 'text-xs font-body text-green-600 italic';
    } catch (err: any) {
      status.textContent = `Fout: ${err.message}`;
      status.className = 'text-xs font-body text-red-600 italic';
    }
  });
</script>
