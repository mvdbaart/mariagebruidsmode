---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getServiceRoleClient } from '../../../lib/serverAuth';

// Parse ?week=YYYY-MM-DD or default to current week
const url = new URL(Astro.request.url);
const weekParam = url.searchParams.get('week');

function getMondayOfWeek(date: Date): Date {
  const d = new Date(date);
  const day = d.getDay();
  const diff = day === 0 ? -6 : 1 - day;
  d.setDate(d.getDate() + diff);
  d.setHours(0, 0, 0, 0);
  return d;
}

let monday: Date;
if (weekParam) {
  const parsed = new Date(weekParam + 'T00:00:00');
  monday = isNaN(parsed.getTime()) ? getMondayOfWeek(new Date()) : getMondayOfWeek(parsed);
} else {
  monday = getMondayOfWeek(new Date());
}

// Build 7-day week (Mon–Sun)
const weekDays: Date[] = Array.from({ length: 7 }, (_, i) => {
  const d = new Date(monday);
  d.setDate(monday.getDate() + i);
  return d;
});

const weekStart = monday.toISOString().split('T')[0];
const sunday = weekDays[6];
const weekEnd = sunday.toISOString().split('T')[0];

const prevMonday = new Date(monday);
prevMonday.setDate(monday.getDate() - 7);
const nextMonday = new Date(monday);
nextMonday.setDate(monday.getDate() + 7);
const prevParam = prevMonday.toISOString().split('T')[0];
const nextParam = nextMonday.toISOString().split('T')[0];

const supabase = getServiceRoleClient();

const [{ data: appointments }, { data: openExceptions }] = await Promise.all([
  supabase
    .from('appointments')
    .select('id, full_name, preferred_date, start_time, end_time, appointment_type, status, employees(first_name, last_name)')
    .gte('preferred_date', weekStart)
    .lte('preferred_date', weekEnd)
    .in('status', ['pending', 'confirmed'])
    .order('start_time', { ascending: true }),
  supabase
    .from('opening_exceptions')
    .select('date')
    .gte('date', weekStart)
    .lte('date', weekEnd),
]);

const openSundayDates = new Set((openExceptions || []).map((e) => e.date));

// Time grid: 09:00 – 18:00 = 540 minutes = 540px (1px per minute)
const GRID_START = 9 * 60;
const GRID_END = 18 * 60;
const GRID_MINUTES = GRID_END - GRID_START; // 540
const GRID_HEIGHT_PX = 540;

function timeToMinutes(t: string | null | undefined): number {
  if (!t) return -1;
  const [h, m] = t.split(':').map(Number);
  return h * 60 + (m || 0);
}

function topPx(time: string | null): number {
  const mins = timeToMinutes(time);
  if (mins < 0) return 0;
  return Math.max(0, mins - GRID_START);
}

function heightPx(start: string | null, end: string | null): number {
  const s = timeToMinutes(start);
  const e = timeToMinutes(end);
  if (s < 0) return 56;
  if (e < 0) return 120;
  return Math.max(40, e - s);
}

// 2-hour block definitions (must match availability.ts)
const WEEKDAY_BLOCKS = [
  { start: '10:00', end: '12:00', label: '10:00 – 12:00' },
  { start: '13:00', end: '15:00', label: '13:00 – 15:00' },
  { start: '15:30', end: '17:30', label: '15:30 – 17:30' },
];
const WEEKEND_BLOCKS = [
  { start: '09:30', end: '11:30', label: '09:30 – 11:30' },
  { start: '12:00', end: '14:00', label: '12:00 – 14:00' },
  { start: '14:30', end: '16:30', label: '14:30 – 16:30' },
];

const today = new Date().toISOString().split('T')[0];
const dayNames = ['Ma', 'Di', 'Wo', 'Do', 'Vr', 'Za', 'Zo'];
const hours = Array.from({ length: 10 }, (_, i) => i + 9); // 9–18

const statusColor: Record<string, string> = {
  pending: 'bg-amber-100 border-amber-400 text-amber-900',
  confirmed: 'bg-green-100 border-green-400 text-green-900',
};
---

<AdminLayout title="Afspraken Kalender">
  <div class="pt-8 pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6">
      <div class="flex flex-wrap justify-between items-center mb-8 gap-4">
        <h1 class="font-display font-normal text-charcoal text-3xl italic">Afspraken <span class="text-blush-deep opacity-60">Kalender</span></h1>
        <div class="flex gap-3 items-center">
          <a href="/admin/afspraken" class="text-[10px] uppercase tracking-widest text-taupe hover:text-blush-deep transition-colors border border-champagne px-4 py-2">Lijstweergave</a>
          <a href="/admin" class="text-[10px] uppercase tracking-widest text-taupe hover:text-blush-deep transition-colors">← Dashboard</a>
        </div>
      </div>

      <!-- Week navigation -->
      <div class="flex items-center justify-between mb-6">
        <a href={`/admin/afspraken/kalender?week=${prevParam}`} class="text-[10px] uppercase tracking-widest text-taupe hover:text-charcoal transition-colors px-4 py-2 border border-champagne">← Vorige week</a>
        <p class="font-body text-sm text-charcoal">
          {monday.toLocaleDateString('nl-NL', { day: 'numeric', month: 'long' })} – {sunday.toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' })}
        </p>
        <a href={`/admin/afspraken/kalender?week=${nextParam}`} class="text-[10px] uppercase tracking-widest text-taupe hover:text-charcoal transition-colors px-4 py-2 border border-champagne">Volgende week →</a>
      </div>

      <!-- Calendar grid -->
      <div class="bg-white border border-champagne shadow-soft overflow-auto">
        <div class="min-w-[900px]">

          <!-- Day header row -->
          <div class="grid border-b border-champagne" style="grid-template-columns: 52px repeat(7, 1fr);">
            <div class="border-r border-champagne"></div>
            {weekDays.map((day, i) => {
              const dateStr = day.toISOString().split('T')[0];
              const isToday = dateStr === today;
              const isMon = i === 0;
              const isSun = i === 6;
              const isSunOpen = isSun && openSundayDates.has(dateStr);
              return (
                <div class={`px-2 py-3 text-center border-r border-champagne last:border-r-0 ${isToday ? 'bg-blush/10' : isMon ? 'bg-gray-50' : ''}`}>
                  <p class={`text-[10px] uppercase tracking-widest font-body ${isToday ? 'text-blush-deep' : isMon ? 'text-gray-400' : 'text-taupe'}`}>{dayNames[i]}</p>
                  <p class={`text-sm font-body font-medium mt-0.5 ${isToday ? 'text-charcoal' : isMon ? 'text-gray-400' : 'text-taupe'}`}>{day.getDate()}</p>
                  {isMon && <span class="text-[8px] uppercase tracking-wider text-gray-400 font-body">Gesloten</span>}
                  {isSun && !isSunOpen && (
                    <button
                      class="toggle-sunday mt-1 text-[8px] uppercase tracking-wider text-blush-deep hover:text-charcoal font-body border border-blush/30 px-2 py-0.5 transition-colors"
                      data-date={dateStr}
                      data-action="open"
                      title="Zondag openstellen voor afspraken"
                    >+ Openstellen</button>
                  )}
                  {isSun && isSunOpen && (
                    <div class="flex flex-col items-center gap-0.5 mt-1">
                      <span class="text-[8px] uppercase tracking-wider text-green-600 font-body">Op afspraak</span>
                      <button
                        class="toggle-sunday text-[8px] uppercase tracking-wider text-gray-400 hover:text-red-600 font-body transition-colors"
                        data-date={dateStr}
                        data-action="close"
                        title="Zondag sluiten"
                      >× Sluiten</button>
                    </div>
                  )}
                </div>
              );
            })}
          </div>

          <!-- Time grid body -->
          <div class="grid relative" style={`grid-template-columns: 52px repeat(7, 1fr); height: ${GRID_HEIGHT_PX}px;`}>

            <!-- Left time column -->
            <div class="relative border-r border-champagne">
              {hours.map(h => (
                <div
                  class="absolute w-full text-right pr-2"
                  style={`top: calc(${((h - 9) / 9) * 100}% - 8px)`}
                >
                  <span class="text-[9px] text-taupe-light font-body">{String(h).padStart(2, '0')}:00</span>
                </div>
              ))}
            </div>

            <!-- Day columns -->
            {weekDays.map((day, colIdx) => {
              const dateStr = day.toISOString().split('T')[0];
              const isToday = dateStr === today;
              const isMon = colIdx === 0;
              const isSun = colIdx === 6;
              const isSunOpen = isSun && openSundayDates.has(dateStr);
              const isOpen = !isMon && (!isSun || isSunOpen);
              const dayApps = (appointments || []).filter(a => a.preferred_date === dateStr);
              const blocks = (isSun || colIdx === 5) ? WEEKEND_BLOCKS : WEEKDAY_BLOCKS;
              const bookedStartTimes = new Set(dayApps.map(a => a.start_time?.slice(0, 5)));

              return (
                <div class={`relative border-r border-champagne last:border-r-0 ${isToday ? 'bg-blush/5' : isMon ? 'bg-gray-50/60' : ''}`}>

                  {/* Hour grid lines */}
                  {hours.map(h => (
                    <div
                      class="absolute w-full border-t border-champagne/50"
                      style={`top: ${((h - 9) / 9) * 100}%`}
                    ></div>
                  ))}

                  {/* Closed day overlay */}
                  {!isOpen && (
                    <div class="absolute inset-0 flex items-center justify-center pointer-events-none" style="background: repeating-linear-gradient(45deg, transparent, transparent 8px, rgba(0,0,0,0.02) 8px, rgba(0,0,0,0.02) 16px);">
                      {isSun && !isSunOpen && (
                        <span class="text-[8px] uppercase tracking-widest text-gray-300 font-body rotate-[-30deg] select-none">Op aanvraag</span>
                      )}
                    </div>
                  )}

                  {/* Empty block outlines for open days */}
                  {isOpen && blocks.map(block => {
                    const isBooked = bookedStartTimes.has(block.start);
                    if (isBooked) return null; // booked blocks shown as appointment cards
                    const top = topPx(block.start);
                    const height = heightPx(block.start, block.end);
                    return (
                      <div
                        class="absolute left-1 right-1 border border-dashed border-champagne rounded-sm"
                        style={`top: ${top}px; height: ${height}px;`}
                        title={`${block.label} — vrij`}
                      >
                        <span class="absolute top-1 left-1.5 text-[8px] text-taupe-light/70 font-body">{block.start}</span>
                      </div>
                    );
                  })}

                  {/* Appointment blocks */}
                  {dayApps.map(app => {
                    const top = topPx(app.start_time);
                    const height = heightPx(app.start_time, app.end_time);
                    const color = statusColor[app.status] || statusColor.pending;
                    const employee = app.employees as { first_name: string; last_name: string } | null;
                    return (
                      <a
                        href={`/admin/afspraken/${app.id}`}
                        class={`absolute left-1 right-1 rounded-sm border-l-2 px-2 py-1 overflow-hidden hover:opacity-90 transition-opacity ${color}`}
                        style={`top: ${top}px; height: ${height}px;`}
                        title={`${app.full_name} — ${app.start_time?.slice(0, 5) ?? ''}`}
                      >
                        <p class="text-[10px] font-body font-medium leading-tight truncate">{app.full_name}</p>
                        {app.start_time && (
                          <p class="text-[9px] font-body opacity-70">{app.start_time.slice(0, 5)} – {app.end_time?.slice(0, 5) ?? ''}</p>
                        )}
                        {employee && (
                          <p class="text-[8px] font-body opacity-60 truncate">{employee.first_name}</p>
                        )}
                        <span class={`text-[8px] font-body px-1 inline-block mt-0.5 ${app.appointment_type === 'vip' ? 'bg-gold/30' : 'bg-champagne/60'}`}>
                          {app.appointment_type === 'vip' ? 'VIP' : app.appointment_type === 'standard_bride' ? 'Bruid' : app.appointment_type === 'standard_groom' ? 'Bruidegom' : 'Std'}
                        </span>
                      </a>
                    );
                  })}
                </div>
              );
            })}
          </div>
        </div>
      </div>

      <!-- Legend -->
      <div class="flex flex-wrap gap-6 mt-4">
        <div class="flex items-center gap-2">
          <span class="inline-block w-3 h-3 rounded-sm bg-amber-200 border-l-2 border-amber-400"></span>
          <span class="text-[10px] uppercase tracking-widest text-taupe font-body">In afwachting</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="inline-block w-3 h-3 rounded-sm bg-green-200 border-l-2 border-green-400"></span>
          <span class="text-[10px] uppercase tracking-widest text-taupe font-body">Bevestigd</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="inline-block w-4 h-3 border border-dashed border-champagne rounded-sm"></span>
          <span class="text-[10px] uppercase tracking-widest text-taupe font-body">Vrij tijdblok</span>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.toggle-sunday').forEach(btn => {
    btn.addEventListener('click', async () => {
      const date = btn.dataset.date;
      const action = btn.dataset.action;
      if (!date) return;

      btn.disabled = true;
      btn.textContent = action === 'open' ? 'Bezig…' : 'Bezig…';

      try {
        const res = await fetch('/api/admin/opening-exceptions', {
          method: action === 'open' ? 'POST' : 'DELETE',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ date }),
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json().catch(() => ({}));
          alert(data.error || 'Actie mislukt.');
          btn.disabled = false;
          btn.textContent = action === 'open' ? '+ Openstellen' : '× Sluiten';
        }
      } catch {
        alert('Netwerkfout.');
        btn.disabled = false;
      }
    });
  });
</script>
