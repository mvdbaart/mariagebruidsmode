---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';

const { data: collections } = await supabase
  .from('collections')
  .select('*')
  .order('type', { ascending: true });
---

<Layout title="Beheer Collecties">
  <div class="pt-32 pb-24 bg-accent/5 min-h-screen">
    <div class="container mx-auto px-6">
      <nav class="mb-12 flex items-center gap-4 text-[10px] tracking-[0.2em] uppercase text-accent/40">
        <a href="/admin" class="hover:text-secondary">Dashboard</a>
        <span>/</span>
        <span class="text-secondary text-secondary">Beheer Collecties</span>
      </nav>

      <div class="flex items-center justify-between mb-12">
        <h1 class="text-4xl font-serif text-accent italic">Beheer <span class="text-secondary opacity-50">Collecties</span></h1>
        <button class="bg-accent text-white px-6 py-2 text-xs tracking-widest uppercase hover:opacity-80 transition-all font-medium">Nieuwe Collectie</button>
      </div>

      <div class="bg-white border border-secondary/10 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
        <table class="w-full min-w-[760px] text-left">
          <thead>
            <tr class="bg-primary/50 text-[10px] tracking-widest uppercase text-accent/60 border-b border-secondary/10">
              <th class="px-6 py-4 font-medium whitespace-nowrap">Titel</th>
              <th class="px-6 py-4 font-medium whitespace-nowrap">Type</th>
              <th class="px-6 py-4 font-medium whitespace-nowrap">Slug</th>
              <th class="px-6 py-4 font-medium text-right whitespace-nowrap">Acties</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-secondary/5 text-sm font-light text-accent">
            {collections?.map((col) => (
              <tr class="hover:bg-primary/20 transition-colors">
                <td class="px-6 py-4 font-medium uppercase tracking-wide whitespace-nowrap">{col.title}</td>
                <td class="px-6 py-4 italic whitespace-nowrap">{col.type === 'dress' ? 'Jurken' : 'Pakken'}</td>
                <td class="px-6 py-4 text-accent/40 whitespace-nowrap">{col.slug}</td>
                <td class="px-6 py-4 text-right">
                  <div class="flex justify-end gap-4 uppercase text-[11px] tracking-[0.12em] font-medium whitespace-nowrap">
                    <a href={`/admin/collection/${col.id}/edit`} class="text-secondary hover:underline">Aanpassen</a>
                    <button class="text-red-400 hover:underline">Verwijderen</button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
        </div>
        {!collections?.length && <p class="p-12 text-center text-accent/40 italic">Geen collecties gevonden.</p>}
      </div>
    </div>
  </div>
</Layout>
