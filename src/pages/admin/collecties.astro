---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

const { data: collections } = await supabase
  .from('collections')
  .select('*')
  .order('type', { ascending: true });
---

<AdminLayout title="Beheer Collecties">
  <div class="pt-8 pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6">
      <nav class="mb-12 flex items-center gap-4 text-[10px] tracking-[0.2em] uppercase font-body text-taupe">
        <a href="/admin" class="hover:text-charcoal transition-colors">Dashboard</a>
        <span class="text-champagne">›</span>
        <span class="text-charcoal font-medium">Beheer Collecties</span>
      </nav>

      <div class="flex items-center justify-between mb-12">
        <h1 class="font-display font-normal text-charcoal text-4xl italic">Beheer <span class="font-signature text-blush-deep text-5xl lowercase px-2">Collecties</span></h1>
        <button class="btn-blush py-3 px-8 text-[11px] tracking-[0.2em] uppercase">Nieuwe Collectie</button>
      </div>

      <div class="bg-white border border-champagne shadow-soft overflow-hidden rounded-2xl">
        <div class="overflow-x-auto">
        <table class="w-full min-w-[760px] text-left border-collapse">
          <thead>
            <tr class="bg-linen/50 text-[10px] tracking-[0.2em] uppercase text-charcoal border-b border-champagne">
              <th class="px-6 py-5 font-medium">Titel</th>
              <th class="px-6 py-5 font-medium">Type</th>
              <th class="px-6 py-5 font-medium">Slug</th>
              <th class="px-6 py-5 font-medium text-right">Acties</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-champagne text-sm text-charcoal font-body">
            {collections?.map((col) => (
              <tr class="hover:bg-ivory/50 transition-colors">
                <td class="px-6 py-5 font-medium uppercase tracking-wider">
                  <a href={`/admin/producten?collectionId=${col.id}`} class="hover:text-blush-deep transition-colors">
                    {col.title}
                  </a>
                </td>
                <td class="px-6 py-5 text-taupe">{col.type === 'dress' ? 'Jurken' : 'Pakken'}</td>
                <td class="px-6 py-5 text-taupe-light font-light">{col.slug}</td>
                <td class="px-6 py-5 text-right">
                  <div class="flex justify-end gap-5 uppercase text-[10px] tracking-[0.15em] font-medium whitespace-nowrap">
                    <a href={`/admin/producten?collectionId=${col.id}`} class="text-charcoal hover:text-blush-deep hover:underline transition-colors font-bold">Bekijken</a>
                    <a href={`/admin/collection/${col.id}/edit`} class="text-blush-deep hover:text-charcoal hover:underline transition-colors">Aanpassen</a>
                    <button class="text-red-700 hover:text-red-900 transition-colors">Verwijderen</button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
        </div>
        {!collections?.length && <p class="p-16 text-center text-taupe font-italic italic">Geen collecties gevonden.</p>}
      </div>
    </div>
  </div>
</AdminLayout>
