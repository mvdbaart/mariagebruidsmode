---
import Layout from '../../../layouts/Layout.astro';
import { getAdminAuthFromCookies, getServiceRoleClient } from '../../../lib/serverAuth';

interface Employee {
  id: string;
  first_name: string;
  last_name: string;
  role?: string;
  email?: string;
  contract_hours: number;
  is_active: boolean;
}

const adminAuth = await getAdminAuthFromCookies(Astro.cookies);
if (!adminAuth) {
  return Astro.redirect('/admin/login');
}

const supabase = getServiceRoleClient();
const { data: employees, error } = await supabase
  .from('employees')
  .select('*')
  .order('first_name', { ascending: true });
---

<Layout title="Medewerkers - Admin">
  <main class="min-h-screen bg-primary py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-4">
          <a href="/admin" class="text-[10px] uppercase tracking-widest text-accent/60 hover:text-accent transition-colors flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
            Dashboard
          </a>
          <h1 class="text-3xl font-serif text-accent">Planning & Personeel</h1>
        </div>
        <button id="add-employee-btn" class="px-6 py-2 bg-secondary text-white text-[10px] uppercase tracking-widest rounded hover:bg-accent transition-all">
          Medewerker Toevoegen
        </button>
      </div>

      <div class="flex gap-8 mb-12 border-b border-accent/10">
          <a href="/admin/planner/medewerkers" class="pb-4 text-[10px] uppercase tracking-widest font-bold border-b-2 border-secondary text-secondary">Medewerkers</a>
          <a href="/admin/planner/kalender" class="pb-4 text-[10px] uppercase tracking-widest text-accent/40 hover:text-accent transition-colors">Weekrooster</a>
          <a href="/admin/planner/uren" class="pb-4 text-[10px] uppercase tracking-widest text-accent/40 hover:text-accent transition-colors">Urenregistratie</a>
          <a href="/admin/planner/verlof" class="pb-4 text-[10px] uppercase tracking-widest text-accent/40 hover:text-accent transition-colors">Verlof & Ziekte</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {employees?.map((emp: Employee) => (
          <div class="bg-white/50 backdrop-blur-sm border border-accent/10 p-6 rounded-lg shadow-sm hover:shadow-md transition-all group">
            <div class="flex justify-between items-start mb-4">
              <div>
                <h3 class="text-lg font-serif text-accent">{emp.first_name} {emp.last_name}</h3>
                <p class="text-[10px] uppercase tracking-widest text-secondary font-medium">{emp.role || 'Gén functie'}</p>
              </div>
              <span class={`w-2 h-2 rounded-full ${emp.is_active ? 'bg-green-400' : 'bg-red-400'}`}></span>
            </div>
            
            <div class="space-y-2 mb-6">
              <div class="flex items-center gap-2 text-xs text-accent/60">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                {emp.email || 'Geen e-mail'}
              </div>
              <div class="flex items-center gap-2 text-xs text-accent/60">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                {emp.contract_hours} uur p/w
              </div>
            </div>

            <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
              <button class="flex-1 py-1.5 border border-accent/10 text-[10px] uppercase tracking-widest text-accent hover:bg-accent hover:text-white transition-all rounded">Beherr</button>
              <button class="flex-1 py-1.5 border border-secondary/20 text-[10px] uppercase tracking-widest text-secondary hover:bg-secondary hover:text-white transition-all rounded">Planning</button>
            </div>
          </div>
        ))}
      </div>

      {employees?.length === 0 && (
        <div class="text-center py-20 bg-white/30 rounded-lg border border-dashed border-accent/20">
          <p class="text-accent/60 font-serif italic">Nog geen medewerkers toegevoegd.</p>
        </div>
      )}
    </div>

    <!-- Add Employee Modal -->
    <div id="add-modal" class="fixed inset-0 bg-accent/40 backdrop-blur-sm hidden z-50 flex items-center justify-center p-4">
      <div class="bg-primary w-full max-w-md p-8 rounded-lg shadow-xl border border-accent/10">
        <h2 class="text-2xl font-serif text-accent mb-6">Nieuwe Medewerker</h2>
        <form id="add-employee-form" class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] uppercase tracking-widest text-accent/60 mb-1">Voornaam</label>
              <input type="text" name="first_name" required class="w-full bg-white border border-accent/10 px-3 py-2 text-sm focus:border-secondary transition-colors outline-none" />
            </div>
            <div>
              <label class="block text-[10px] uppercase tracking-widest text-accent/60 mb-1">Achternaam</label>
              <input type="text" name="last_name" required class="w-full bg-white border border-accent/10 px-3 py-2 text-sm focus:border-secondary transition-colors outline-none" />
            </div>
          </div>
          <div>
            <label class="block text-[10px] uppercase tracking-widest text-accent/60 mb-1">E-mail</label>
            <input type="email" name="email" class="w-full bg-white border border-accent/10 px-3 py-2 text-sm focus:border-secondary transition-colors outline-none" />
          </div>
          <div>
            <label class="block text-[10px] uppercase tracking-widest text-accent/60 mb-1">Rol / Functie</label>
            <input type="text" name="role" placeholder="bijv. Verkoopadviseur" class="w-full bg-white border border-accent/10 px-3 py-2 text-sm focus:border-secondary transition-colors outline-none" />
          </div>
          <div>
            <label class="block text-[10px] uppercase tracking-widest text-accent/60 mb-1">Contracturen per week</label>
            <input type="number" name="contract_hours" value="40" class="w-full bg-white border border-accent/10 px-3 py-2 text-sm focus:border-secondary transition-colors outline-none" />
          </div>
          <div class="flex gap-4 mt-8">
            <button type="button" id="close-modal" class="flex-1 py-3 text-[10px] uppercase tracking-widest text-accent/60 hover:text-accent transition-colors">Annuleren</button>
            <button type="submit" class="flex-2 bg-accent text-white px-8 py-3 text-[10px] uppercase tracking-widest hover:bg-secondary transition-all rounded">Opslaan</button>
          </div>
        </form>
      </div>
    </div>
  </main>
</Layout>

<script>
  const modal = document.getElementById('add-modal');
  const addBtn = document.getElementById('add-employee-btn');
  const closeBtn = document.getElementById('close-modal');
  const form = document.getElementById('add-employee-form') as HTMLFormElement;

  addBtn?.addEventListener('click', () => modal?.classList.remove('hidden'));
  closeBtn?.addEventListener('click', () => modal?.classList.add('hidden'));

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const resp = await fetch('/api/admin/employees', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      if (resp.ok) {
        window.location.reload();
      } else {
        const err = await resp.json();
        alert('Fout: ' + err.error);
      }
    } catch (err) {
      alert('Er is een fout opgetreden.');
    }
  });
</script>
