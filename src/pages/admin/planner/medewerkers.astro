---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getAdminAuthFromCookies, getServiceRoleClient, getUserRole } from '../../../lib/serverAuth';

const adminAuth = await getAdminAuthFromCookies(Astro.cookies);
if (!adminAuth) {
  return Astro.redirect('/admin/login');
}

const { user } = adminAuth;
const userRole = await getUserRole(user.id);
const adminEmails = (import.meta.env.ADMIN_EMAILS ?? '').split(',').map((e: string) => e.trim().toLowerCase());
const canSeeRate = adminEmails.includes(user.email?.toLowerCase() ?? '') || userRole === 'admin';

const supabase = getServiceRoleClient();
const { data: employees } = await supabase
  .from('employees')
  .select('*')
  .order('team_sort_order', { ascending: true, nullsFirst: true })
  .order('first_name', { ascending: true });

interface ScheduleDay {
  active: boolean;
  start?: string;
  end?: string;
}
interface ContractSchedule {
  mon?: ScheduleDay;
  tue?: ScheduleDay;
  wed?: ScheduleDay;
  thu?: ScheduleDay;
  fri?: ScheduleDay;
  sat?: ScheduleDay;
  sun?: ScheduleDay;
}
interface Employee {
  id: string;
  first_name: string;
  last_name: string;
  role?: string;
  email?: string;
  bio?: string;
  specialisms?: string[];
  profile_photo_url?: string;
  contract_hours: number;
  hourly_rate?: number;
  sort_order?: number;
  show_on_team?: boolean;
  team_sort_order?: number;
  is_active: boolean;
  contract_schedule?: ContractSchedule;
}

const SCHEDULE_DAYS = [
  { key: 'mon', label: 'Maandag' },
  { key: 'tue', label: 'Dinsdag' },
  { key: 'wed', label: 'Woensdag' },
  { key: 'thu', label: 'Donderdag' },
  { key: 'fri', label: 'Vrijdag' },
  { key: 'sat', label: 'Zaterdag' },
  { key: 'sun', label: 'Zondag' },
] as const;

const inputClass = "w-full bg-white border border-champagne px-3 py-2 text-sm text-charcoal focus:border-blush-deep focus:ring-1 focus:ring-blush-deep/20 transition-colors outline-none rounded-lg";
const labelClass = "block text-xs uppercase tracking-[0.15em] text-taupe font-medium mb-1";
---

<AdminLayout title="Medewerkers">
  <div class="min-h-screen py-8 px-6">
    <div class="max-w-6xl mx-auto">

      <!-- Page header -->
      <div class="flex items-center justify-between mb-8">
        <div>
          <a href="/admin" class="text-[10px] uppercase tracking-widest text-taupe hover:text-charcoal transition-colors flex items-center gap-1.5 mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
            Dashboard
          </a>
          <h1 class="admin-heading text-3xl text-charcoal">Planning & Personeel</h1>
        </div>
        <button id="add-employee-btn" class="btn-premium">
          + Medewerker Toevoegen
        </button>
      </div>

      <div class="mb-6 rounded-2xl border border-champagne bg-ivory px-4 py-3 text-sm text-taupe">
        Sleep de kaarten om de volgorde op <span class="text-charcoal font-medium">Ons Team</span> en de homepage te bepalen.
      </div>

      <!-- Tab navigatie -->
      <div class="flex gap-6 mb-10 border-b border-champagne">
        <a href="/admin/planner/medewerkers" class="pb-3 text-[10px] uppercase tracking-[0.2em] border-b-2 border-blush-deep text-blush-deep font-medium -mb-px">Medewerkers</a>
        <a href="/admin/planner/kalender" class="pb-3 text-[10px] uppercase tracking-[0.2em] text-taupe hover:text-charcoal transition-colors">Weekrooster</a>
        <a href="/admin/planner/uren" class="pb-3 text-[10px] uppercase tracking-[0.2em] text-taupe hover:text-charcoal transition-colors">Urenregistratie</a>
        <a href="/admin/planner/verlof" class="pb-3 text-[10px] uppercase tracking-[0.2em] text-taupe hover:text-charcoal transition-colors">Verlof & Ziekte</a>
      </div>

      <!-- Medewerker kaarten -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-employee-grid>
        {(employees as Employee[] | null)?.map((emp) => (
          <div class="bg-white border border-champagne shadow-soft rounded-2xl p-6 flex flex-col relative" draggable="true" data-employee-card data-employee-id={emp.id}>

            <button
              type="button"
              class="drag-handle absolute top-4 right-4 inline-flex items-center gap-2 rounded-full border border-champagne bg-white px-3 py-1 text-[9px] uppercase tracking-[0.2em] text-taupe hover:text-charcoal hover:border-charcoal transition-colors cursor-grab active:cursor-grabbing"
              aria-label={`Sleep ${emp.first_name} ${emp.last_name} om de volgorde te wijzigen`}
              data-drag-handle
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M9 5h.01M15 5h.01M9 12h.01M15 12h.01M9 19h.01M15 19h.01" />
              </svg>
              Sleep
            </button>

            <!-- Kaart header -->
            <div class="flex items-start justify-between mb-4 pr-16">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-full overflow-hidden bg-linen flex items-center justify-center shrink-0">
                  {emp.profile_photo_url
                    ? <img src={emp.profile_photo_url} alt={`${emp.first_name} ${emp.last_name}`} onerror="this.onerror=null;this.src='/images/logo/Social-Media-profielfoto.jpg'" class="w-full h-full object-cover" />
                    : <span class="text-sm font-display text-taupe">{emp.first_name.charAt(0)}{emp.last_name.charAt(0)}</span>
                  }
                </div>
                <div>
                  <h3 class="font-display text-charcoal text-lg leading-tight">{emp.first_name} {emp.last_name}</h3>
                  <p class="ds-eyebrow mt-0.5">{emp.role || 'Geen functie'}</p>
                </div>
              </div>
              <span class={`text-[9px] uppercase tracking-[0.12em] px-2.5 py-1 rounded-full font-medium shrink-0 ml-2 ${emp.is_active ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-500'}`}>
                {emp.is_active ? 'Actief' : 'Inactief'}
              </span>
            </div>

            <!-- Bio -->
            {emp.bio && (
              <p class="text-xs text-taupe italic mb-4 line-clamp-2">{emp.bio}</p>
            )}

            <!-- Specialisme tags -->
            {emp.specialisms && emp.specialisms.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mb-4">
                {emp.specialisms.map((specialism) => (
                  <span class="text-[9px] uppercase tracking-[0.12em] px-2.5 py-1 bg-linen text-taupe border border-champagne rounded-full">
                    {specialism}
                  </span>
                ))}
              </div>
            )}

            <!-- Details -->
            <div class="space-y-1.5 text-xs text-taupe flex-1 mb-5">
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 shrink-0 text-blush-deep" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                <span class="truncate">{emp.email || 'Geen e-mail'}</span>
              </div>
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 shrink-0 text-blush-deep" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span>{emp.contract_hours} uur p/w</span>
              </div>
              {/* Contractrooster samenvatting */}
              {emp.contract_schedule && Object.values(emp.contract_schedule).some((d: any) => d?.active) && (
                <div class="flex items-start gap-2 pt-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 shrink-0 text-blush-deep mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                  <div class="flex flex-wrap gap-1">
                    {SCHEDULE_DAYS.filter(d => (emp.contract_schedule as any)?.[d.key]?.active).map(d => {
                      const day = (emp.contract_schedule as any)[d.key];
                      return (
                        <span class="inline-flex items-center gap-1 text-[9px] bg-linen border border-champagne rounded px-1.5 py-0.5 font-medium text-charcoal">
                          <span class="text-blush-deep">{d.label.slice(0, 2)}</span>
                          {day.start && day.end && <span class="text-taupe">{day.start}–{day.end}</span>}
                        </span>
                      );
                    })}
                  </div>
                </div>
              )}
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 shrink-0 text-blush-deep" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span>{emp.show_on_team ? `Zichtbaar op Ons Team (#${emp.team_sort_order ?? 0})` : 'Niet zichtbaar op Ons Team'}</span>
              </div>
              {canSeeRate && emp.hourly_rate != null && (
                <div class="flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 shrink-0 text-blush-deep" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  <span>€{Number(emp.hourly_rate).toFixed(2)} p/u</span>
                </div>
              )}
            </div>

            <!-- Acties — altijd zichtbaar -->
            <div class="flex gap-2 pt-4 border-t border-champagne">
              <button
                class="flex-1 py-2 text-[10px] uppercase tracking-[0.15em] font-medium text-charcoal border border-champagne rounded-lg hover:bg-charcoal hover:text-ivory hover:border-charcoal transition-all edit-btn"
                data-employee={JSON.stringify(emp)}
              >Bewerken</button>
              <button
                class="py-2 px-3 text-[10px] text-red-400 border border-red-200 rounded-lg hover:bg-red-500 hover:text-white hover:border-red-500 transition-all delete-btn"
                data-id={emp.id}
                data-name={`${emp.first_name} ${emp.last_name}`}
              >✕</button>
            </div>
          </div>
        ))}
      </div>

      <!-- Leeg-state -->
      {(!employees || employees.length === 0) && (
        <div class="text-center py-20 bg-white border border-dashed border-champagne rounded-2xl">
          <p class="font-display italic text-taupe">Nog geen medewerkers toegevoegd.</p>
        </div>
      )}
    </div>

    <!-- ── Add Employee Modal ─────────────────────────────────── -->
    <div id="add-modal" class="fixed inset-0 bg-charcoal/40 backdrop-blur-sm hidden z-50 flex items-center justify-center p-4">
      <div class="bg-white border border-champagne shadow-card rounded-2xl w-full max-w-lg p-8 max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between mb-6">
          <h2 class="font-display text-charcoal text-2xl italic">Nieuwe Medewerker</h2>
          <button type="button" id="close-add-modal" class="text-taupe hover:text-charcoal transition-colors" aria-label="Sluiten">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
          </button>
        </div>
        <form id="add-employee-form" class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class={labelClass}>Voornaam *</label>
              <input type="text" name="first_name" required class={inputClass} />
            </div>
            <div>
              <label class={labelClass}>Achternaam *</label>
              <input type="text" name="last_name" required class={inputClass} />
            </div>
          </div>
          <div>
            <label class={labelClass}>E-mail</label>
            <input type="email" name="email" class={inputClass} />
          </div>
          <div>
            <label class={labelClass}>Rol / Functie</label>
            <input type="text" name="role" placeholder="bijv. Verkoopadviseur" class={inputClass} />
          </div>
          <div>
            <label class={labelClass}>Bio</label>
            <textarea name="bio" rows="3" class={`${inputClass} resize-none`} placeholder="Korte beschrijving..."></textarea>
          </div>
          <div>
            <label class={labelClass}>Specialismes</label>
            <textarea name="specialisms" rows="3" class={`${inputClass} resize-none`} placeholder="Eén specialisme per regel of komma-gescheiden"></textarea>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class={labelClass}>Contracturen p/w</label>
              <input type="number" name="contract_hours" value="40" step="0.5" min="0" class={inputClass} />
            </div>
            {canSeeRate && (
              <div>
                <label class={labelClass}>Uurtarief (€)</label>
                <input type="number" name="hourly_rate" step="0.01" min="0" placeholder="0.00" class={inputClass} />
              </div>
            )}
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class={labelClass}>Volgorde</label>
              <input type="number" name="sort_order" value="0" step="1" class={inputClass} />
            </div>
            <div>
              <label class={labelClass}>Team volgorde</label>
              <input type="number" name="team_sort_order" value="0" step="1" class={inputClass} />
            </div>
          </div>
          <!-- Contractrooster -->
          <div class="pt-2">
            <label class={labelClass}>Contractrooster</label>
            <div class="space-y-1.5 mt-2 p-4 bg-linen border border-champagne rounded-xl">
              {SCHEDULE_DAYS.map(({ key, label }) => (
                <div class="flex items-center gap-3">
                  <input
                    type="checkbox"
                    id={`add-sched-${key}-active`}
                    name={`sched_${key}_active`}
                    class="w-4 h-4 accent-blush-deep sched-toggle"
                    data-prefix={`add-sched-${key}`}
                  />
                  <span class="text-xs font-medium text-charcoal w-24 shrink-0">{label}</span>
                  <input
                    type="time"
                    id={`add-sched-${key}-start`}
                    name={`sched_${key}_start`}
                    value="09:00"
                    disabled
                    class="w-24 bg-white border border-champagne px-2 py-1 text-xs text-charcoal focus:border-blush-deep outline-none rounded-lg disabled:opacity-30 disabled:cursor-not-allowed"
                  />
                  <span class="text-taupe text-xs">–</span>
                  <input
                    type="time"
                    id={`add-sched-${key}-end`}
                    name={`sched_${key}_end`}
                    value="17:00"
                    disabled
                    class="w-24 bg-white border border-champagne px-2 py-1 text-xs text-charcoal focus:border-blush-deep outline-none rounded-lg disabled:opacity-30 disabled:cursor-not-allowed"
                  />
                </div>
              ))}
            </div>
          </div>

          <div class="flex flex-col gap-3 pt-2">
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" name="is_active" id="add-is-active" checked class="w-4 h-4 accent-blush-deep" />
              <span class="text-sm text-charcoal">Actief</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" name="show_on_team" id="add-show-on-team" class="w-4 h-4 accent-blush-deep" />
              <span class="text-sm text-charcoal">Tonen op Ons Team</span>
            </label>
          </div>
          <div class="flex gap-3 pt-4 border-t border-champagne mt-6">
            <button type="button" id="close-add-modal-2" class="btn-gold flex-1 justify-center">Annuleren</button>
            <button type="submit" class="btn-premium flex-1 justify-center">Opslaan</button>
          </div>
        </form>
      </div>
    </div>

    <!-- ── Edit Employee Modal ────────────────────────────────── -->
    <div id="edit-modal" class="fixed inset-0 bg-charcoal/40 backdrop-blur-sm hidden z-50 flex items-center justify-center p-4">
      <div class="bg-white border border-champagne shadow-card rounded-2xl w-full max-w-lg p-8 max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between mb-6">
          <h2 class="font-display text-charcoal text-2xl italic">Medewerker Bewerken</h2>
          <button type="button" id="close-edit-modal" class="text-taupe hover:text-charcoal transition-colors" aria-label="Sluiten">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
          </button>
        </div>

        <!-- Foto sectie -->
        <div class="mb-6 flex items-center gap-4 p-4 bg-linen border border-champagne rounded-xl">
          <div id="edit-avatar" class="w-16 h-16 rounded-full overflow-hidden bg-champagne flex items-center justify-center shrink-0">
            <span id="edit-avatar-initials" class="text-base font-display text-taupe"></span>
          </div>
          <div class="flex-1 min-w-0">
            <label class={labelClass}>Profielfoto</label>
            <input type="file" id="edit-photo-input" accept="image/jpeg,image/png,image/webp,image/avif"
              class="w-full text-xs text-taupe file:mr-3 file:py-1.5 file:px-3 file:border file:border-champagne file:rounded-md file:text-[9px] file:uppercase file:tracking-widest file:bg-white file:text-charcoal hover:file:bg-linen transition-all" />
            <button type="button" id="edit-photo-delete" class="mt-1.5 text-[9px] uppercase tracking-widest text-red-400 hover:text-red-600 transition-colors hidden">Foto verwijderen</button>
          </div>
        </div>

        <form id="edit-employee-form" class="space-y-4">
          <input type="hidden" id="edit-id" name="id" />
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class={labelClass}>Voornaam *</label>
              <input type="text" id="edit-first-name" name="first_name" required class={inputClass} />
            </div>
            <div>
              <label class={labelClass}>Achternaam *</label>
              <input type="text" id="edit-last-name" name="last_name" required class={inputClass} />
            </div>
          </div>
          <div>
            <label class={labelClass}>E-mail</label>
            <input type="email" id="edit-email" name="email" class={inputClass} />
          </div>
          <div>
            <label class={labelClass}>Rol / Functie</label>
            <input type="text" id="edit-role" name="role" class={inputClass} />
          </div>
          <div>
            <label class={labelClass}>Bio</label>
            <textarea id="edit-bio" name="bio" rows="3" class={`${inputClass} resize-none`}></textarea>
          </div>
          <div>
            <label class={labelClass}>Specialismes</label>
            <textarea id="edit-specialisms" name="specialisms" rows="3" class={`${inputClass} resize-none`} placeholder="Eén specialisme per regel of komma-gescheiden"></textarea>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class={labelClass}>Contracturen p/w</label>
              <input type="number" id="edit-contract-hours" name="contract_hours" step="0.5" min="0" class={inputClass} />
            </div>
            {canSeeRate && (
              <div id="hourly-rate-field">
                <label class={labelClass}>Uurtarief (€)</label>
                <input type="number" id="edit-hourly-rate" name="hourly_rate" step="0.01" min="0" placeholder="0.00" class={inputClass} />
              </div>
            )}
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class={labelClass}>Volgorde</label>
              <input type="number" id="edit-sort-order" name="sort_order" step="1" class={inputClass} />
            </div>
            <div>
              <label class={labelClass}>Team volgorde</label>
              <input type="number" id="edit-team-sort-order" name="team_sort_order" step="1" class={inputClass} />
            </div>
          </div>
          <!-- Contractrooster -->
          <div class="pt-2">
            <label class={labelClass}>Contractrooster</label>
            <div class="space-y-1.5 mt-2 p-4 bg-linen border border-champagne rounded-xl">
              {SCHEDULE_DAYS.map(({ key, label }) => (
                <div class="flex items-center gap-3">
                  <input
                    type="checkbox"
                    id={`edit-sched-${key}-active`}
                    name={`sched_${key}_active`}
                    class="w-4 h-4 accent-blush-deep sched-toggle"
                    data-prefix={`edit-sched-${key}`}
                  />
                  <span class="text-xs font-medium text-charcoal w-24 shrink-0">{label}</span>
                  <input
                    type="time"
                    id={`edit-sched-${key}-start`}
                    name={`sched_${key}_start`}
                    value="09:00"
                    disabled
                    class="w-24 bg-white border border-champagne px-2 py-1 text-xs text-charcoal focus:border-blush-deep outline-none rounded-lg disabled:opacity-30 disabled:cursor-not-allowed"
                  />
                  <span class="text-taupe text-xs">–</span>
                  <input
                    type="time"
                    id={`edit-sched-${key}-end`}
                    name={`sched_${key}_end`}
                    value="17:00"
                    disabled
                    class="w-24 bg-white border border-champagne px-2 py-1 text-xs text-charcoal focus:border-blush-deep outline-none rounded-lg disabled:opacity-30 disabled:cursor-not-allowed"
                  />
                </div>
              ))}
            </div>
          </div>

          <div class="flex flex-col gap-3 pt-2">
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" id="edit-is-active" name="is_active" class="w-4 h-4 accent-blush-deep" />
              <span class="text-sm text-charcoal">Actief</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" id="edit-show-on-team" name="show_on_team" class="w-4 h-4 accent-blush-deep" />
              <span class="text-sm text-charcoal">Tonen op Ons Team</span>
            </label>
          </div>
          <div class="flex gap-3 pt-4 border-t border-champagne mt-6">
            <button type="button" id="close-edit-modal-2" class="btn-gold flex-1 justify-center">Annuleren</button>
            <button type="submit" class="btn-premium flex-1 justify-center">Opslaan</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</AdminLayout>

<script define:vars={{ canSeeRate }}>
  const DAYS = ['mon', 'tue', 'wed', 'thu', 'fri', 'sat', 'sun'];

  // ─── Schedule toggle (enable/disable time inputs) ────────────
  document.querySelectorAll('.sched-toggle').forEach(cb => {
    cb.addEventListener('change', () => {
      const prefix = cb.getAttribute('data-prefix');
      const startInput = document.getElementById(`${prefix}-start`);
      const endInput = document.getElementById(`${prefix}-end`);
      if (startInput) startInput.disabled = !cb.checked;
      if (endInput) endInput.disabled = !cb.checked;
    });
  });

  function buildSchedule(formData) {
    const schedule = {};
    for (const day of DAYS) {
      const active = formData.get(`sched_${day}_active`) === 'on';
      schedule[day] = {
        active,
        start: active ? (formData.get(`sched_${day}_start`) || '09:00') : null,
        end: active ? (formData.get(`sched_${day}_end`) || '17:00') : null,
      };
    }
    return schedule;
  }

  function fillScheduleInputs(prefix, schedule) {
    for (const day of DAYS) {
      const dayData = (schedule || {})[day] || {};
      const cb = document.getElementById(`${prefix}-sched-${day}-active`);
      const startInput = document.getElementById(`${prefix}-sched-${day}-start`);
      const endInput = document.getElementById(`${prefix}-sched-${day}-end`);
      if (cb) cb.checked = dayData.active || false;
      if (startInput) {
        startInput.value = dayData.start || '09:00';
        startInput.disabled = !dayData.active;
      }
      if (endInput) {
        endInput.value = dayData.end || '17:00';
        endInput.disabled = !dayData.active;
      }
    }
  }

  // ─── Add modal ───────────────────────────────────────────────
  const employeeGrid = document.querySelector('[data-employee-grid]');
  const employeeCards = Array.from(document.querySelectorAll('[data-employee-card]'));
  let draggedEmployeeCard = null;
  let employeeReorderDirty = false;
  let employeeReorderSaving = false;

  function currentEmployeeOrder() {
    return Array.from(document.querySelectorAll('[data-employee-card]'))
      .map((card) => card.dataset.employeeId || '')
      .filter(Boolean);
  }

  async function persistEmployeeOrder() {
    if (employeeReorderSaving) return;
    const employee_ids = currentEmployeeOrder();
    if (employee_ids.length === 0) return;

    employeeReorderSaving = true;
    try {
      const resp = await fetch('/api/admin/employees/reorder', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ employee_ids }),
      });

      if (resp.ok) {
        window.location.reload();
        return;
      }

      const err = await resp.json().catch(() => ({ error: 'Volgorde opslaan mislukt' }));
      alert('Fout: ' + (err.error || 'Volgorde opslaan mislukt'));
      window.location.reload();
    } catch {
      alert('Er is een fout opgetreden.');
      window.location.reload();
    } finally {
      employeeReorderSaving = false;
    }
  }

  function setDraggedState(card, active) {
    card.classList.toggle('opacity-60', active);
    card.classList.toggle('scale-[0.98]', active);
  }

  function reorderCard(targetCard, clientY) {
    if (!draggedEmployeeCard || !employeeGrid || targetCard === draggedEmployeeCard) return;

    const rect = targetCard.getBoundingClientRect();
    const insertBefore = clientY < rect.top + rect.height / 2;
    const destination = insertBefore ? targetCard : targetCard.nextElementSibling;

    if (destination !== draggedEmployeeCard) {
      employeeGrid.insertBefore(draggedEmployeeCard, destination);
      employeeReorderDirty = true;
    }
  }

  function bindEmployeeCard(card) {
    card.addEventListener('dragstart', (event) => {
      const target = event.target;
      if (!(target instanceof Element) || !target.closest('[data-drag-handle]')) {
        event.preventDefault();
        return;
      }

      draggedEmployeeCard = card;
      employeeReorderDirty = false;
      setDraggedState(card, true);

      if (event.dataTransfer) {
        event.dataTransfer.effectAllowed = 'move';
        event.dataTransfer.setData('text/plain', card.dataset.employeeId || '');
      }
    });

    card.addEventListener('dragover', (event) => {
      if (!draggedEmployeeCard) return;
      event.preventDefault();
      reorderCard(card, event.clientY);
    });

    card.addEventListener('dragenter', (event) => {
      if (!draggedEmployeeCard) return;
      event.preventDefault();
    });

    card.addEventListener('dragend', () => {
      setDraggedState(card, false);
      const shouldPersist = employeeReorderDirty;
      draggedEmployeeCard = null;
      employeeReorderDirty = false;
      if (shouldPersist) void persistEmployeeOrder();
    });
  }

  employeeCards.forEach(bindEmployeeCard);

  const addModal = document.getElementById('add-modal');
  document.getElementById('add-employee-btn')?.addEventListener('click', () => addModal?.classList.remove('hidden'));
  document.getElementById('close-add-modal')?.addEventListener('click', () => addModal?.classList.add('hidden'));
  document.getElementById('close-add-modal-2')?.addEventListener('click', () => addModal?.classList.add('hidden'));

  document.getElementById('add-employee-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const formData = new FormData(form);
    const data = {
      first_name: formData.get('first_name'),
      last_name: formData.get('last_name'),
      email: formData.get('email') || null,
      role: formData.get('role') || null,
      bio: formData.get('bio') || null,
      specialisms: formData.get('specialisms'),
      contract_hours: Number(formData.get('contract_hours')) || 0,
      hourly_rate: formData.get('hourly_rate') ? Number(formData.get('hourly_rate')) : null,
      sort_order: Number(formData.get('sort_order')) || 0,
      team_sort_order: Number(formData.get('team_sort_order')) || 0,
      is_active: formData.get('is_active') === 'on',
      show_on_team: formData.get('show_on_team') === 'on',
      contract_schedule: buildSchedule(formData),
    };

    try {
      const resp = await fetch('/api/admin/employees', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (resp.ok) {
        window.location.reload();
      } else {
        const err = await resp.json();
        alert('Fout: ' + err.error);
      }
    } catch {
      alert('Er is een fout opgetreden.');
    }
  });

  // ─── Edit modal ───────────────────────────────────────────────
  const editModal = document.getElementById('edit-modal');
  let currentEditId = null;

  function openEditModal(emp) {
    currentEditId = emp.id;
    document.getElementById('edit-id').value = emp.id;
    document.getElementById('edit-first-name').value = emp.first_name || '';
    document.getElementById('edit-last-name').value = emp.last_name || '';
    document.getElementById('edit-email').value = emp.email || '';
    document.getElementById('edit-role').value = emp.role || '';
    document.getElementById('edit-bio').value = emp.bio || '';
    document.getElementById('edit-specialisms').value = Array.isArray(emp.specialisms) ? emp.specialisms.join('\n') : '';
    document.getElementById('edit-contract-hours').value = emp.contract_hours ?? 0;
    document.getElementById('edit-sort-order').value = emp.sort_order ?? 0;
    document.getElementById('edit-team-sort-order').value = emp.team_sort_order ?? 0;
    document.getElementById('edit-is-active').checked = emp.is_active !== false;
    document.getElementById('edit-show-on-team').checked = emp.show_on_team === true;
    fillScheduleInputs('edit', emp.contract_schedule || {});

    if (canSeeRate) {
      const rateInput = document.getElementById('edit-hourly-rate');
      if (rateInput) rateInput.value = emp.hourly_rate ?? '';
    }

    // Avatar
    const avatarEl = document.getElementById('edit-avatar');
    const initialsEl = document.getElementById('edit-avatar-initials');
    const deletePhotoBtn = document.getElementById('edit-photo-delete');

    if (emp.profile_photo_url) {
      avatarEl.innerHTML = `<img src="${emp.profile_photo_url}" alt="" onerror="this.onerror=null;this.src='/images/logo/Social-Media-profielfoto.jpg'" class="w-full h-full object-cover" />`;
      deletePhotoBtn?.classList.remove('hidden');
    } else {
      avatarEl.innerHTML = `<span id="edit-avatar-initials" class="text-base font-serif text-accent/60">${(emp.first_name || '').charAt(0)}${(emp.last_name || '').charAt(0)}</span>`;
      deletePhotoBtn?.classList.add('hidden');
    }

    editModal?.classList.remove('hidden');
  }

  document.getElementById('close-edit-modal')?.addEventListener('click', () => editModal?.classList.add('hidden'));
  document.getElementById('close-edit-modal-2')?.addEventListener('click', () => editModal?.classList.add('hidden'));

  document.querySelectorAll('.edit-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const emp = JSON.parse(btn.getAttribute('data-employee') || '{}');
      openEditModal(emp);
    });
  });

  document.getElementById('edit-employee-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!currentEditId) return;
    const form = e.target;
    const formData = new FormData(form);

    const data = {
      first_name: formData.get('first_name'),
      last_name: formData.get('last_name'),
      email: formData.get('email') || null,
      role: formData.get('role') || null,
      bio: formData.get('bio') || null,
      specialisms: formData.get('specialisms'),
      contract_hours: Number(formData.get('contract_hours')) || 0,
      hourly_rate: formData.get('hourly_rate') ? Number(formData.get('hourly_rate')) : null,
      sort_order: Number(formData.get('sort_order')) || 0,
      team_sort_order: Number(formData.get('team_sort_order')) || 0,
      is_active: formData.get('is_active') === 'on',
      show_on_team: formData.get('show_on_team') === 'on',
      contract_schedule: buildSchedule(formData),
    };

    try {
      const resp = await fetch(`/api/admin/employees/${currentEditId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (resp.ok) {
        // Upload photo if selected
        const photoInput = document.getElementById('edit-photo-input');
        if (photoInput?.files?.length > 0) {
          const photoForm = new FormData();
          photoForm.append('photo', photoInput.files[0]);
          await fetch(`/api/admin/employees/${currentEditId}/photo`, {
            method: 'POST',
            body: photoForm,
          });
        }
        window.location.reload();
      } else {
        const err = await resp.json();
        alert('Fout: ' + err.error);
      }
    } catch {
      alert('Er is een fout opgetreden.');
    }
  });

  // Photo delete
  document.getElementById('edit-photo-delete')?.addEventListener('click', async () => {
    if (!currentEditId) return;
    if (!confirm('Profielfoto verwijderen?')) return;
    try {
      const resp = await fetch(`/api/admin/employees/${currentEditId}/photo`, { method: 'DELETE' });
      if (resp.ok) window.location.reload();
      else alert('Kon foto niet verwijderen.');
    } catch {
      alert('Er is een fout opgetreden.');
    }
  });

  // ─── Delete ───────────────────────────────────────────────────
  document.querySelectorAll('.delete-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      const name = btn.getAttribute('data-name');
      if (!confirm(`Medewerker "${name}" verwijderen? Dit kan niet ongedaan worden gemaakt.`)) return;
      try {
        const resp = await fetch(`/api/admin/employees/${id}`, { method: 'DELETE' });
        if (resp.ok) {
          window.location.reload();
        } else {
          const err = await resp.json();
          alert('Fout: ' + err.error);
        }
      } catch {
        alert('Er is een fout opgetreden.');
      }
    });
  });

  // Close modals on backdrop click
  [addModal, editModal].forEach((modal) => {
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) modal.classList.add('hidden');
    });
  });
</script>
