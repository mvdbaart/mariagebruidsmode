---
import Layout from '../../../layouts/Layout.astro';
import { getAdminAuthFromCookies, getServiceRoleClient } from '../../../lib/serverAuth';

const adminAuth = await getAdminAuthFromCookies(Astro.cookies);
if (!adminAuth) {
  return Astro.redirect('/admin/login');
}

const supabase = getServiceRoleClient();
const { data: employees } = await supabase.from('employees').select('*').eq('is_active', true);

// Get entries for the last 30 days
const thirtyDaysAgo = new Date();
thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);

const { data: entries } = await supabase
  .from('time_entries')
  .select('*, employees(first_name, last_name)')
  .gte('date', thirtyDaysAgo.toISOString().split('T')[0])
  .order('date', { ascending: false });
---

<Layout title="Urenregistratie - Admin">
  <main class="min-h-screen bg-primary py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-12">
        <div class="flex items-center gap-4">
          <a href="/admin/planner/medewerkers" class="text-[10px] uppercase tracking-widest text-accent/60 hover:text-accent transition-colors flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
            Planning
          </a>
          <h1 class="text-3xl font-serif text-accent">Urenregistratie</h1>
        </div>
        <button id="add-entry-btn" class="px-6 py-2 bg-secondary text-white text-[10px] uppercase tracking-widest rounded hover:bg-accent transition-all">
          Uren Toevoegen
        </button>
      </div>

      <div class="flex gap-8 mb-12 border-b border-accent/10">
        <a href="/admin/planner/medewerkers" class="pb-4 text-[10px] uppercase tracking-widest text-accent/40 hover:text-accent transition-colors">Medewerkers</a>
        <a href="/admin/planner/kalender" class="pb-4 text-[10px] uppercase tracking-widest text-accent/40 hover:text-accent transition-colors">Weekrooster</a>
        <a href="/admin/planner/uren" class="pb-4 text-[10px] uppercase tracking-widest font-bold border-b-2 border-secondary text-secondary">Urenregistratie</a>
        <a href="/admin/planner/verlof" class="pb-4 text-[10px] uppercase tracking-widest text-accent/40 hover:text-accent transition-colors">Verlof & Ziekte</a>
      </div>

      <div class="bg-white/50 backdrop-blur-sm border border-accent/10 rounded-lg overflow-hidden shadow-sm">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-accent/5">
              <th class="px-6 py-4 text-[10px] uppercase tracking-widest text-accent font-medium">Datum</th>
              <th class="px-6 py-4 text-[10px] uppercase tracking-widest text-accent font-medium">Medewerker</th>
              <th class="px-6 py-4 text-[10px] uppercase tracking-widest text-accent font-medium">Tijd</th>
              <th class="px-6 py-4 text-[10px] uppercase tracking-widest text-accent font-medium">Pauze</th>
              <th class="px-6 py-4 text-[10px] uppercase tracking-widest text-accent font-medium text-right">Totaal</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-accent/10">
            {entries?.map(entry => {
              const start = new Date(`1970-01-01T${entry.start_time}`);
              const end = new Date(`1970-01-01T${entry.end_time}`);
              let diffMs = end.getTime() - start.getTime();
              if (diffMs < 0) diffMs += 24 * 60 * 60 * 1000;
              const totalMinutes = (diffMs / 60000) - (entry.break_minutes || 0);
              const hours = Math.floor(totalMinutes / 60);
              const minutes = Math.round(totalMinutes % 60);
              
              return (
                <tr class="hover:bg-accent/[0.02] transition-colors">
                  <td class="px-6 py-4 text-xs font-medium text-accent">
                    {new Date(entry.date).toLocaleDateString('nl-NL', { weekday: 'short', day: 'numeric', month: 'short' })}
                  </td>
                  <td class="px-6 py-4 text-sm text-accent">
                    {entry.employees?.first_name} {entry.employees?.last_name}
                  </td>
                  <td class="px-6 py-4 text-xs text-accent/60">
                    {entry.start_time.slice(0, 5)} - {entry.end_time.slice(0, 5)}
                  </td>
                  <td class="px-6 py-4 text-xs text-accent/60">
                    {entry.break_minutes} min
                  </td>
                  <td class="px-6 py-4 text-right text-sm font-medium text-secondary">
                    {hours}u {minutes}m
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Modal for adding time entries -->
    <div id="entry-modal" class="fixed inset-0 bg-accent/40 backdrop-blur-sm hidden z-50 flex items-center justify-center p-4">
      <div class="bg-primary w-full max-w-sm p-8 rounded-lg shadow-xl border border-accent/10">
        <h2 class="text-2xl font-serif text-accent mb-6">Uren Registreren</h2>
        <form id="entry-form" class="space-y-4">
          <div>
            <label class="block text-[10px] uppercase tracking-widest text-accent/60 mb-1">Medewerker</label>
            <select name="employee_id" required class="w-full bg-white border border-accent/10 px-3 py-2 text-sm focus:border-secondary outline-none">
              {employees?.map(emp => (
                <option value={emp.id}>{emp.first_name} {emp.last_name}</option>
              ))}
            </select>
          </div>
          <div>
            <label class="block text-[10px] uppercase tracking-widest text-accent/60 mb-1">Datum</label>
            <input type="date" name="date" required value={new Date().toISOString().split('T')[0]} class="w-full bg-white border border-accent/10 px-3 py-2 text-sm focus:border-secondary outline-none" />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] uppercase tracking-widest text-accent/60 mb-1">Start</label>
              <input type="time" name="start_time" required value="09:00" class="w-full bg-white border border-accent/10 px-3 py-2 text-sm focus:border-secondary outline-none" />
            </div>
            <div>
              <label class="block text-[10px] uppercase tracking-widest text-accent/60 mb-1">Eind</label>
              <input type="time" name="end_time" required value="17:00" class="w-full bg-white border border-accent/10 px-3 py-2 text-sm focus:border-secondary outline-none" />
            </div>
          </div>
          <div>
            <label class="block text-[10px] uppercase tracking-widest text-accent/60 mb-1">Pauze (minuten)</label>
            <input type="number" name="break_minutes" value="30" class="w-full bg-white border border-accent/10 px-3 py-2 text-sm focus:border-secondary outline-none" />
          </div>
          <div class="flex gap-4 mt-8">
            <button type="button" id="close-entry-modal" class="flex-1 py-3 text-[10px] uppercase tracking-widest text-accent/60 hover:text-accent transition-colors">Annuleren</button>
            <button type="submit" class="flex-2 bg-accent text-white px-8 py-3 text-[10px] uppercase tracking-widest hover:bg-secondary transition-all rounded">Opslaan</button>
          </div>
        </form>
      </div>
    </div>
  </main>
</Layout>

<script>
  const modal = document.getElementById('entry-modal');
  const addBtn = document.getElementById('add-entry-btn');
  const closeBtn = document.getElementById('close-entry-modal');
  const form = document.getElementById('entry-form') as HTMLFormElement;

  addBtn?.addEventListener('click', () => modal?.classList.remove('hidden'));
  closeBtn?.addEventListener('click', () => modal?.classList.add('hidden'));

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const resp = await fetch('/api/admin/time_entries', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      if (resp.ok) {
        window.location.reload();
      } else {
        const err = await resp.json();
        alert('Fout: ' + err.error);
      }
    } catch (err) {
      alert('Er is een fout opgetreden.');
    }
  });
</script>
