---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { getServiceRoleClient } from '../../../../lib/serverAuth';
import type { FieldDefinition } from '../../../../lib/forms';

const { id } = Astro.params;
const supabase = getServiceRoleClient();

const [{ data: form }, { data: submissions }] = await Promise.all([
  supabase.from('forms').select('*').eq('id', id).single(),
  supabase.from('form_submissions').select('*').eq('form_id', id).order('submitted_at', { ascending: false }),
]);

if (!form) return Astro.redirect('/admin/formulieren');

const fields: FieldDefinition[] = form.fields ?? [];
const fieldMap = Object.fromEntries(fields.map(f => [f.id, f.label]));
---

<AdminLayout title={`Inzendingen: ${form.name}`}>
  <div class="pt-8 pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6">
      <nav class="mb-10 flex items-center gap-3 text-[10px] tracking-[0.2em] uppercase text-taupe font-body">
        <a href="/admin" class="hover:text-charcoal transition-colors">Dashboard</a>
        <span class="text-champagne">›</span>
        <a href="/admin/formulieren" class="hover:text-charcoal transition-colors">Formulieren</a>
        <span class="text-champagne">›</span>
        <span class="text-charcoal">{form.name} — Inzendingen</span>
      </nav>

      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="text-[10px] tracking-[0.3em] uppercase text-blush-deep font-body mb-2">{form.name}</p>
          <h1 class="font-display font-normal text-charcoal text-4xl leading-tight">
            Inzendingen
          </h1>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-[10px] tracking-widest uppercase font-body text-taupe font-medium">{submissions?.length ?? 0} resultaten</span>
          <a href={`/admin/formulier/${form.id}/edit`} class="border border-champagne px-6 py-3 text-[10px] tracking-widest uppercase font-body text-taupe hover:border-charcoal hover:text-charcoal transition-colors">
            Bewerk formulier
          </a>
        </div>
      </div>

      {submissions && submissions.length > 0 ? (
        <div class="bg-white border border-champagne shadow-soft overflow-x-auto">
          <table class="w-full text-sm font-body min-w-[600px]">
            <thead>
              <tr class="border-b border-champagne bg-[#faf9f7]">
                <th class="text-left px-5 py-4 text-[9px] tracking-[0.25em] uppercase text-taupe font-medium whitespace-nowrap">Datum</th>
                {fields.map(field => (
                  <th class="text-left px-5 py-4 text-[9px] tracking-[0.25em] uppercase text-taupe font-medium whitespace-nowrap">{field.label}</th>
                ))}
              </tr>
            </thead>
            <tbody class="divide-y divide-champagne">
              {submissions.map(sub => (
                <tr class="hover:bg-[#faf9f7] transition-colors">
                  <td class="px-5 py-4 text-xs text-taupe whitespace-nowrap">
                    {new Date(sub.submitted_at).toLocaleString('nl-NL', {
                      day: 'numeric', month: 'short', year: 'numeric',
                      hour: '2-digit', minute: '2-digit'
                    })}
                  </td>
                  {fields.map(field => {
                    const value = sub.data?.[field.id];
                    const displayValue = Array.isArray(value) ? value.join(', ') : (value ?? '—');
                    return (
                      <td class="px-5 py-4 text-sm text-charcoal max-w-xs">
                        <span class="line-clamp-2" title={displayValue}>{displayValue || '—'}</span>
                      </td>
                    );
                  })}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="text-center py-24 bg-white border border-dashed border-champagne">
          <p class="font-display text-xl text-taupe italic mb-2">Nog geen inzendingen.</p>
          <p class="text-sm font-body text-taupe">Inzendingen verschijnen hier zodra het formulier is ingevuld.</p>
        </div>
      )}

      {fields.length > 0 && submissions && submissions.length > 0 && (
        <div class="mt-6 flex justify-end">
          <button
            id="export-csv-btn"
            class="border border-champagne px-6 py-3 text-[10px] tracking-widest uppercase font-body text-taupe hover:border-charcoal hover:text-charcoal transition-colors"
          >
            Exporteer als CSV
          </button>
        </div>
      )}
    </div>
  </div>
</AdminLayout>

<script define:vars={{ submissions, fields, formName: form.name }}>
  document.getElementById('export-csv-btn')?.addEventListener('click', () => {
    const headers = ['Datum', ...fields.map(f => f.label)];
    const rows = submissions.map(sub => [
      new Date(sub.submitted_at).toLocaleString('nl-NL'),
      ...fields.map(f => {
        const v = sub.data?.[f.id];
        return Array.isArray(v) ? v.join('; ') : (v ?? '');
      }),
    ]);

    const escape = v => `"${String(v).replace(/"/g, '""')}"`;
    const csv = [headers, ...rows].map(row => row.map(escape).join(',')).join('\n');
    const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${formName.toLowerCase().replace(/\s+/g, '-')}-inzendingen.csv`;
    a.click();
    URL.revokeObjectURL(url);
  });
</script>
