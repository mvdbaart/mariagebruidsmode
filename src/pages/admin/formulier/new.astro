---
import Layout from '../../../layouts/Layout.astro';
import FormBuilderEditor from '../../../components/admin/FormBuilderEditor';
---

<Layout title="Nieuw Formulier">
  <div class="pt-32 pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6 max-w-4xl">
      <nav class="mb-10 flex items-center gap-3 text-[10px] tracking-[0.2em] uppercase text-taupe font-body">
        <a href="/admin" class="hover:text-charcoal transition-colors">Dashboard</a>
        <span class="text-champagne">›</span>
        <a href="/admin/formulieren" class="hover:text-charcoal transition-colors">Formulieren</a>
        <span class="text-champagne">›</span>
        <span class="text-charcoal">Nieuw Formulier</span>
      </nav>

      <div class="mb-10">
        <p class="text-[10px] tracking-[0.3em] uppercase text-blush-deep font-body mb-2">Formulieren</p>
        <h1 class="font-display font-normal text-charcoal text-4xl leading-tight">
          Nieuw <em class="font-normal italic text-taupe">Formulier</em>
        </h1>
      </div>

      <FormBuilderEditor client:only="react" />
    </div>
  </div>
</Layout>
