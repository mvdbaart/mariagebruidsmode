---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Nieuwe Bruidsstory">
  <div class="pt-8 pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6 max-w-3xl">
      <nav class="mb-10 flex items-center gap-3 text-[10px] tracking-[0.2em] uppercase text-taupe font-body">
        <a href="/admin" class="hover:text-blush-deep transition-colors">Dashboard</a>
        <span class="text-champagne">/</span>
        <a href="/admin/inspiratie" class="hover:text-blush-deep transition-colors">Inspiratie Beheer</a>
        <span class="text-champagne">/</span>
        <span class="text-charcoal">Nieuw Verhaal</span>
      </nav>

      <div class="bg-white border border-champagne p-10 shadow-soft">
        <h1 class="font-display font-normal text-charcoal text-3xl mb-10">Nieuw <em class="italic font-light">bruidsverhaal</em></h1>

        <form id="new-wedding-form" class="space-y-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Naam Bruid *</label>
              <input type="text" name="bride_name" required class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" />
            </div>
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Naam Bruidegom *</label>
              <input type="text" name="groom_name" required class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" />
            </div>
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Trouwdatum</label>
              <input type="date" name="wedding_date" class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" />
            </div>
            <div class="space-y-2">
              <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Slug (URL pad)</label>
              <input type="text" name="slug" id="wedding-slug" class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" placeholder="bijv. emma-en-david-2026" />
            </div>
          </div>

          <div class="space-y-2">
            <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Cover Afbeelding URL</label>
            <input type="url" name="cover_image" class="w-full border-b border-champagne py-3 focus:border-charcoal outline-none transition-colors font-body font-light bg-transparent" placeholder="https://..." />
          </div>

          <div class="space-y-2">
            <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Galerij Afbeeldingen (één URL per regel)</label>
            <textarea name="gallery_images_raw" rows="4" class="w-full border border-champagne p-4 focus:border-charcoal outline-none transition-colors font-body font-light bg-cream/30 resize-none" placeholder="https://image1.jpg&#10;https://image2.jpg"></textarea>
          </div>

          <div class="space-y-2">
            <label class="text-[10px] tracking-widest uppercase text-charcoal font-body font-medium">Verhaal / Omschrijving</label>
            <textarea name="story" rows="8" class="w-full border border-champagne p-4 focus:border-charcoal outline-none transition-colors font-body font-light bg-cream/30 resize-none" placeholder="Vertel het trouwverhaal van het stel..."></textarea>
          </div>

          <div class="flex gap-4 pt-4">
            <button type="submit" class="btn-premium text-[10px]">Verhaal Publiceren</button>
            <a href="/admin/inspiratie" class="btn-gold text-[10px]">Annuleren</a>
          </div>
          <p id="form-status" class="text-sm font-body font-light hidden"></p>
        </form>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  const form = document.getElementById('new-wedding-form') as HTMLFormElement;
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;
    status.textContent = 'Bezig met publiceren...';
    status.className = 'text-sm font-body font-light text-taupe block';

    const data = new FormData(form);
    const galleryRaw = (data.get('gallery_images_raw') as string ?? '').split('\n').map(s => s.trim()).filter(Boolean);

    const response = await fetch('/api/admin/inspiratie', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({
        bride_name: data.get('bride_name'),
        groom_name: data.get('groom_name'),
        wedding_date: data.get('wedding_date') || null,
        slug: data.get('slug') || null,
        cover_image: data.get('cover_image') || null,
        gallery_images: galleryRaw,
        story: data.get('story') || null,
      }),
    });
    const result = await response.json().catch(() => ({ error: 'Onbekende fout.' }));

    if (!response.ok) {
      status.textContent = 'Fout: ' + result.error;
      status.className = 'text-sm font-body font-light text-red-500 block';
    } else {
      status.textContent = 'Verhaal gepubliceerd!';
      status.className = 'text-sm font-body font-light text-green-600 block';
      setTimeout(() => { window.location.href = '/admin/inspiratie'; }, 1200);
    }
  });
</script>
