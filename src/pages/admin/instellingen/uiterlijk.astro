---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getServiceRoleClient } from '../../../lib/serverAuth';

const supabase = getServiceRoleClient();
const { data: settings } = await supabase.from('site_settings').select('*').eq('id', 'current').single();
---

<AdminLayout title="Uiterlijk Instellingen">
  <div class="pt-8 pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6 max-w-4xl">
      <nav class="mb-10 flex items-center gap-3 text-[10px] tracking-[0.2em] uppercase text-taupe font-body">
        <a href="/admin" class="hover:text-charcoal transition-colors">Dashboard</a>
        <span class="text-champagne">›</span>
        <a href="/admin/instellingen" class="hover:text-charcoal transition-colors">Instellingen</a>
        <span class="text-champagne">›</span>
        <span class="text-charcoal">Uiterlijk</span>
      </nav>

      <div class="mb-10">
        <p class="text-[10px] tracking-[0.3em] uppercase text-blush-deep font-body mb-2">Instellingen</p>
        <h1 class="font-display font-normal text-charcoal text-4xl leading-tight">
          Uiterlijk <em class="font-normal italic text-taupe">& Stijl</em>
        </h1>
      </div>

      <form id="settings-form" class="space-y-10">
        <!-- Kleurenpalet -->
        <section class="bg-white border border-champagne p-8 shadow-soft space-y-8">
          <h2 class="text-[10px] uppercase tracking-[0.3em] text-taupe font-body font-medium border-b border-champagne pb-4">Kleurenpalet</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {Object.entries(settings?.colors || {}).map(([key, value]) => (
              <div class="space-y-2">
                <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body">{key.replace(/_/g, ' ')}</label>
                <div class="flex items-center gap-4">
                  <input
                    type="color"
                    name={`color_${key}`}
                    value={String(value)}
                    class="w-10 h-10 cursor-pointer border border-champagne bg-transparent p-0.5"
                  />
                  <input
                    type="text"
                    name={`color_text_${key}`}
                    value={String(value)}
                    class="flex-grow border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors font-mono uppercase"
                  />
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Typografie -->
        <section class="bg-white border border-champagne p-8 shadow-soft space-y-8">
          <h2 class="text-[10px] uppercase tracking-[0.3em] text-taupe font-body font-medium border-b border-champagne pb-4">Typografie</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Heading Font</label>
              <input type="text" name="heading_font" value={settings?.typography?.heading_font}
                class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors" />
            </div>
            <div>
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Body Font</label>
              <input type="text" name="body_font" value={settings?.typography?.body_font}
                class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors" />
            </div>
            <div>
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Basis Tekstgrootte</label>
              <input type="text" name="base_size" value={settings?.typography?.base_size} placeholder="16px"
                class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors" />
            </div>
            <div>
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Heading Dikte</label>
              <select name="heading_weight"
                class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors">
                {['300','400','500','600','700'].map(w => (
                  <option value={w} selected={settings?.typography?.heading_weight === w}>
                    {w === '300' ? 'Light' : w === '400' ? 'Regular' : w === '500' ? 'Medium' : w === '600' ? 'Semi-Bold' : 'Bold'} ({w})
                  </option>
                ))}
              </select>
            </div>
          </div>
        </section>

        <!-- UI Stijl -->
        <section class="bg-white border border-champagne p-8 shadow-soft space-y-8">
          <h2 class="text-[10px] uppercase tracking-[0.3em] text-taupe font-body font-medium border-b border-champagne pb-4">UI Stijl & Rundingen</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Border Radius</label>
              <input type="text" name="border_radius" value={settings?.ui_styles?.border_radius} placeholder="0px"
                class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors" />
            </div>
            <div>
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Button Padding</label>
              <input type="text" name="button_padding" value={settings?.ui_styles?.button_padding} placeholder="12px 32px"
                class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors" />
            </div>
          </div>
        </section>

        <!-- Algemeen -->
        <section class="bg-white border border-champagne p-8 shadow-soft space-y-8">
          <h2 class="text-[10px] uppercase tracking-[0.3em] text-taupe font-body font-medium border-b border-champagne pb-4">Algemeen</h2>
          <div class="space-y-6">
            <div>
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Website Titel</label>
              <input type="text" name="site_title" value={settings?.site_metadata?.title}
                class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors" />
            </div>
            <div>
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Website Beschrijving (SEO)</label>
              <textarea name="site_description" rows={3} spellcheck="false"
                class="w-full border border-champagne bg-transparent p-3 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors resize-none"
              >{settings?.site_metadata?.description}</textarea>
            </div>
          </div>
        </section>

        <div id="save-error" class="hidden bg-red-50 border border-red-200 px-4 py-3 text-sm font-body text-red-700"></div>
        <div id="save-success" class="hidden bg-green-50 border border-green-200 px-4 py-3 text-sm font-body text-green-700">Instellingen opgeslagen. Herlaad de pagina om wijzigingen overal te zien.</div>

        <div class="flex gap-4 pt-2">
          <button type="submit" id="save-btn" class="btn-premium text-[10px]">Instellingen Opslaan</button>
          <a href="/admin/instellingen" class="border border-champagne px-8 py-3 text-[10px] tracking-widest uppercase font-body text-taupe hover:border-charcoal hover:text-charcoal transition-colors">Terug</a>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  // Sync color pickers with text inputs
  document.querySelectorAll<HTMLInputElement>('input[type="color"]').forEach(input => {
    const textInput = input.nextElementSibling as HTMLInputElement;
    input.addEventListener('input', () => { if (textInput) textInput.value = input.value.toUpperCase(); });
    textInput?.addEventListener('input', () => { input.value = textInput.value; });
  });

  const form = document.getElementById('settings-form') as HTMLFormElement;
  const saveBtn = document.getElementById('save-btn');
  const errorEl = document.getElementById('save-error');
  const successEl = document.getElementById('save-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (errorEl) { errorEl.textContent = ''; errorEl.classList.add('hidden'); }
    if (successEl) successEl.classList.add('hidden');
    if (saveBtn) { saveBtn.textContent = 'Bezig met opslaan...'; saveBtn.setAttribute('disabled', 'true'); }

    const fd = new FormData(form);
    const data = {
      colors: Object.fromEntries(
        Array.from(fd.entries())
          .filter(([k]) => k.startsWith('color_') && !k.startsWith('color_text_'))
          .map(([k, v]) => [k.replace('color_', ''), v])
      ),
      typography: {
        heading_font: fd.get('heading_font'),
        body_font: fd.get('body_font'),
        base_size: fd.get('base_size'),
        heading_weight: fd.get('heading_weight'),
        body_weight: '400',
      },
      ui_styles: {
        border_radius: fd.get('border_radius'),
        button_padding: fd.get('button_padding'),
        container_width: '1280px',
      },
      site_metadata: {
        title: fd.get('site_title'),
        description: fd.get('site_description'),
        footer_text: '© 2026 Mariage Bruidsmode. Alle rechten voorbehouden.',
      },
    };

    try {
      const res = await fetch('/api/admin/settings', {
        method: 'PUT',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        successEl?.classList.remove('hidden');
      } else {
        const err = await res.json();
        if (errorEl) { errorEl.textContent = 'Fout: ' + (err.error ?? 'Onbekend'); errorEl.classList.remove('hidden'); }
      }
    } catch {
      if (errorEl) { errorEl.textContent = 'Netwerkfout. Probeer opnieuw.'; errorEl.classList.remove('hidden'); }
    } finally {
      if (saveBtn) { saveBtn.textContent = 'Instellingen Opslaan'; saveBtn.removeAttribute('disabled'); }
    }
  });
</script>
