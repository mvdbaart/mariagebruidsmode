---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getServiceRoleClient } from '../../../lib/serverAuth';

const supabase = getServiceRoleClient();
const { data: settings } = await supabase.from('site_settings').select('logo_url, contact_info').eq('id', 'current').single();

const logo = settings?.logo_url ?? null;
const contact = (settings?.contact_info ?? {}) as Record<string, string>;
---

<AdminLayout title="Bedrijfsgegevens — Instellingen">
  <div class="pt-8 pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6 max-w-4xl">
      <nav class="mb-10 flex items-center gap-3 text-[10px] tracking-[0.2em] uppercase text-taupe font-body">
        <a href="/admin" class="hover:text-charcoal transition-colors">Dashboard</a>
        <span class="text-champagne">›</span>
        <a href="/admin/instellingen" class="hover:text-charcoal transition-colors">Instellingen</a>
        <span class="text-champagne">›</span>
        <span class="text-charcoal">Bedrijfsgegevens</span>
      </nav>

      <div class="mb-10">
        <p class="text-[10px] tracking-[0.3em] uppercase text-blush-deep font-body mb-2">Instellingen</p>
        <h1 class="font-display font-normal text-charcoal text-4xl leading-tight">
          Bedrijf <em class="font-normal italic text-taupe">& Logo</em>
        </h1>
      </div>

      <!-- Logo sectie -->
      <section class="bg-white border border-champagne p-8 shadow-soft mb-8">
        <h2 class="text-[10px] uppercase tracking-[0.3em] text-taupe font-body font-medium border-b border-champagne pb-4 mb-8">Logo</h2>

        <!-- Huidige logo preview -->
        <div class="mb-8">
          <p class="text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-4">Huidig logo</p>
          <div id="logo-preview-wrapper" class="flex items-center gap-6">
            {logo ? (
              <img id="logo-preview" src={logo} alt="Huidig logo" class="h-16 object-contain border border-champagne p-2 bg-white" />
            ) : (
              <div id="logo-preview" class="h-16 w-40 border border-dashed border-champagne flex items-center justify-center bg-linen">
                <span class="text-[10px] uppercase tracking-widest font-body text-taupe">Geen logo</span>
              </div>
            )}
            <button
              id="remove-logo-btn"
              type="button"
              class={`text-[9px] tracking-widest uppercase font-body text-red-400 hover:text-red-600 transition-colors ${!logo ? 'hidden' : ''}`}
            >
              Verwijderen
            </button>
          </div>
        </div>

        <!-- Upload -->
        <div>
          <p class="text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-3">Nieuw logo uploaden</p>
          <p class="text-xs font-body text-taupe mb-4">Ondersteunde formaten: JPG, PNG, WebP, AVIF, SVG. Max. 5 MB. Aanbevolen: transparante achtergrond (PNG/SVG).</p>
          <div class="flex items-center gap-4 flex-wrap">
            <label class="cursor-pointer">
              <span class="border border-champagne px-6 py-3 text-[10px] tracking-widest uppercase font-body text-taupe hover:border-charcoal hover:text-charcoal transition-colors inline-block">
                Bestand kiezen
              </span>
              <input id="logo-file-input" type="file" accept="image/jpeg,image/png,image/webp,image/avif,image/svg+xml" class="sr-only" />
            </label>
            <span id="logo-file-name" class="text-xs font-body text-taupe">Geen bestand gekozen</span>
          </div>
          <div id="logo-upload-error" class="hidden mt-3 text-xs font-body text-red-600"></div>
          <div id="logo-upload-success" class="hidden mt-3 text-xs font-body text-green-600">Logo succesvol opgeslagen.</div>
        </div>
      </section>

      <!-- Adresgegevens sectie -->
      <form id="contact-form" class="space-y-0">
        <section class="bg-white border border-champagne p-8 shadow-soft space-y-8">
          <h2 class="text-[10px] uppercase tracking-[0.3em] text-taupe font-body font-medium border-b border-champagne pb-4">Adres- en contactgegevens</h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="md:col-span-2">
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Bedrijfsnaam</label>
              <input type="text" name="name" value={contact.name ?? ''}
                class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors" />
            </div>

            <div class="md:col-span-2">
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Straat en huisnummer</label>
              <input type="text" name="address" value={contact.address ?? ''}
                class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors" />
            </div>

            <div>
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Postcode</label>
              <input type="text" name="postal_code" value={contact.postal_code ?? ''}
                class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors" />
            </div>

            <div>
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Plaats</label>
              <input type="text" name="city" value={contact.city ?? ''}
                class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors" />
            </div>

            <div>
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Telefoonnummer</label>
              <input type="tel" name="phone" value={contact.phone ?? ''}
                class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors" />
            </div>

            <div>
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">E-mailadres</label>
              <input type="email" name="email" value={contact.email ?? ''}
                class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors" />
            </div>

            <div>
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">KVK-nummer</label>
              <input type="text" name="kvk" value={contact.kvk ?? ''}
                class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors" />
            </div>

            <div>
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">BTW-nummer</label>
              <input type="text" name="btw" value={contact.btw ?? ''}
                class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors" />
            </div>

            <div class="md:col-span-2">
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Openingstijden</label>
              <textarea name="opening_hours" rows={4} spellcheck="false"
                class="w-full border border-champagne bg-transparent p-3 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors resize-none"
                placeholder="Ma: gesloten&#10;Di–Vr: 10:00–18:00&#10;Za: 10:00–17:00&#10;Zo: gesloten"
              >{contact.opening_hours ?? ''}</textarea>
            </div>
          </div>
        </section>

        <div id="contact-error" class="hidden bg-red-50 border border-red-200 px-4 py-3 text-sm font-body text-red-700 mt-6"></div>
        <div id="contact-success" class="hidden bg-green-50 border border-green-200 px-4 py-3 text-sm font-body text-green-700 mt-6">Gegevens opgeslagen.</div>

        <div class="flex gap-4 pt-6">
          <button type="submit" id="contact-save-btn" class="btn-premium text-[10px]">Gegevens Opslaan</button>
          <a href="/admin/instellingen" class="border border-champagne px-8 py-3 text-[10px] tracking-widest uppercase font-body text-taupe hover:border-charcoal hover:text-charcoal transition-colors">Terug</a>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  // --- Logo upload ---
  const fileInput = document.getElementById('logo-file-input') as HTMLInputElement;
  const fileNameEl = document.getElementById('logo-file-name')!;
  const uploadError = document.getElementById('logo-upload-error')!;
  const uploadSuccess = document.getElementById('logo-upload-success')!;
  const removeBtn = document.getElementById('remove-logo-btn')!;
  const previewEl = document.getElementById('logo-preview')!;

  fileInput?.addEventListener('change', async () => {
    const file = fileInput.files?.[0];
    if (!file) return;
    fileNameEl.textContent = file.name;
    uploadError.classList.add('hidden');
    uploadSuccess.classList.add('hidden');

    const fd = new FormData();
    fd.append('logo', file);

    fileNameEl.textContent = 'Bezig met uploaden…';
    try {
      const res = await fetch('/api/admin/settings/logo', { method: 'POST', body: fd });
      const json = await res.json();
      if (res.ok) {
        // Update preview
        if (previewEl.tagName === 'IMG') {
          (previewEl as HTMLImageElement).src = json.url;
        } else {
          const img = document.createElement('img');
          img.id = 'logo-preview';
          img.src = json.url;
          img.alt = 'Huidig logo';
          img.className = 'h-16 object-contain border border-champagne p-2 bg-white';
          previewEl.replaceWith(img);
        }
        removeBtn.classList.remove('hidden');
        uploadSuccess.classList.remove('hidden');
        fileNameEl.textContent = 'Geen bestand gekozen';
        fileInput.value = '';
      } else {
        uploadError.textContent = json.error ?? 'Upload mislukt';
        uploadError.classList.remove('hidden');
        fileNameEl.textContent = 'Geen bestand gekozen';
      }
    } catch {
      uploadError.textContent = 'Netwerkfout. Probeer opnieuw.';
      uploadError.classList.remove('hidden');
      fileNameEl.textContent = 'Geen bestand gekozen';
    }
  });

  removeBtn?.addEventListener('click', async () => {
    if (!confirm('Logo verwijderen?')) return;
    uploadError.classList.add('hidden');
    uploadSuccess.classList.add('hidden');
    try {
      const res = await fetch('/api/admin/settings/logo', { method: 'DELETE' });
      if (res.ok) {
        const placeholder = document.createElement('div');
        placeholder.id = 'logo-preview';
        placeholder.className = 'h-16 w-40 border border-dashed border-champagne flex items-center justify-center bg-linen';
        placeholder.innerHTML = '<span class="text-[10px] uppercase tracking-widest font-body text-taupe">Geen logo</span>';
        document.getElementById('logo-preview')?.replaceWith(placeholder);
        removeBtn.classList.add('hidden');
      }
    } catch {
      uploadError.textContent = 'Verwijderen mislukt. Probeer opnieuw.';
      uploadError.classList.remove('hidden');
    }
  });

  // --- Contact form ---
  const contactForm = document.getElementById('contact-form') as HTMLFormElement;
  const contactSaveBtn = document.getElementById('contact-save-btn') as HTMLButtonElement;
  const contactError = document.getElementById('contact-error')!;
  const contactSuccess = document.getElementById('contact-success')!;

  contactForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    contactError.classList.add('hidden');
    contactSuccess.classList.add('hidden');
    contactSaveBtn.textContent = 'Bezig…';
    contactSaveBtn.disabled = true;

    const fd = new FormData(contactForm);
    const contact_info: Record<string, string> = {};
    for (const [key, value] of fd.entries()) {
      contact_info[key] = value as string;
    }

    try {
      const res = await fetch('/api/admin/settings', {
        method: 'PUT',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ contact_info }),
      });
      if (res.ok) {
        contactSuccess.classList.remove('hidden');
      } else {
        const err = await res.json();
        contactError.textContent = 'Fout: ' + (err.error ?? 'Onbekend');
        contactError.classList.remove('hidden');
      }
    } catch {
      contactError.textContent = 'Netwerkfout. Probeer opnieuw.';
      contactError.classList.remove('hidden');
    } finally {
      contactSaveBtn.textContent = 'Gegevens Opslaan';
      contactSaveBtn.disabled = false;
    }
  });
</script>
