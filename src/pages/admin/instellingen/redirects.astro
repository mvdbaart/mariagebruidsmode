---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getServiceRoleClient } from '../../../lib/serverAuth';

const supabase = getServiceRoleClient();
const [
  { data: redirects },
  { count: suggestionCount },
  { count: log404Count },
] = await Promise.all([
  supabase.from('redirects').select('*').order('created_at', { ascending: false }),
  supabase.from('redirect_suggestions').select('id', { count: 'exact', head: true }).eq('status', 'pending'),
  supabase.from('redirect_404_log').select('id', { count: 'exact', head: true }),
]);

const total = redirects?.length ?? 0;
const active = redirects?.filter((r: any) => r.is_active).length ?? 0;
const pendingSuggestions = suggestionCount ?? 0;
const total404 = log404Count ?? 0;
---

<AdminLayout title="Redirects — Instellingen">
  <div class="pt-8 pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6 max-w-6xl">
      <nav class="mb-10 flex items-center gap-3 text-[10px] tracking-[0.2em] uppercase text-taupe font-body">
        <a href="/admin" class="hover:text-charcoal transition-colors">Dashboard</a>
        <span class="text-champagne">›</span>
        <a href="/admin/instellingen" class="hover:text-charcoal transition-colors">Instellingen</a>
        <span class="text-champagne">›</span>
        <span class="text-charcoal">Redirects</span>
      </nav>

      <div class="mb-10 flex items-end justify-between flex-wrap gap-4">
        <div>
          <p class="text-[10px] tracking-[0.3em] uppercase text-blush-deep font-body mb-2">Instellingen</p>
          <h1 class="font-display font-normal text-charcoal text-4xl leading-tight">
            URL <em class="font-normal italic text-taupe">Redirects</em>
          </h1>
        </div>
        <div class="flex flex-wrap gap-6 text-xs font-body text-taupe">
          <span><span id="stat-total" class="text-charcoal font-medium text-base">{total}</span> totaal</span>
          <span><span id="stat-active" class="text-green-600 font-medium text-base">{active}</span> actief</span>
          {pendingSuggestions > 0 && (
            <span><span class="text-amber-600 font-medium text-base">{pendingSuggestions}</span> suggesties</span>
          )}
          {total404 > 0 && (
            <span><span class="text-red-500 font-medium text-base">{total404}</span> 404-paden</span>
          )}
        </div>
      </div>

      <!-- Tab navigatie -->
      <div class="flex gap-0 border-b border-champagne mb-8">
        <button class="tab-btn active-tab px-6 py-3 text-[10px] tracking-[0.2em] uppercase font-body border-b-2 border-charcoal text-charcoal" data-tab="redirects">
          Redirects
        </button>
        <button class="tab-btn px-6 py-3 text-[10px] tracking-[0.2em] uppercase font-body border-b-2 border-transparent text-taupe hover:text-charcoal transition-colors" data-tab="suggesties">
          Suggesties {pendingSuggestions > 0 ? `(${pendingSuggestions})` : ''}
        </button>
        <button class="tab-btn px-6 py-3 text-[10px] tracking-[0.2em] uppercase font-body border-b-2 border-transparent text-taupe hover:text-charcoal transition-colors" data-tab="monitor">
          404 Monitor {total404 > 0 ? `(${total404})` : ''}
        </button>
        <button class="tab-btn px-6 py-3 text-[10px] tracking-[0.2em] uppercase font-body border-b-2 border-transparent text-taupe hover:text-charcoal transition-colors" data-tab="import">
          Sitemap import
        </button>
      </div>

      <!-- TAB: Redirects -->
      <div id="tab-panel-redirects" class="tab-panel">

      <!-- Formulier -->
      <section class="bg-white border border-champagne p-8 shadow-soft mb-8">
        <h2 id="form-title" class="text-[10px] uppercase tracking-[0.3em] text-taupe font-body font-medium border-b border-champagne pb-4 mb-8">
          Redirect toevoegen
        </h2>
        <div id="form-error" class="hidden mb-6 bg-red-50 border border-red-200 px-4 py-3 text-sm font-body text-red-700"></div>
        <div id="form-success" class="hidden mb-6 bg-green-50 border border-green-200 px-4 py-3 text-sm font-body text-green-700"></div>

        <form id="redirect-form" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <input type="hidden" id="edit-id" value="" />

          <div>
            <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Van-pad <span class="text-red-400">*</span></label>
            <input id="f-from" type="text" placeholder="/oud-pad"
              class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors" />
            <p class="mt-1 text-[10px] font-body text-taupe">Moet beginnen met /</p>
          </div>

          <div>
            <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Naar-pad <span class="text-red-400">*</span></label>
            <input id="f-to" type="text" placeholder="/nieuw-pad"
              class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors" />
          </div>

          <div>
            <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Notitie</label>
            <input id="f-note" type="text" placeholder="Optionele omschrijving"
              class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors" />
          </div>

          <div>
            <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Status</label>
            <select id="f-status"
              class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors">
              <option value="301">301 — Permanent</option>
              <option value="302">302 — Tijdelijk</option>
            </select>
          </div>

          <div>
            <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Type</label>
            <select id="f-type"
              class="w-full border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors">
              <option value="exact">Exact</option>
              <option value="prefix">Prefix</option>
            </select>
          </div>

          <div class="flex items-end gap-3 pb-1">
            <label class="flex items-center gap-2 cursor-pointer">
              <input id="f-active" type="checkbox" checked class="w-4 h-4 accent-blush-deep" />
              <span class="text-xs font-body text-charcoal">Actief</span>
            </label>
          </div>

          <div class="lg:col-span-3 flex gap-4 pt-2">
            <button type="submit" id="form-submit-btn" class="btn-premium text-[10px]">Opslaan</button>
            <button type="button" id="form-cancel-btn" class="hidden border border-champagne px-8 py-3 text-[10px] tracking-widest uppercase font-body text-taupe hover:border-charcoal hover:text-charcoal transition-colors">
              Annuleren
            </button>
          </div>
        </form>
      </section>

      <!-- Tabel -->
      <section class="bg-white border border-champagne shadow-soft">
        <div class="overflow-x-auto">
          <table class="w-full text-xs font-body">
            <thead>
              <tr class="border-b border-champagne">
                <th class="text-left text-[10px] tracking-widest uppercase text-taupe font-body font-normal px-6 py-4">Van</th>
                <th class="text-left text-[10px] tracking-widest uppercase text-taupe font-body font-normal px-4 py-4">Naar</th>
                <th class="text-left text-[10px] tracking-widest uppercase text-taupe font-body font-normal px-4 py-4">Type</th>
                <th class="text-left text-[10px] tracking-widest uppercase text-taupe font-body font-normal px-4 py-4">Status</th>
                <th class="text-left text-[10px] tracking-widest uppercase text-taupe font-body font-normal px-4 py-4">Notitie</th>
                <th class="text-center text-[10px] tracking-widest uppercase text-taupe font-body font-normal px-4 py-4">Actief</th>
                <th class="px-4 py-4"></th>
              </tr>
            </thead>
            <tbody id="redirects-tbody">
              {redirects?.map((r: any) => (
                <tr class="border-b border-champagne/50 hover:bg-linen/30 transition-colors redirect-row" data-id={r.id}>
                  <td class="px-6 py-4 font-mono text-charcoal">{r.from_path}</td>
                  <td class="px-4 py-4 font-mono text-taupe">{r.to_path}</td>
                  <td class="px-4 py-4 text-taupe">{r.match_type}</td>
                  <td class="px-4 py-4">
                    <span class={`inline-block px-2 py-0.5 text-[9px] tracking-widest uppercase font-body ${r.status_code === 301 ? 'bg-linen text-taupe' : 'bg-champagne/30 text-taupe'}`}>
                      {r.status_code}
                    </span>
                  </td>
                  <td class="px-4 py-4 text-taupe">{r.note ?? '—'}</td>
                  <td class="px-4 py-4 text-center">
                    <button
                      class="toggle-active-btn w-8 h-4 rounded-full transition-colors relative"
                      data-id={r.id}
                      data-active={r.is_active ? 'true' : 'false'}
                      title={r.is_active ? 'Deactiveren' : 'Activeren'}
                    >
                    </button>
                  </td>
                  <td class="px-4 py-4">
                    <div class="flex items-center gap-4 justify-end">
                      <button
                        class="edit-btn text-[9px] tracking-widest uppercase font-body text-taupe hover:text-charcoal transition-colors"
                        data-id={r.id}
                        data-from={r.from_path}
                        data-to={r.to_path}
                        data-status={r.status_code}
                        data-type={r.match_type}
                        data-note={r.note ?? ''}
                        data-active={r.is_active ? 'true' : 'false'}
                      >Bewerken</button>
                      <button
                        class="delete-btn text-[9px] tracking-widest uppercase font-body text-red-300 hover:text-red-600 transition-colors"
                        data-id={r.id}
                      >Verwijder</button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          {(!redirects || redirects.length === 0) && (
            <div class="px-6 py-12 text-center text-sm font-body text-taupe">Geen redirects gevonden.</div>
          )}
        </div>
      </section>

      </div>{/* end tab-panel-redirects */}

      <!-- TAB: Suggesties -->
      <div id="tab-panel-suggesties" class="tab-panel hidden">
        <div class="bg-white border border-champagne shadow-soft">
          <div class="flex items-center justify-between px-6 py-4 border-b border-champagne">
            <p class="text-[10px] tracking-[0.3em] uppercase text-taupe font-body">
              Wachtend op review — hoge confidence worden automatisch als redirect opgenomen.
            </p>
            <div class="flex gap-3">
              <select id="sug-filter" class="text-xs font-body border-0 border-b border-champagne bg-transparent py-1 focus:outline-none text-charcoal">
                <option value="pending">Pending</option>
                <option value="approved">Goedgekeurd</option>
                <option value="rejected">Afgewezen</option>
                <option value="all">Alles</option>
              </select>
            </div>
          </div>
          <div id="sug-loading" class="px-6 py-12 text-center text-sm font-body text-taupe">Laden…</div>
          <div id="sug-empty" class="hidden px-6 py-12 text-center text-sm font-body text-taupe">Geen suggesties gevonden.</div>
          <div class="overflow-x-auto">
            <table class="w-full text-xs font-body" id="sug-table">
              <thead id="sug-thead" class="hidden">
                <tr class="border-b border-champagne">
                  <th class="text-left text-[10px] tracking-widest uppercase text-taupe font-normal px-6 py-4">Oud pad</th>
                  <th class="text-left text-[10px] tracking-widest uppercase text-taupe font-normal px-4 py-4">Suggestie</th>
                  <th class="text-left text-[10px] tracking-widest uppercase text-taupe font-normal px-4 py-4">Conf.</th>
                  <th class="text-left text-[10px] tracking-widest uppercase text-taupe font-normal px-4 py-4">Bron</th>
                  <th class="text-left text-[10px] tracking-widest uppercase text-taupe font-normal px-4 py-4">Status</th>
                  <th class="px-4 py-4"></th>
                </tr>
              </thead>
              <tbody id="sug-tbody"></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- TAB: 404 Monitor -->
      <div id="tab-panel-monitor" class="tab-panel hidden">
        <div class="bg-white border border-champagne shadow-soft">
          <div class="flex items-center justify-between px-6 py-4 border-b border-champagne">
            <p class="text-[10px] tracking-[0.3em] uppercase text-taupe font-body">
              Paden die een 404 hebben gegenereerd — gesorteerd op frequentie.
            </p>
            <button id="log-clear-btn" class="text-[9px] tracking-widest uppercase font-body text-red-300 hover:text-red-600 transition-colors">
              Log wissen
            </button>
          </div>
          <div id="log-loading" class="px-6 py-12 text-center text-sm font-body text-taupe">Laden…</div>
          <div id="log-empty" class="hidden px-6 py-12 text-center text-sm font-body text-taupe">Geen 404-entries gevonden.</div>
          <div class="overflow-x-auto">
            <table class="w-full text-xs font-body">
              <thead id="log-thead" class="hidden">
                <tr class="border-b border-champagne">
                  <th class="text-left text-[10px] tracking-widest uppercase text-taupe font-normal px-6 py-4">Pad</th>
                  <th class="text-left text-[10px] tracking-widest uppercase text-taupe font-normal px-4 py-4">Hits</th>
                  <th class="text-left text-[10px] tracking-widest uppercase text-taupe font-normal px-4 py-4">Laatste hit</th>
                  <th class="text-left text-[10px] tracking-widest uppercase text-taupe font-normal px-4 py-4">Suggestie</th>
                  <th class="text-left text-[10px] tracking-widest uppercase text-taupe font-normal px-4 py-4">Referer</th>
                </tr>
              </thead>
              <tbody id="log-tbody"></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- TAB: Sitemap import -->
      <div id="tab-panel-import" class="tab-panel hidden">
        <div class="bg-white border border-champagne p-8 shadow-soft">
          <h2 class="text-[10px] uppercase tracking-[0.3em] text-taupe font-body font-medium border-b border-champagne pb-4 mb-8">
            Yoast sitemap importeren
          </h2>
          <p class="text-sm font-body text-taupe mb-6 leading-relaxed">
            Haalt alle URLs op uit de sitemap van de oude WordPress-site en koppelt ze aan routes in de nieuwe site.
            URL's met een hoge confidence (≥ 85%) worden direct als actieve redirect opgeslagen.
            Lager-gerangschikte URL's verschijnen als suggesties voor handmatige review.
          </p>
          <div class="mb-6">
            <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">
              Sitemap index URL
            </label>
            <input
              id="import-url"
              type="url"
              value="https://www.mariagebruidsmode.nl/sitemap_index.xml"
              class="w-full max-w-xl border-0 border-b border-champagne bg-transparent py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors"
            />
          </div>
          <div id="import-msg" class="hidden mb-6 px-4 py-3 text-sm font-body"></div>
          <button id="import-btn" class="btn-premium text-[10px]">Import starten</button>
          <div id="import-result" class="hidden mt-6 grid grid-cols-2 sm:grid-cols-4 gap-4">
            <div class="border border-champagne p-4 text-center">
              <div id="ir-total" class="text-2xl font-display text-charcoal">0</div>
              <div class="text-[10px] tracking-widest uppercase font-body text-taupe mt-1">Totaal</div>
            </div>
            <div class="border border-champagne p-4 text-center">
              <div id="ir-approved" class="text-2xl font-display text-green-600">0</div>
              <div class="text-[10px] tracking-widest uppercase font-body text-taupe mt-1">Goedgekeurd</div>
            </div>
            <div class="border border-champagne p-4 text-center">
              <div id="ir-suggestions" class="text-2xl font-display text-amber-600">0</div>
              <div class="text-[10px] tracking-widest uppercase font-body text-taupe mt-1">Suggesties</div>
            </div>
            <div class="border border-champagne p-4 text-center">
              <div id="ir-skipped" class="text-2xl font-display text-taupe">0</div>
              <div class="text-[10px] tracking-widest uppercase font-body text-taupe mt-1">Overgeslagen</div>
            </div>
          </div>
          <div id="import-errors" class="hidden mt-4 text-xs font-mono text-red-600 whitespace-pre-wrap"></div>
        </div>
      </div>

    </div>
  </div>
</AdminLayout>

<script>
  // ---- State ----
  let editingId: string | null = null;

  const form = document.getElementById('redirect-form') as HTMLFormElement;
  const formTitle = document.getElementById('form-title')!;
  const formError = document.getElementById('form-error')!;
  const formSuccess = document.getElementById('form-success')!;
  const submitBtn = document.getElementById('form-submit-btn') as HTMLButtonElement;
  const cancelBtn = document.getElementById('form-cancel-btn') as HTMLButtonElement;
  const editIdInput = document.getElementById('edit-id') as HTMLInputElement;
  const fFrom = document.getElementById('f-from') as HTMLInputElement;
  const fTo = document.getElementById('f-to') as HTMLInputElement;
  const fStatus = document.getElementById('f-status') as HTMLSelectElement;
  const fType = document.getElementById('f-type') as HTMLSelectElement;
  const fNote = document.getElementById('f-note') as HTMLInputElement;
  const fActive = document.getElementById('f-active') as HTMLInputElement;

  // ---- Helpers ----
  function showMsg(el: HTMLElement, msg: string) {
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  function resetForm() {
    editingId = null;
    editIdInput.value = '';
    form.reset();
    fActive.checked = true;
    formTitle.textContent = 'Redirect toevoegen';
    submitBtn.textContent = 'Opslaan';
    cancelBtn.classList.add('hidden');
    formError.classList.add('hidden');
    formSuccess.classList.add('hidden');
  }

  function updateStats() {
    const rows = document.querySelectorAll('.redirect-row');
    const activeRows = document.querySelectorAll('.redirect-row .toggle-active-btn[data-active="true"]');
    const statTotal = document.getElementById('stat-total');
    const statActive = document.getElementById('stat-active');
    if (statTotal) statTotal.textContent = String(rows.length);
    if (statActive) statActive.textContent = String(activeRows.length);
  }

  function applyToggleStyle(btn: HTMLButtonElement) {
    const isActive = btn.dataset.active === 'true';
    btn.className = `toggle-active-btn w-8 h-4 rounded-full transition-colors relative ${isActive ? 'bg-green-400' : 'bg-champagne'}`;
    btn.title = isActive ? 'Deactiveren' : 'Activeren';
  }

  function buildRow(r: any): string {
    const statusClass = r.status_code === 301 ? 'bg-linen text-taupe' : 'bg-champagne/30 text-taupe';
    const toggleClass = r.is_active ? 'bg-green-400' : 'bg-champagne';
    return `
      <tr class="border-b border-champagne/50 hover:bg-linen/30 transition-colors redirect-row" data-id="${r.id}">
        <td class="px-6 py-4 font-mono text-charcoal">${escHtml(r.from_path)}</td>
        <td class="px-4 py-4 font-mono text-taupe">${escHtml(r.to_path)}</td>
        <td class="px-4 py-4 text-taupe">${escHtml(r.match_type)}</td>
        <td class="px-4 py-4">
          <span class="inline-block px-2 py-0.5 text-[9px] tracking-widest uppercase font-body ${statusClass}">${r.status_code}</span>
        </td>
        <td class="px-4 py-4 text-taupe">${r.note ? escHtml(r.note) : '—'}</td>
        <td class="px-4 py-4 text-center">
          <button class="toggle-active-btn w-8 h-4 rounded-full transition-colors relative ${toggleClass}"
            data-id="${r.id}" data-active="${r.is_active}" title="${r.is_active ? 'Deactiveren' : 'Activeren'}"></button>
        </td>
        <td class="px-4 py-4">
          <div class="flex items-center gap-4 justify-end">
            <button class="edit-btn text-[9px] tracking-widest uppercase font-body text-taupe hover:text-charcoal transition-colors"
              data-id="${r.id}" data-from="${escAttr(r.from_path)}" data-to="${escAttr(r.to_path)}"
              data-status="${r.status_code}" data-type="${r.match_type}"
              data-note="${escAttr(r.note ?? '')}" data-active="${r.is_active}">Bewerken</button>
            <button class="delete-btn text-[9px] tracking-widest uppercase font-body text-red-300 hover:text-red-600 transition-colors"
              data-id="${r.id}">Verwijder</button>
          </div>
        </td>
      </tr>`;
  }

  function escHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }
  function escAttr(s: string): string {
    return s.replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  // ---- Tab switching ----
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const tabPanels = document.querySelectorAll<HTMLElement>('.tab-panel');
  let suggestiesLoaded = false;
  let monitorLoaded = false;

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab!;
      tabBtns.forEach((b) => {
        b.classList.remove('active-tab', 'border-charcoal', 'text-charcoal');
        b.classList.add('border-transparent', 'text-taupe');
      });
      btn.classList.add('active-tab', 'border-charcoal', 'text-charcoal');
      btn.classList.remove('border-transparent', 'text-taupe');
      tabPanels.forEach((p) => p.classList.add('hidden'));
      const panel = document.getElementById(`tab-panel-${tab}`);
      if (panel) panel.classList.remove('hidden');

      if (tab === 'suggesties' && !suggestiesLoaded) { loadSuggesties(); suggestiesLoaded = true; }
      if (tab === 'monitor' && !monitorLoaded) { loadLog404(); monitorLoaded = true; }
    });
  });

  // ---- Suggesties ----
  async function loadSuggesties(status = (document.getElementById('sug-filter') as HTMLSelectElement)?.value ?? 'pending') {
    const loading = document.getElementById('sug-loading')!;
    const empty = document.getElementById('sug-empty')!;
    const thead = document.getElementById('sug-thead')!;
    const tbody = document.getElementById('sug-tbody')!;
    loading.classList.remove('hidden');
    empty.classList.add('hidden');
    thead.classList.add('hidden');
    tbody.innerHTML = '';

    const res = await fetch(`/api/admin/redirect-suggestions?status=${status}`);
    const data: any[] = await res.json();
    loading.classList.add('hidden');

    if (!data.length) { empty.classList.remove('hidden'); return; }
    thead.classList.remove('hidden');

    for (const s of data) {
      const confColor = s.confidence >= 0.85 ? 'text-green-600' : s.confidence >= 0.65 ? 'text-amber-600' : 'text-red-500';
      const statusLabel: Record<string, string> = { pending: 'Wachtend', approved: 'Goedgekeurd', rejected: 'Afgewezen' };
      const row = document.createElement('tr');
      row.className = 'border-b border-champagne/50 hover:bg-linen/30 transition-colors';
      row.dataset.id = s.id;
      row.innerHTML = `
        <td class="px-6 py-4 font-mono text-charcoal text-xs">${escHtml(s.from_path)}</td>
        <td class="px-4 py-4 font-mono text-taupe text-xs">${escHtml(s.to_path)}</td>
        <td class="px-4 py-4 font-mono ${confColor} font-medium">${(s.confidence * 100).toFixed(0)}%</td>
        <td class="px-4 py-4 text-taupe">${escHtml(s.source)}</td>
        <td class="px-4 py-4 text-taupe">${statusLabel[s.status] ?? s.status}</td>
        <td class="px-4 py-4">
          ${s.status === 'pending' ? `
            <div class="flex gap-3 justify-end">
              <button class="sug-approve text-[9px] tracking-widest uppercase font-body text-green-600 hover:text-green-800 transition-colors" data-id="${s.id}">Goedkeuren</button>
              <button class="sug-reject text-[9px] tracking-widest uppercase font-body text-red-300 hover:text-red-600 transition-colors" data-id="${s.id}">Afwijzen</button>
            </div>` : ''}
        </td>`;
      tbody.appendChild(row);
    }
  }

  document.getElementById('sug-filter')?.addEventListener('change', (e) => {
    suggestiesLoaded = false;
    loadSuggesties((e.target as HTMLSelectElement).value);
    suggestiesLoaded = true;
  });

  document.addEventListener('click', async (e) => {
    const t = e.target as HTMLElement;
    const approveBtn = t.closest<HTMLButtonElement>('.sug-approve');
    const rejectBtn = t.closest<HTMLButtonElement>('.sug-reject');
    const btn = approveBtn ?? rejectBtn;
    if (!btn) return;
    const id = btn.dataset.id!;
    const action = approveBtn ? 'approve' : 'reject';
    btn.disabled = true;
    btn.textContent = '…';
    const res = await fetch(`/api/admin/redirect-suggestions/${id}`, {
      method: 'PUT',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ action }),
    });
    if (res.ok) {
      const row = document.querySelector(`[data-id="${id}"]`);
      row?.remove();
    } else {
      btn.disabled = false;
      btn.textContent = action === 'approve' ? 'Goedkeuren' : 'Afwijzen';
    }
  });

  // ---- 404 Monitor ----
  async function loadLog404() {
    const loading = document.getElementById('log-loading')!;
    const empty = document.getElementById('log-empty')!;
    const thead = document.getElementById('log-thead')!;
    const tbody = document.getElementById('log-tbody')!;
    loading.classList.remove('hidden');
    empty.classList.add('hidden');
    thead.classList.add('hidden');
    tbody.innerHTML = '';

    const res = await fetch('/api/admin/404-log?limit=100');
    const { data }: { data: any[] } = await res.json();
    loading.classList.add('hidden');

    if (!data?.length) { empty.classList.remove('hidden'); return; }
    thead.classList.remove('hidden');

    for (const entry of data) {
      const bestSug = Array.isArray(entry.suggestions) && entry.suggestions.length
        ? entry.suggestions[0]
        : null;
      const dateStr = new Date(entry.last_seen_at).toLocaleDateString('nl-NL', { day: '2-digit', month: '2-digit', year: 'numeric' });
      const row = document.createElement('tr');
      row.className = 'border-b border-champagne/50 hover:bg-linen/30 transition-colors';
      row.innerHTML = `
        <td class="px-6 py-4 font-mono text-charcoal text-xs">${escHtml(entry.path)}${entry.query_string ? `<span class="text-taupe">${escHtml(entry.query_string)}</span>` : ''}</td>
        <td class="px-4 py-4 text-center font-medium text-red-500">${entry.hit_count}</td>
        <td class="px-4 py-4 text-taupe">${dateStr}</td>
        <td class="px-4 py-4 font-mono text-taupe text-xs">${bestSug ? `${escHtml(bestSug.path)} <span class="text-[9px]">(${Math.round(bestSug.confidence * 100)}%)</span>` : '—'}</td>
        <td class="px-4 py-4 text-taupe text-xs truncate max-w-xs">${entry.referer ? escHtml(entry.referer) : '—'}</td>`;
      tbody.appendChild(row);
    }
  }

  document.getElementById('log-clear-btn')?.addEventListener('click', async () => {
    if (!confirm('Weet je zeker dat je het volledige 404-log wilt wissen?')) return;
    const res = await fetch('/api/admin/404-log', { method: 'DELETE' });
    if (res.ok || res.status === 204) {
      document.getElementById('log-tbody')!.innerHTML = '';
      document.getElementById('log-thead')!.classList.add('hidden');
      document.getElementById('log-empty')!.classList.remove('hidden');
    }
  });

  // ---- Sitemap import ----
  document.getElementById('import-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('import-btn') as HTMLButtonElement;
    const msg = document.getElementById('import-msg')!;
    const result = document.getElementById('import-result')!;
    const errBox = document.getElementById('import-errors')!;
    const urlInput = document.getElementById('import-url') as HTMLInputElement;

    btn.disabled = true;
    btn.textContent = 'Importeren…';
    msg.className = 'hidden mb-6 px-4 py-3 text-sm font-body';
    result.classList.add('hidden');
    errBox.classList.add('hidden');

    try {
      const res = await fetch('/api/admin/sitemap-import', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ url: urlInput.value }),
      });
      const data = await res.json();

      if (!res.ok) {
        msg.textContent = data.error ?? 'Import mislukt.';
        msg.className = 'mb-6 px-4 py-3 text-sm font-body bg-red-50 border border-red-200 text-red-700';
        return;
      }

      document.getElementById('ir-total')!.textContent = String(data.total);
      document.getElementById('ir-approved')!.textContent = String(data.approved);
      document.getElementById('ir-suggestions')!.textContent = String(data.suggestions);
      document.getElementById('ir-skipped')!.textContent = String(data.skipped);
      result.classList.remove('hidden');

      if (data.errors?.length) {
        errBox.textContent = data.errors.join('\n');
        errBox.classList.remove('hidden');
      }

      msg.textContent = `Import voltooid: ${data.approved} redirects toegevoegd, ${data.suggestions} suggesties opgeslagen.`;
      msg.className = 'mb-6 px-4 py-3 text-sm font-body bg-green-50 border border-green-200 text-green-700';

      // Invalidate caches for suggesties tab
      suggestiesLoaded = false;
    } catch {
      msg.textContent = 'Netwerkfout. Probeer opnieuw.';
      msg.className = 'mb-6 px-4 py-3 text-sm font-body bg-red-50 border border-red-200 text-red-700';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Import starten';
    }
  });

  // ---- Init toggle styles ----
  document.querySelectorAll<HTMLButtonElement>('.toggle-active-btn').forEach(applyToggleStyle);
  updateStats();

  // ---- Cancel ----
  cancelBtn.addEventListener('click', resetForm);

  // ---- Form submit (create / update) ----
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    formError.classList.add('hidden');
    formSuccess.classList.add('hidden');

    const from_path = fFrom.value.trim();
    if (!from_path.startsWith('/')) {
      showMsg(formError, 'Van-pad moet beginnen met /');
      return;
    }
    const payload = {
      from_path,
      to_path: fTo.value.trim(),
      status_code: Number(fStatus.value),
      match_type: fType.value,
      note: fNote.value.trim() || null,
      is_active: fActive.checked,
    };

    submitBtn.disabled = true;
    submitBtn.textContent = 'Bezig…';

    try {
      const url = editingId ? `/api/admin/redirects/${editingId}` : '/api/admin/redirects';
      const method = editingId ? 'PUT' : 'POST';
      const res = await fetch(url, {
        method,
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const json = await res.json();
      if (!res.ok) {
        showMsg(formError, json.error ?? 'Onbekende fout');
        return;
      }

      if (editingId) {
        // Update existing row
        const row = document.querySelector(`.redirect-row[data-id="${editingId}"]`);
        if (row) {
          const tmp = document.createElement('tbody');
          tmp.innerHTML = buildRow(json);
          const newRow = tmp.firstElementChild!;
          row.replaceWith(newRow);
          const toggleBtn = newRow.querySelector<HTMLButtonElement>('.toggle-active-btn');
          if (toggleBtn) applyToggleStyle(toggleBtn);
        }
        showMsg(formSuccess, 'Redirect bijgewerkt.');
      } else {
        // Prepend new row
        const tbody = document.getElementById('redirects-tbody')!;
        const tmp = document.createElement('tbody');
        tmp.innerHTML = buildRow(json);
        const newRow = tmp.firstElementChild!;
        tbody.prepend(newRow);
        const toggleBtn = newRow.querySelector<HTMLButtonElement>('.toggle-active-btn');
        if (toggleBtn) applyToggleStyle(toggleBtn);
        showMsg(formSuccess, 'Redirect aangemaakt.');
      }

      updateStats();
      resetForm();
    } catch {
      showMsg(formError, 'Netwerkfout. Probeer opnieuw.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Opslaan';
    }
  });

  // ---- Delegated: edit, delete, toggle ----
  document.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement;

    // Edit
    const editBtn = target.closest<HTMLButtonElement>('.edit-btn');
    if (editBtn) {
      const d = editBtn.dataset;
      editingId = d.id!;
      editIdInput.value = editingId;
      fFrom.value = d.from!;
      fTo.value = d.to!;
      fStatus.value = d.status!;
      fType.value = d.type!;
      fNote.value = d.note ?? '';
      fActive.checked = d.active === 'true';
      formTitle.textContent = 'Redirect bewerken';
      submitBtn.textContent = 'Bijwerken';
      cancelBtn.classList.remove('hidden');
      formError.classList.add('hidden');
      formSuccess.classList.add('hidden');
      form.scrollIntoView({ behavior: 'smooth', block: 'start' });
      return;
    }

    // Delete
    const deleteBtn = target.closest<HTMLButtonElement>('.delete-btn');
    if (deleteBtn) {
      if (!confirm('Redirect verwijderen?')) return;
      const id = deleteBtn.dataset.id!;
      try {
        const res = await fetch(`/api/admin/redirects/${id}`, { method: 'DELETE' });
        if (res.ok || res.status === 204) {
          document.querySelector(`.redirect-row[data-id="${id}"]`)?.remove();
          updateStats();
          if (editingId === id) resetForm();
        }
      } catch {
        alert('Verwijderen mislukt. Probeer opnieuw.');
      }
      return;
    }

    // Toggle active
    const toggleBtn = target.closest<HTMLButtonElement>('.toggle-active-btn');
    if (toggleBtn) {
      const id = toggleBtn.dataset.id!;
      const newActive = toggleBtn.dataset.active !== 'true';
      try {
        const res = await fetch(`/api/admin/redirects/${id}`, {
          method: 'PUT',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ is_active: newActive }),
        });
        if (res.ok) {
          toggleBtn.dataset.active = String(newActive);
          applyToggleStyle(toggleBtn);
          updateStats();
        }
      } catch {
        alert('Bijwerken mislukt. Probeer opnieuw.');
      }
    }
  });
</script>
