---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getServiceRoleClient } from '../../../lib/serverAuth';
import { createClient } from '@supabase/supabase-js';
import { HOMEPAGE_SECTION_DEFINITIONS, normalizeHomepageSettings } from '../../../lib/homepageSections';
import { normalizeHomepageCategorySliderItems } from '../../../lib/homepageCategorySlider';

const supabase = getServiceRoleClient();
const [
  { data: slides },
  { data: settings },
] = await Promise.all([
  supabase.from('hero_slides').select('*').order('sort_order', { ascending: true }),
  supabase.from('site_settings').select('homepage').eq('id', 'current').single(),
]);

const hp = normalizeHomepageSettings(settings?.homepage ?? {});
const categorySliderItems = normalizeHomepageCategorySliderItems(hp.category_slider_items);
const sectionDefs = HOMEPAGE_SECTION_DEFINITIONS;
const orderedSectionDefs = hp.sections_order
  .map((id) => sectionDefs.find((section) => section.id === id))
  .filter(Boolean);

let sliderPublicReadBlocked = false;
let sliderHealthMessage = '';

const publicSupabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const publicSupabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

if (!publicSupabaseUrl || !publicSupabaseAnonKey) {
  sliderPublicReadBlocked = true;
  sliderHealthMessage = 'PUBLIC_SUPABASE_URL of PUBLIC_SUPABASE_ANON_KEY ontbreekt.';
} else {
  const publicSupabase = createClient(publicSupabaseUrl, publicSupabaseAnonKey, {
    auth: { persistSession: false, autoRefreshToken: false },
  });
  const { error: publicReadError } = await publicSupabase
    .from('hero_slides')
    .select('id')
    .eq('is_active', true)
    .limit(1);

  if (publicReadError) {
    sliderPublicReadBlocked = true;
    sliderHealthMessage = publicReadError.message;
  }
}
---

<AdminLayout title="Homepage Beheer">
  <div class="pt-8 pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6 max-w-5xl">

      <nav class="mb-10 flex items-center gap-3 text-[10px] tracking-[0.2em] uppercase text-taupe font-body">
        <a href="/admin" class="hover:text-charcoal transition-colors">Dashboard</a>
        <span class="text-champagne">›</span>
        <span class="text-charcoal">Homepage</span>
      </nav>

      <div class="mb-12">
        <p class="text-[10px] tracking-[0.3em] uppercase text-blush-deep font-body mb-2">Beheer</p>
        <h1 class="font-display font-normal text-charcoal text-4xl leading-tight">
          Homepage <em class="font-normal italic text-taupe">Beheer</em>
        </h1>
      </div>

      <section id="promo-banner" class="mb-14">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h2 class="text-[10px] uppercase tracking-[0.3em] text-taupe font-body font-medium">Top promo banner</h2>
            <p class="text-xs text-taupe font-body mt-1">
              Beheer de banner bovenaan de site, inclusief rotatie, sluiten en linkgedrag.
            </p>
          </div>
          <span class="text-[10px] font-body text-taupe">
            {hp.promo_banner.enabled && hp.promo_banner.messages.length > 0 ? 'Actief' : 'Uitgeschakeld'}
          </span>
        </div>

        <div class="bg-white border border-champagne p-8 shadow-soft">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            {[
              { key: 'enabled', label: 'Banner actief', type: 'boolean', value: hp.promo_banner.enabled },
              { key: 'rotation_ms', label: 'Rotatie interval (ms)', type: 'number', value: hp.promo_banner.rotation_ms, min: 2000, max: 20000 },
              { key: 'transition_ms', label: 'Overgang (ms)', type: 'number', value: hp.promo_banner.transition_ms, min: 250, max: 2000 },
              { key: 'pause_on_hover', label: 'Pauzeren bij hover', type: 'boolean', value: hp.promo_banner.pause_on_hover },
              { key: 'dismissible', label: 'Sluitbaar', type: 'boolean', value: hp.promo_banner.dismissible },
              { key: 'remember_dismissal', label: 'Sluiting onthouden', type: 'boolean', value: hp.promo_banner.remember_dismissal },
              { key: 'open_in_new_tab', label: 'Link in nieuw tabblad', type: 'boolean', value: hp.promo_banner.open_in_new_tab },
            ].map((field) => {
              const commonClass = 'w-full border border-champagne bg-white px-3 py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors';
              return (
                <div class={field.key === 'enabled' ? '' : ''}>
                  <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">{field.label}</label>
                  {field.type === 'boolean' ? (
                    <select
                      class={commonClass}
                      data-setting-field="true"
                      data-section-id="promo_banner"
                      data-field-key={field.key}
                      data-field-type={field.type}
                    >
                      <option value="true" selected={Boolean(field.value) === true}>Aan</option>
                      <option value="false" selected={Boolean(field.value) === false}>Uit</option>
                    </select>
                  ) : field.type === 'number' ? (
                    <input
                      type="number"
                      min={field.min}
                      max={field.max}
                      value={String(field.value)}
                      class={commonClass}
                      data-setting-field="true"
                      data-section-id="promo_banner"
                      data-field-key={field.key}
                      data-field-type={field.type}
                    />
                  ) : (
                    <input
                      type="text"
                      value={String(field.value)}
                      class={commonClass}
                      data-setting-field="true"
                      data-section-id="promo_banner"
                      data-field-key={field.key}
                      data-field-type={field.type}
                    />
                  )}
                </div>
              );
            })}

            <div class="md:col-span-2">
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Thema</label>
              <select
                class="w-full border border-champagne bg-white px-3 py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors"
                data-setting-field="true"
                data-section-id="promo_banner"
                data-field-key="theme"
                data-field-type="text"
              >
                <option value="charcoal" selected={hp.promo_banner.theme === 'charcoal'}>Charcoal</option>
                <option value="blush" selected={hp.promo_banner.theme === 'blush'}>Blush</option>
                <option value="champagne" selected={hp.promo_banner.theme === 'champagne'}>Champagne</option>
                <option value="ivory" selected={hp.promo_banner.theme === 'ivory'}>Ivory</option>
              </select>
            </div>

            <div class="md:col-span-2">
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Berichten, één per regel</label>
              <textarea
                rows={4}
                class="w-full border border-champagne bg-white px-3 py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors"
                placeholder="Kort promotiebericht 1&#10;Promotiebericht 2&#10;Nog een boodschap"
                data-setting-field="true"
                data-section-id="promo_banner"
                data-field-key="messages"
                data-field-type="textarea"
              >{hp.promo_banner.messages.join('\n')}</textarea>
              <p class="text-xs text-taupe font-body mt-2">
                Voeg meerdere regels toe om berichten om beurten te tonen. De weergave roteert per bericht zonder overlap.
              </p>
            </div>

            <div class="md:col-span-2">
              <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Link URL</label>
              <input
                type="url"
                value={hp.promo_banner.link_url}
                placeholder="/afspraak-maken"
                class="w-full border border-champagne bg-white px-3 py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors"
                data-setting-field="true"
                data-section-id="promo_banner"
                data-field-key="link_url"
                data-field-type="url"
              />
            </div>

            <div class="md:col-span-2 mt-4">
              <div class="flex items-center justify-between gap-4 mb-3">
                <div>
                  <p class="text-[10px] tracking-[0.2em] uppercase text-taupe font-body">Live preview</p>
                  <p class="text-xs text-taupe font-body mt-1">Deze preview gebruikt dezelfde banneropties als de siteheader.</p>
                </div>
                <span class="text-[10px] font-body text-taupe" id="promo-preview-status">
                  {hp.promo_banner.enabled ? 'Zichtbaar' : 'Verborgen'}
                </span>
              </div>

              <div id="promo-banner-preview" class="border border-champagne shadow-soft overflow-hidden">
                <div class="flex items-center justify-center px-10 py-2 min-h-[2.25rem] bg-charcoal text-warm-white relative">
                  <a id="promo-preview-link" href={hp.promo_banner.link_url || '#'} class="inline-flex items-center justify-center">
                    <span id="promo-preview-message" class="text-[10px] font-body tracking-[0.16em] uppercase transition-opacity duration-500 ease-in-out">
                      {hp.promo_banner.messages[0] || 'Voorbeeld promotiebericht'}
                    </span>
                  </a>
                  {hp.promo_banner.dismissible && (
                    <button
                      type="button"
                      aria-label="Preview sluiten"
                      class="absolute right-3 top-1/2 -translate-y-1/2 text-warm-white/60 hover:text-warm-white transition-colors"
                      id="promo-preview-close"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </button>
                  )}
                </div>
                <div class="bg-white px-4 py-3 border-t border-champagne grid grid-cols-2 md:grid-cols-4 gap-3 text-[10px] tracking-[0.15em] uppercase font-body text-taupe">
                  <div><span class="block text-charcoal/60">Thema</span><span id="promo-preview-theme" class="text-charcoal">Charcoal</span></div>
                  <div><span class="block text-charcoal/60">Berichten</span><span id="promo-preview-count" class="text-charcoal">{hp.promo_banner.messages.length}</span></div>
                  <div><span class="block text-charcoal/60">Rotatie</span><span id="promo-preview-rotation" class="text-charcoal">{hp.promo_banner.rotation_ms} ms</span></div>
                  <div><span class="block text-charcoal/60">Overgang</span><span id="promo-preview-transition" class="text-charcoal">{hp.promo_banner.transition_ms} ms</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="mb-14">
        <div class="flex items-center justify-between mb-6 gap-4">
          <div>
            <h2 class="text-[10px] uppercase tracking-[0.3em] text-taupe font-body font-medium">Categorie Slider</h2>
            <p class="text-xs text-taupe font-body mt-2">
              Beheer de 12 vaste stijlcategorieën die onder de hero op de homepage verschijnen.
            </p>
          </div>
          <button type="button" id="category-slider-save-btn" class="btn-premium text-[10px]">Categorieën opslaan</button>
        </div>

        <div id="category-slider-error" class="hidden bg-red-50 border border-red-200 px-4 py-3 text-sm font-body text-red-700 mb-4"></div>
        <div id="category-slider-success" class="hidden bg-green-50 border border-green-200 px-4 py-3 text-sm font-body text-green-700 mb-4">Categorie slider opgeslagen.</div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
          {categorySliderItems.map((item, index) => (
            <article class="bg-white border border-champagne p-4 shadow-soft space-y-4" data-category-item data-item-id={item.id}>
              <div class="aspect-[4/5] bg-linen overflow-hidden">
                <img
                  src={item.image_url}
                  alt={item.label}
                  class="w-full h-full object-cover"
                  data-preview-image
                  onerror="this.onerror=null;this.src='/images/jurkvormen/a-lijn.png';"
                />
              </div>
              <div class="space-y-3">
                <div>
                  <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Naam</label>
                  <input
                    type="text"
                    class="w-full border border-champagne bg-white px-3 py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors"
                    value={item.label}
                    data-field="label"
                  />
                </div>
                <div>
                  <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Link</label>
                  <input
                    type="text"
                    class="w-full border border-champagne bg-white px-3 py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors"
                    value={item.href}
                    data-field="href"
                  />
                </div>
                <div>
                  <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">Afbeelding URL</label>
                  <input
                    type="text"
                    class="w-full border border-champagne bg-white px-3 py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors"
                    value={item.image_url}
                    data-field="image_url"
                  />
                </div>
                <div class="flex gap-2">
                  <input type="file" accept="image/jpeg,image/png,image/webp,image/avif" class="hidden" data-file-input />
                  <button
                    type="button"
                    class="border border-champagne px-3 py-2 text-[10px] tracking-widest uppercase font-body text-taupe hover:text-charcoal hover:border-charcoal transition-colors"
                    data-upload-btn
                  >
                    Upload / Vervang
                  </button>
                  <button
                    type="button"
                    class="border border-red-200 px-3 py-2 text-[10px] tracking-widest uppercase font-body text-red-500 hover:text-red-700 transition-colors"
                    data-clear-btn
                  >
                    Verwijder foto
                  </button>
                </div>
              </div>
              <p class="text-[10px] tracking-[0.2em] uppercase text-champagne font-body">Item {index + 1} van 12</p>
            </article>
          ))}
        </div>
      </section>
      
      {sliderPublicReadBlocked && (
        <div class="mb-8 border border-amber-300 bg-amber-50 px-4 py-3">
          <p class="text-[10px] tracking-[0.2em] uppercase text-amber-800 font-body mb-1">Health Check</p>
          <p class="text-sm font-body text-amber-900">
            Homepage slider is publiek niet leesbaar. Controleer de RLS policy op <code>hero_slides</code>.
          </p>
          <p class="text-xs font-body text-amber-800 mt-1">
            Details: {sliderHealthMessage}
          </p>
        </div>
      )}

      <!-- ===== HERO SLIDER ===== -->
      <section class="mb-14">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-[10px] uppercase tracking-[0.3em] text-taupe font-body font-medium">Hero Slider</h2>
          <span class="text-[10px] font-body text-taupe">
            <span id="slide-count">{slides?.length ?? 0}</span> slide{(slides?.length ?? 0) !== 1 ? 's' : ''}
          </span>
        </div>

        <!-- Drop zone -->
        <div
          id="drop-zone"
          class="relative border-2 border-dashed border-champagne bg-white p-12 text-center hover:border-taupe transition-colors mb-6"
        >
          <input
            type="file"
            id="bulk-input"
            multiple
            accept="image/jpeg,image/png,image/webp,image/avif"
            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer"
            aria-label="Foto's uploaden"
          />
          <div class="pointer-events-none">
            <svg class="w-10 h-10 text-champagne mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="font-body text-charcoal text-sm mb-1">Sleep foto's hierheen of klik om te selecteren</p>
            <p class="font-body text-taupe text-xs">Meerdere foto's tegelijk • Automatisch gecomprimeerd naar WebP • Aanbevolen: 2560×1080px</p>
          </div>
        </div>

        <!-- Upload progress -->
        <div id="upload-progress" class="hidden space-y-2 mb-6"></div>

        <!-- Slides list -->
        <div id="slides-list" class="space-y-3">
          {(slides ?? []).map((slide, idx) => (
            <div
              class="bg-white border border-champagne shadow-soft flex items-center gap-4 p-4 slide-card"
              data-id={slide.id}
            >
              <div class="w-24 h-16 bg-linen shrink-0 overflow-hidden">
                <img src={slide.image_url || '/wp-content/uploads/2023/07/Home-Hero-img.jpg'} alt={slide.title || 'Slide'} onerror="this.onerror=null;this.src='/wp-content/uploads/2023/07/Home-Hero-img.jpg'" class="w-full h-full object-cover" />
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-body font-medium text-charcoal truncate">{slide.title || <em class="text-taupe font-normal">Geen titel</em>}</p>
                <p class="text-[10px] tracking-widest uppercase font-body text-taupe mt-0.5">
                  {slide.text_align} · Overlay {slide.overlay_opacity}%
                  {slide.button1_text && ` · ${slide.button1_text}`}
                </p>
              </div>
              <button
                data-toggle-id={slide.id}
                data-toggle-active={slide.is_active ? 'true' : 'false'}
                class={`shrink-0 text-[9px] tracking-widest uppercase font-body px-3 py-1.5 border transition-colors ${slide.is_active ? 'border-green-400 text-green-700 bg-green-50' : 'border-champagne text-taupe'}`}
              >{slide.is_active ? 'Actief' : 'Inactief'}</button>
              <div class="flex flex-col gap-0.5 shrink-0">
                <button data-move-id={slide.id} data-move-dir="up" disabled={idx === 0}
                  class="px-2 py-1 text-taupe hover:text-charcoal disabled:opacity-20 transition-colors text-xs" title="Omhoog">▲</button>
                <button data-move-id={slide.id} data-move-dir="down" disabled={idx === (slides?.length ?? 0) - 1}
                  class="px-2 py-1 text-taupe hover:text-charcoal disabled:opacity-20 transition-colors text-xs" title="Omlaag">▼</button>
              </div>
              <div class="flex items-center gap-3 shrink-0">
                <a href={`/admin/homepage/slide/${slide.id}/edit`}
                  class="text-[9px] tracking-widest uppercase font-body text-blush-deep hover:underline">Bewerken</a>
                <button data-delete-id={slide.id}
                  class="text-[9px] tracking-widest uppercase font-body text-red-400 hover:text-red-600 transition-colors">Verwijder</button>
              </div>
            </div>
          ))}
        </div>

        {(!slides || slides.length === 0) && (
          <p id="empty-msg" class="text-xs font-body text-taupe italic text-center py-4">
            Nog geen slides. Upload hierboven foto's om te beginnen.
          </p>
        )}
      </section>

      <!-- ===== HOMEPAGE SECTIES ===== -->
      <section>
        <h2 class="text-[10px] uppercase tracking-[0.3em] text-taupe font-body font-medium mb-6">Homepage Secties</h2>
        <form id="hp-settings-form" class="space-y-8">
          <div class="bg-white border border-champagne p-8 shadow-soft">
            <div class="flex items-center justify-between gap-4 mb-4">
              <h3 class="text-[10px] uppercase tracking-[0.2em] text-taupe font-body">Sectievolgorde & zichtbaarheid</h3>
              <p class="text-xs text-taupe font-body">Sleep secties om de homepage-volgorde te wijzigen.</p>
            </div>
            <input type="hidden" id="hp-sections-order" value={JSON.stringify(hp.sections_order)} />
            <div id="hp-sections-list" class="space-y-4">
              {orderedSectionDefs.map((section) => (
                <article
                  class="border border-champagne bg-ivory/30 p-5 space-y-4 cursor-move section-editor-card"
                  data-section-id={section.id}
                  draggable="true"
                >
                  <div class="flex items-start justify-between gap-4">
                    <div class="min-w-0">
                      <p class="text-[10px] tracking-[0.2em] uppercase text-blush-deep font-body mb-1">Sectie</p>
                      <h4 class="font-body text-charcoal text-base">{section.label}</h4>
                      <p class="text-xs text-taupe font-body mt-1">{section.description}</p>
                    </div>
                    <label class="inline-flex items-center gap-2 text-[10px] tracking-[0.2em] uppercase text-taupe font-body shrink-0">
                      <input
                        type="checkbox"
                        class="accent-blush-deep"
                        data-visibility-toggle={section.id}
                        checked={Boolean(hp.sections_visibility[section.id])}
                      />
                      Zichtbaar
                    </label>
                  </div>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    {section.fields.map((field) => {
                      const value = hp.sections_content[section.id]?.[field.key];
                      const commonClass = 'w-full border border-champagne bg-white px-3 py-2 text-sm font-body text-charcoal focus:outline-none focus:border-blush-deep transition-colors';
                      return (
                        <div class={field.type === 'textarea' ? 'md:col-span-2' : ''}>
                          <label class="block text-[10px] tracking-[0.2em] uppercase text-taupe font-body mb-2">{field.label}</label>
                          {field.type === 'textarea' ? (
                            <textarea
                              rows={3}
                              class={commonClass}
                              data-setting-field="true"
                              data-section-id={section.id}
                              data-field-key={field.key}
                              data-field-type={field.type}
                            >{String(value ?? '')}</textarea>
                          ) : field.type === 'boolean' ? (
                            <select
                              class={commonClass}
                              data-setting-field="true"
                              data-section-id={section.id}
                              data-field-key={field.key}
                              data-field-type={field.type}
                            >
                              <option value="true" selected={Boolean(value) === true}>Aan</option>
                              <option value="false" selected={Boolean(value) === false}>Uit</option>
                            </select>
                          ) : (
                            <input
                              type={field.type === 'number' ? 'number' : 'text'}
                              min={field.type === 'number' ? field.min : undefined}
                              max={field.type === 'number' ? field.max : undefined}
                              value={String(value ?? '')}
                              class={commonClass}
                              data-setting-field="true"
                              data-section-id={section.id}
                              data-field-key={field.key}
                              data-field-type={field.type}
                            />
                          )}
                        </div>
                      );
                    })}
                  </div>
                </article>
              ))}
            </div>
          </div>

          <div id="hp-error" class="hidden bg-red-50 border border-red-200 px-4 py-3 text-sm font-body text-red-700"></div>
          <div id="hp-success" class="hidden bg-green-50 border border-green-200 px-4 py-3 text-sm font-body text-green-700">Instellingen opgeslagen.</div>

          <div class="flex gap-4">
            <button type="submit" id="hp-save-btn" class="btn-premium text-[10px]">Opslaan</button>
            <a href="/admin" class="border border-champagne px-8 py-3 text-[10px] tracking-widest uppercase font-body text-taupe hover:border-charcoal hover:text-charcoal transition-colors">Dashboard</a>
          </div>
        </form>
      </section>
    </div>
  </div>
</AdminLayout>

<script>
// ─── Compression ────────────────────────────────────────────────────────────
async function compressToWebP(file: File, maxWidth = 2560): Promise<File> {
  return new Promise((resolve, reject) => {
    const img = new Image();
    const url = URL.createObjectURL(file);
    img.onload = () => {
      URL.revokeObjectURL(url);
      const ratio = Math.min(1, maxWidth / img.naturalWidth);
      const w = Math.round(img.naturalWidth * ratio);
      const h = Math.round(img.naturalHeight * ratio);
      const canvas = document.createElement('canvas');
      canvas.width = w;
      canvas.height = h;
      canvas.getContext('2d')!.drawImage(img, 0, 0, w, h);
      canvas.toBlob(
        (blob) => {
          if (!blob) { reject(new Error('Compressie mislukt')); return; }
          resolve(new File([blob], file.name.replace(/\.[^.]+$/, '.webp'), { type: 'image/webp' }));
        },
        'image/webp',
        0.92,
      );
    };
    img.onerror = () => { URL.revokeObjectURL(url); reject(new Error('Afbeelding laden mislukt')); };
    img.src = url;
  });
}

function formatKB(bytes: number) {
  return bytes < 1024 * 1024
    ? Math.round(bytes / 1024) + ' KB'
    : (bytes / (1024 * 1024)).toFixed(1) + ' MB';
}

// ─── Progress items ──────────────────────────────────────────────────────────
function createProgressItem(name: string) {
  const el = document.createElement('div');
  el.className = 'flex items-center gap-3 bg-white border border-champagne px-4 py-3 text-sm font-body';
  el.innerHTML = `
    <span class="text-taupe shrink-0">⟳</span>
    <span class="flex-1 truncate text-charcoal">${name}</span>
    <span class="status text-taupe text-xs shrink-0">Wachten...</span>
  `;
  const statusEl = el.querySelector<HTMLElement>('.status')!;
  const iconEl = el.querySelector<HTMLElement>('span')!;

  return {
    el,
    setStatus(msg: string, state?: 'success' | 'error') {
      statusEl.textContent = msg;
      if (state === 'success') {
        iconEl.textContent = '✓';
        iconEl.className = 'text-green-600 shrink-0';
      } else if (state === 'error') {
        iconEl.textContent = '✗';
        iconEl.className = 'text-red-500 shrink-0';
        statusEl.className = 'status text-red-500 text-xs shrink-0';
      } else {
        iconEl.textContent = '⟳';
        iconEl.className = 'text-taupe shrink-0 animate-spin';
      }
    },
  };
}

// ─── Append new slide card ───────────────────────────────────────────────────
function appendSlideCard(slide: Record<string, unknown>) {
  document.getElementById('empty-msg')?.remove();

  const list = document.getElementById('slides-list')!;
  const existing = list.querySelectorAll('.slide-card');
  const idx = existing.length;

  const card = document.createElement('div');
  card.className = 'bg-white border border-champagne shadow-soft flex items-center gap-4 p-4 slide-card';
  card.dataset.id = String(slide.id);
  card.innerHTML = `
    <div class="w-24 h-16 bg-linen shrink-0 overflow-hidden">
      <img src="${slide.image_url}" alt="${slide.title || 'Slide'}" onerror="this.onerror=null;this.src='/wp-content/uploads/2023/07/Home-Hero-img.jpg'" class="w-full h-full object-cover" />
    </div>
    <div class="flex-1 min-w-0">
      <p class="text-sm font-body font-medium text-charcoal truncate italic text-taupe">Geen titel — klik Bewerken</p>
      <p class="text-[10px] tracking-widest uppercase font-body text-taupe mt-0.5">center · Overlay 40%</p>
    </div>
    <button data-toggle-id="${slide.id}" data-toggle-active="true"
      class="shrink-0 text-[9px] tracking-widest uppercase font-body px-3 py-1.5 border transition-colors border-green-400 text-green-700 bg-green-50">
      Actief
    </button>
    <div class="flex flex-col gap-0.5 shrink-0">
      <button data-move-id="${slide.id}" data-move-dir="up" ${idx === 0 ? 'disabled' : ''}
        class="px-2 py-1 text-taupe hover:text-charcoal disabled:opacity-20 transition-colors text-xs" title="Omhoog">▲</button>
      <button data-move-id="${slide.id}" data-move-dir="down"
        class="px-2 py-1 text-taupe hover:text-charcoal disabled:opacity-20 transition-colors text-xs" title="Omlaag">▼</button>
    </div>
    <div class="flex items-center gap-3 shrink-0">
      <a href="/admin/homepage/slide/${slide.id}/edit"
        class="text-[9px] tracking-widest uppercase font-body text-blush-deep hover:underline">Bewerken</a>
      <button data-delete-id="${slide.id}"
        class="text-[9px] tracking-widest uppercase font-body text-red-400 hover:text-red-600 transition-colors">Verwijder</button>
    </div>
  `;
  list.appendChild(card);

  // Update counter
  const countEl = document.getElementById('slide-count');
  if (countEl) countEl.textContent = String(list.querySelectorAll('.slide-card').length);

  updateMoveButtons();
}

// ─── Reorder helpers ─────────────────────────────────────────────────────────
function updateMoveButtons() {
  const cards = Array.from(document.querySelectorAll<HTMLElement>('#slides-list .slide-card'));
  cards.forEach((card, i) => {
    const up = card.querySelector<HTMLButtonElement>('[data-move-dir="up"]');
    const down = card.querySelector<HTMLButtonElement>('[data-move-dir="down"]');
    if (up) up.disabled = i === 0;
    if (down) down.disabled = i === cards.length - 1;
  });
}

async function saveOrder() {
  const cards = Array.from(document.querySelectorAll<HTMLElement>('#slides-list .slide-card'));
  const slides = cards.map((c, i) => ({ id: c.dataset.id!, sort_order: i }));
  await fetch('/api/admin/homepage/slides/reorder', {
    method: 'PUT',
    headers: { 'content-type': 'application/json' },
    body: JSON.stringify({ slides }),
  });
  updateMoveButtons();
}

// ─── Upload pipeline ─────────────────────────────────────────────────────────
async function handleFiles(files: FileList | File[]) {
  const progressWrap = document.getElementById('upload-progress')!;
  progressWrap.classList.remove('hidden');

  for (const file of Array.from(files)) {
    const item = createProgressItem(file.name);
    progressWrap.appendChild(item.el);

    try {
      // 1. Compress
      item.setStatus('Comprimeren...');
      const compressed = await compressToWebP(file);
      const before = formatKB(file.size);
      const after = formatKB(compressed.size);
      const pct = Math.round((1 - compressed.size / file.size) * 100);

      // 2. Upload image
      item.setStatus(`Uploaden (${before} → ${after}, ${pct}% kleiner)...`);
      const fd = new FormData();
      fd.append('image', compressed);
      const uploadRes = await fetch('/api/admin/homepage/slides/image', { method: 'POST', body: fd });
      const uploadJson = await uploadRes.json();
      if (!uploadRes.ok) throw new Error(uploadJson.error ?? 'Upload mislukt');

      // 3. Create slide
      item.setStatus('Slide aanmaken...');
      const slideRes = await fetch('/api/admin/homepage/slides', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ image_url: uploadJson.url, title: '', is_active: true }),
      });
      const slide = await slideRes.json();
      if (!slideRes.ok) throw new Error(slide.error ?? 'Slide aanmaken mislukt');

      appendSlideCard(slide);
      item.setStatus(`${before} → ${after} (${pct}% kleiner)`, 'success');
    } catch (err: any) {
      item.setStatus(err.message, 'error');
    }
  }
}

// ─── Drop zone ───────────────────────────────────────────────────────────────
const dropZone = document.getElementById('drop-zone')!;
const bulkInput = document.getElementById('bulk-input') as HTMLInputElement;

bulkInput.addEventListener('change', () => {
  if (bulkInput.files?.length) handleFiles(bulkInput.files);
  bulkInput.value = '';
});

dropZone.addEventListener('dragover', (e) => {
  e.preventDefault();
  dropZone.classList.add('border-taupe', 'bg-linen');
});
dropZone.addEventListener('dragleave', () => {
  dropZone.classList.remove('border-taupe', 'bg-linen');
});
dropZone.addEventListener('drop', (e) => {
  e.preventDefault();
  dropZone.classList.remove('border-taupe', 'bg-linen');
  const files = Array.from(e.dataTransfer?.files ?? []).filter(f =>
    ['image/jpeg', 'image/png', 'image/webp', 'image/avif'].includes(f.type)
  );
  if (files.length) handleFiles(files);
});

// ─── Event delegation for slide cards ────────────────────────────────────────
document.getElementById('slides-list')!.addEventListener('click', async (e) => {
  const btn = (e.target as HTMLElement).closest('button') as HTMLButtonElement | null;
  if (!btn) return;

  // Toggle active
  if (btn.dataset.toggleId) {
    const id = btn.dataset.toggleId;
    const newActive = btn.dataset.toggleActive !== 'true';
    const res = await fetch(`/api/admin/homepage/slides/${id}`, {
      method: 'PUT',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ is_active: newActive }),
    });
    if (res.ok) {
      btn.dataset.toggleActive = String(newActive);
      btn.textContent = newActive ? 'Actief' : 'Inactief';
      btn.className = `shrink-0 text-[9px] tracking-widest uppercase font-body px-3 py-1.5 border transition-colors ${
        newActive ? 'border-green-400 text-green-700 bg-green-50' : 'border-champagne text-taupe'
      }`;
    }
    return;
  }

  // Delete
  if (btn.dataset.deleteId) {
    if (!confirm('Deze slide verwijderen?')) return;
    const id = btn.dataset.deleteId;
    const res = await fetch(`/api/admin/homepage/slides/${id}`, { method: 'DELETE' });
    if (res.ok) {
      btn.closest('.slide-card')?.remove();
      const countEl = document.getElementById('slide-count');
      if (countEl) {
        const n = document.querySelectorAll('#slides-list .slide-card').length;
        countEl.textContent = String(n);
        if (n === 0) {
          const msg = document.createElement('p');
          msg.id = 'empty-msg';
          msg.className = 'text-xs font-body text-taupe italic text-center py-4';
          msg.textContent = 'Nog geen slides. Upload hierboven foto\'s om te beginnen.';
          document.getElementById('slides-list')!.after(msg);
        }
      }
      updateMoveButtons();
    }
    return;
  }

  // Move up/down
  if (btn.dataset.moveId) {
    const dir = btn.dataset.moveDir!;
    const card = btn.closest<HTMLElement>('.slide-card')!;
    const list = document.getElementById('slides-list')!;
    if (dir === 'up' && card.previousElementSibling) {
      list.insertBefore(card, card.previousElementSibling);
    } else if (dir === 'down' && card.nextElementSibling) {
      card.nextElementSibling.after(card);
    }
    saveOrder();
  }
});

// ─── Homepage settings form ──────────────────────────────────────────────────
const form = document.getElementById('hp-settings-form') as HTMLFormElement;
const saveBtn = document.getElementById('hp-save-btn') as HTMLButtonElement;
const errorEl = document.getElementById('hp-error')!;
const successEl = document.getElementById('hp-success')!;
const sectionsList = document.getElementById('hp-sections-list') as HTMLElement | null;
const sectionsOrderInput = document.getElementById('hp-sections-order') as HTMLInputElement | null;
const promoPreviewBar = document.getElementById('promo-banner-preview') as HTMLElement | null;
const promoPreviewMessage = document.getElementById('promo-preview-message') as HTMLElement | null;
const promoPreviewLink = document.getElementById('promo-preview-link') as HTMLAnchorElement | null;
const promoPreviewStatus = document.getElementById('promo-preview-status') as HTMLElement | null;
const promoPreviewTheme = document.getElementById('promo-preview-theme') as HTMLElement | null;
const promoPreviewCount = document.getElementById('promo-preview-count') as HTMLElement | null;
const promoPreviewRotation = document.getElementById('promo-preview-rotation') as HTMLElement | null;
const promoPreviewTransition = document.getElementById('promo-preview-transition') as HTMLElement | null;
const promoPreviewClose = document.getElementById('promo-preview-close') as HTMLButtonElement | null;
const promoBannerFields = document.querySelectorAll<HTMLElement>('[data-section-id="promo_banner"][data-setting-field="true"]');
const categorySliderSaveBtn = document.getElementById('category-slider-save-btn') as HTMLButtonElement | null;
const categorySliderError = document.getElementById('category-slider-error') as HTMLElement | null;
const categorySliderSuccess = document.getElementById('category-slider-success') as HTMLElement | null;
const categorySliderCards = Array.from(document.querySelectorAll<HTMLElement>('[data-category-item]'));

const promoBannerThemes: Record<string, { bar: string; close: string; status: string }> = {
  charcoal: { bar: 'bg-charcoal text-warm-white', close: 'text-warm-white/60 hover:text-warm-white', status: 'text-warm-white/70' },
  blush: { bar: 'bg-blush-deep text-white', close: 'text-white/70 hover:text-white', status: 'text-white/80' },
  champagne: { bar: 'bg-champagne text-charcoal', close: 'text-charcoal/50 hover:text-charcoal', status: 'text-charcoal/70' },
  ivory: { bar: 'bg-ivory text-charcoal border-b border-champagne', close: 'text-charcoal/50 hover:text-charcoal', status: 'text-charcoal/70' },
};

let promoPreviewTimer: number | null = null;
let promoPreviewIndex = 0;
let categorySliderSaveInFlight = false;

const syncSectionsOrder = () => {
  if (!sectionsList || !sectionsOrderInput) return [];
  const order = Array.from(sectionsList.querySelectorAll<HTMLElement>('.section-editor-card'))
    .map((card) => card.dataset.sectionId)
    .filter((id): id is string => Boolean(id));
  sectionsOrderInput.value = JSON.stringify(order);
  return order;
};

if (sectionsList) {
  let draggedCard: HTMLElement | null = null;

  sectionsList.addEventListener('dragstart', (event) => {
    const target = (event.target as HTMLElement).closest<HTMLElement>('.section-editor-card');
    if (!target) return;
    draggedCard = target;
    target.classList.add('opacity-60');
    event.dataTransfer?.setData('text/plain', target.dataset.sectionId ?? '');
    if (event.dataTransfer) event.dataTransfer.effectAllowed = 'move';
  });

  sectionsList.addEventListener('dragend', () => {
    if (draggedCard) draggedCard.classList.remove('opacity-60');
    draggedCard = null;
    syncSectionsOrder();
  });

  sectionsList.addEventListener('dragover', (event) => {
    event.preventDefault();
    if (!draggedCard) return;
    const target = (event.target as HTMLElement).closest<HTMLElement>('.section-editor-card');
    if (!target || target === draggedCard) return;
    const bounds = target.getBoundingClientRect();
    const shouldInsertBefore = event.clientY < bounds.top + bounds.height / 2;
    if (shouldInsertBefore) {
      sectionsList.insertBefore(draggedCard, target);
    } else {
      sectionsList.insertBefore(draggedCard, target.nextElementSibling);
    }
  });

  syncSectionsOrder();
}

function stopPromoPreviewRotation() {
  if (promoPreviewTimer !== null) {
    window.clearInterval(promoPreviewTimer);
    promoPreviewTimer = null;
  }
}

function readPromoBannerSettings() {
  const getField = (key: string) =>
    document.querySelector<HTMLElement>(`[data-section-id="promo_banner"][data-field-key="${key}"]`);
  const toBool = (key: string) => {
    const el = getField(key) as HTMLSelectElement | null;
    return el ? el.value === 'true' : false;
  };
  const toNum = (key: string, fallback: number) => {
    const el = getField(key) as HTMLInputElement | null;
    const raw = Number.parseInt(el?.value ?? '', 10);
    return Number.isFinite(raw) ? raw : fallback;
  };
  const toText = (key: string, fallback = '') => {
    const el = getField(key) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
    return (el?.value ?? fallback).toString();
  };
  const messages = toText('messages')
    .split('\n')
    .map((line) => line.trim())
    .filter(Boolean);

  return {
    enabled: toBool('enabled'),
    theme: toText('theme', 'charcoal'),
    messages,
    rotation_ms: toNum('rotation_ms', 4000),
    transition_ms: toNum('transition_ms', 450),
    pause_on_hover: toBool('pause_on_hover'),
    dismissible: toBool('dismissible'),
    remember_dismissal: toBool('remember_dismissal'),
    link_url: toText('link_url').trim(),
    open_in_new_tab: toBool('open_in_new_tab'),
  };
}

function setPromoPreviewTheme(theme: string) {
  if (!promoPreviewBar || !promoPreviewClose || !promoPreviewStatus) return;
  const classes = promoBannerThemes[theme] ?? promoBannerThemes.charcoal;
  promoPreviewBar.className = `border border-champagne shadow-soft overflow-hidden ${classes.bar}`;
  promoPreviewClose.className = `absolute right-3 top-1/2 -translate-y-1/2 transition-colors ${classes.close}`;
  promoPreviewStatus.className = `text-[10px] font-body ${classes.status}`;
  if (promoPreviewTheme) promoPreviewTheme.textContent = theme.charAt(0).toUpperCase() + theme.slice(1);
}

function renderPromoPreviewMessage(text: string) {
  if (!promoPreviewMessage) return;
  promoPreviewMessage.classList.add('opacity-0');
  window.setTimeout(() => {
    promoPreviewMessage.textContent = text || 'Voorbeeld promotiebericht';
    promoPreviewMessage.classList.remove('opacity-0');
  }, 250);
}

function updatePromoPreview() {
  if (!promoPreviewBar || !promoPreviewMessage || !promoPreviewLink || !promoPreviewStatus) return;
  const settings = readPromoBannerSettings();
  const theme = promoBannerThemes[settings.theme] ? settings.theme : 'charcoal';
  const themeClasses = promoBannerThemes[theme];
  const message = settings.messages[0] ?? 'Voorbeeld promotiebericht';

  stopPromoPreviewRotation();
  promoPreviewIndex = 0;

  setPromoPreviewTheme(theme);
  promoPreviewBar.className = `border border-champagne shadow-soft overflow-hidden ${themeClasses.bar}`;
  promoPreviewStatus.textContent = settings.enabled && settings.messages.length > 0 ? 'Zichtbaar' : 'Verborgen';
  promoPreviewBar.style.opacity = settings.enabled ? '1' : '0.45';
  promoPreviewBar.style.pointerEvents = settings.enabled ? 'auto' : 'none';
  promoPreviewMessage.style.transitionDuration = `${settings.transition_ms}ms`;
  promoPreviewLink.href = settings.link_url || '#';
  if (settings.link_url) {
    promoPreviewLink.target = settings.open_in_new_tab ? '_blank' : '_self';
    promoPreviewLink.rel = settings.open_in_new_tab ? 'noopener noreferrer' : '';
  } else {
    promoPreviewLink.removeAttribute('target');
    promoPreviewLink.removeAttribute('rel');
  }

  if (promoPreviewCount) promoPreviewCount.textContent = String(settings.messages.length);
  if (promoPreviewRotation) promoPreviewRotation.textContent = `${settings.rotation_ms} ms`;
  if (promoPreviewTransition) promoPreviewTransition.textContent = `${settings.transition_ms} ms`;
  if (promoPreviewClose) promoPreviewClose.hidden = !settings.dismissible;

  renderPromoPreviewMessage(message);

  if (settings.enabled && settings.messages.length > 1) {
    promoPreviewTimer = window.setInterval(() => {
      promoPreviewIndex = (promoPreviewIndex + 1) % settings.messages.length;
      renderPromoPreviewMessage(settings.messages[promoPreviewIndex] ?? '');
    }, Math.max(settings.rotation_ms, settings.transition_ms + 200));
  }
}

const collectCategorySliderItems = () =>
  categorySliderCards.map((card) => {
    const id = card.dataset.itemId ?? '';
    const getField = (name: string) => card.querySelector<HTMLInputElement>(`[data-field="${name}"]`)?.value?.trim() ?? '';
    return {
      id,
      label: getField('label'),
      href: getField('href'),
      image_url: getField('image_url'),
    };
  });

const setCategorySliderPreviewImage = (card: HTMLElement, url: string) => {
  const preview = card.querySelector<HTMLImageElement>('[data-preview-image]');
  if (!preview) return;
  preview.src = url.trim() || '/images/jurkvormen/a-lijn.png';
};

const bindCategorySliderCard = (card: HTMLElement) => {
  const fileInput = card.querySelector<HTMLInputElement>('[data-file-input]');
  const uploadBtn = card.querySelector<HTMLButtonElement>('[data-upload-btn]');
  const clearBtn = card.querySelector<HTMLButtonElement>('[data-clear-btn]');
  const imageInput = card.querySelector<HTMLInputElement>('[data-field="image_url"]');

  imageInput?.addEventListener('input', () => {
    setCategorySliderPreviewImage(card, imageInput.value);
  });

  uploadBtn?.addEventListener('click', () => fileInput?.click());

  fileInput?.addEventListener('change', async () => {
    const selected = fileInput.files?.[0];
    if (!selected || !imageInput || !uploadBtn) return;

    categorySliderError?.classList.add('hidden');
    categorySliderSuccess?.classList.add('hidden');
    uploadBtn.disabled = true;
    uploadBtn.textContent = 'Uploaden...';

    try {
      const compressed = await compressToWebP(selected, 1600);
      const fd = new FormData();
      fd.append('file', compressed);
      fd.append('bucket', 'settings');

      const response = await fetch('/api/admin/upload', { method: 'POST', body: fd });
      const json = await response.json().catch(() => ({}));
      if (!response.ok || !json.url) {
        throw new Error(json.error ?? 'Upload mislukt');
      }

      imageInput.value = json.url;
      setCategorySliderPreviewImage(card, json.url);
    } catch (error) {
      if (categorySliderError) {
        categorySliderError.textContent = `Upload fout: ${error instanceof Error ? error.message : 'Onbekende fout'}`;
        categorySliderError.classList.remove('hidden');
      }
    } finally {
      uploadBtn.disabled = false;
      uploadBtn.textContent = 'Upload / Vervang';
      fileInput.value = '';
    }
  });

  clearBtn?.addEventListener('click', () => {
    if (imageInput) imageInput.value = '';
    setCategorySliderPreviewImage(card, '');
  });
};

categorySliderCards.forEach(bindCategorySliderCard);

categorySliderSaveBtn?.addEventListener('click', async () => {
  if (categorySliderSaveInFlight) return;
  categorySliderSaveInFlight = true;
  categorySliderError?.classList.add('hidden');
  categorySliderSuccess?.classList.add('hidden');
  categorySliderSaveBtn.disabled = true;
  categorySliderSaveBtn.textContent = 'Bezig...';

  try {
    const response = await fetch('/api/admin/settings', {
      method: 'PUT',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({
        homepage: {
          category_slider_items: collectCategorySliderItems(),
        },
      }),
    });
    const json = await response.json().catch(() => ({}));

    if (!response.ok) {
      throw new Error(json.error ?? 'Opslaan mislukt');
    }

    categorySliderSuccess?.classList.remove('hidden');
  } catch (error) {
    if (categorySliderError) {
      categorySliderError.textContent = `Fout: ${error instanceof Error ? error.message : 'Onbekend'}`;
      categorySliderError.classList.remove('hidden');
    }
  } finally {
    categorySliderSaveInFlight = false;
    categorySliderSaveBtn.disabled = false;
    categorySliderSaveBtn.textContent = 'Categorieën opslaan';
  }
});

form.addEventListener('submit', async (e) => {
  e.preventDefault();
  errorEl.classList.add('hidden');
  successEl.classList.add('hidden');
  saveBtn.textContent = 'Bezig...';
  saveBtn.disabled = true;

  const order = syncSectionsOrder();
  const visibility: Record<string, boolean> = {};
  document.querySelectorAll<HTMLInputElement>('input[data-visibility-toggle]').forEach((input) => {
    const sectionId = input.dataset.visibilityToggle;
    if (!sectionId) return;
    visibility[sectionId] = input.checked;
  });

  const content: Record<string, Record<string, string | number | boolean>> = {};
  document.querySelectorAll<HTMLElement>('[data-setting-field="true"]').forEach((fieldEl) => {
    const sectionId = fieldEl.dataset.sectionId;
    const fieldKey = fieldEl.dataset.fieldKey;
    const fieldType = fieldEl.dataset.fieldType;
    if (!sectionId || !fieldKey || !fieldType) return;

    if (!content[sectionId]) content[sectionId] = {};

    let value: string | number | boolean = '';
    if (fieldType === 'boolean') {
      value = (fieldEl as HTMLSelectElement).value === 'true';
    } else if (fieldType === 'number') {
      const raw = Number.parseInt((fieldEl as HTMLInputElement).value, 10);
      value = Number.isFinite(raw) ? raw : 0;
    } else if (
      fieldEl instanceof HTMLInputElement ||
      fieldEl instanceof HTMLTextAreaElement ||
      fieldEl instanceof HTMLSelectElement
    ) {
      value = fieldEl.value;
    }
    content[sectionId][fieldKey] = value;
  });

  const homepage = {
    sections_order: order,
    sections_visibility: visibility,
    sections_content: content,
  };

  try {
    const res = await fetch('/api/admin/settings', {
      method: 'PUT',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ homepage }),
    });
    if (res.ok) {
      successEl.classList.remove('hidden');
    } else {
      const err = await res.json();
      errorEl.textContent = 'Fout: ' + (err.error ?? 'Onbekend');
      errorEl.classList.remove('hidden');
    }
  } catch {
    errorEl.textContent = 'Netwerkfout.';
    errorEl.classList.remove('hidden');
  } finally {
    saveBtn.textContent = 'Opslaan';
    saveBtn.disabled = false;
  }
});

promoBannerFields.forEach((field) => {
  field.addEventListener('input', updatePromoPreview);
  field.addEventListener('change', updatePromoPreview);
});

promoPreviewClose?.addEventListener('click', () => {
  promoPreviewBar?.classList.add('opacity-0');
  window.setTimeout(() => {
    if (promoPreviewBar) promoPreviewBar.classList.remove('opacity-0');
  }, 250);
});

updatePromoPreview();
</script>
