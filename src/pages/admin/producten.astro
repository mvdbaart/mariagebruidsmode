---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';
import { DRESS_STYLES } from '../../lib/productStyles';

const { data: products } = await supabase
  .from('products')
  .select('*, collections(title, type)')
  .order('created_at', { ascending: false });

const dressCount = products?.filter(p => p.collections?.type === 'dress').length ?? 0;
const suitCount  = products?.filter(p => p.collections?.type === 'suit').length  ?? 0;

const brands = [...new Set((products ?? []).map(p => p.brand).filter(Boolean))].sort();
---

<AdminLayout title="Beheer Producten">
  <div class="pt-8 pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6">
      <nav class="mb-10 flex items-center gap-3 text-[10px] tracking-[0.2em] uppercase text-taupe font-body">
        <a href="/admin" class="hover:text-charcoal transition-colors">Dashboard</a>
        <span class="text-champagne">›</span>
        <span class="text-charcoal">Beheer Producten</span>
      </nav>

      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="text-[10px] tracking-[0.3em] uppercase text-blush-deep font-body mb-2">Backoffice</p>
          <h1 class="font-display font-normal text-charcoal text-4xl leading-tight">
            Beheer <em class="font-normal italic text-taupe">Producten</em>
          </h1>
        </div>
        <div class="flex items-center gap-6">
          <span class="text-[10px] tracking-widest uppercase font-body text-taupe font-medium">{products?.length || 0} items</span>
          <a href="/admin/product/new" class="bg-charcoal text-warm-white px-8 py-3 text-[10px] tracking-widest uppercase hover:bg-taupe transition-all font-medium">+ Nieuw Product</a>
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-5 mb-16">
        <div class="bg-white border border-champagne p-8 shadow-soft">
          <p class="text-4xl font-display text-charcoal leading-none mb-2">{products?.length || 0}</p>
          <p class="text-[9px] tracking-[0.25em] uppercase text-taupe font-body">Totaal</p>
        </div>
        <div class="bg-white border border-champagne p-8 shadow-soft">
          <p class="text-4xl font-display text-charcoal leading-none mb-2">{dressCount}</p>
          <p class="text-[9px] tracking-[0.25em] uppercase text-taupe font-body">Trouwjurken</p>
        </div>
        <div class="bg-white border border-champagne p-8 shadow-soft">
          <p class="text-4xl font-display text-charcoal leading-none mb-2">{suitCount}</p>
          <p class="text-[9px] tracking-[0.25em] uppercase text-taupe font-body">Trouwpakken</p>
        </div>
        <div class="bg-white border border-champagne p-8 shadow-soft">
          <p class="text-4xl font-display text-charcoal leading-none mb-2">{products?.filter(p => p.images?.[0]).length || 0}</p>
          <p class="text-[9px] tracking-[0.25em] uppercase text-taupe font-body">Met afbeelding</p>
        </div>
      </div>

      <!-- Filter toolbar -->
      <div class="flex flex-wrap gap-4 mb-8 items-end">
        <!-- Search -->
        <div class="relative flex-1 min-w-[200px] max-w-sm">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-taupe pointer-events-none w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input id="admin-search" type="search" placeholder="Zoek op naam of merk…" class="w-full pl-9 pr-4 py-2.5 bg-white border border-champagne text-charcoal text-sm font-body placeholder:text-taupe/50 focus:outline-none focus:border-taupe transition-colors" />
        </div>

        <!-- Brand filter -->
        {brands.length > 1 && (
          <select id="admin-brand" class="bg-white border border-champagne text-charcoal text-[11px] tracking-[0.1em] uppercase font-body px-4 py-2.5 focus:outline-none focus:border-taupe transition-colors min-w-[140px]">
            <option value="">Alle merken</option>
            {brands.map(b => <option value={b}>{b}</option>)}
          </select>
        )}

        <!-- Style filter -->
        <select id="admin-style" class="bg-white border border-champagne text-charcoal text-[11px] tracking-[0.1em] uppercase font-body px-4 py-2.5 focus:outline-none focus:border-taupe transition-colors min-w-[180px]">
          <option value="">Alle stijlen</option>
          {DRESS_STYLES.map(s => <option value={s.key}>{s.label}</option>)}
        </select>

        <!-- Type filter -->
        <div class="flex gap-2">
          <button data-type="" class="admin-type-btn text-[10px] tracking-[0.2em] uppercase font-body px-4 py-2.5 border border-charcoal bg-charcoal text-white transition-colors">Alle</button>
          <button data-type="dress" class="admin-type-btn text-[10px] tracking-[0.2em] uppercase font-body px-4 py-2.5 border border-champagne text-taupe hover:border-charcoal hover:text-charcoal transition-colors">Jurken</button>
          <button data-type="suit" class="admin-type-btn text-[10px] tracking-[0.2em] uppercase font-body px-4 py-2.5 border border-champagne text-taupe hover:border-charcoal hover:text-charcoal transition-colors">Pakken</button>
        </div>

        <span id="admin-result-count" class="text-[10px] tracking-[0.15em] uppercase text-taupe font-body ml-auto self-center"></span>
      </div>

      <!-- Products grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="admin-products-grid">
        {products?.map((prod) => (
          <div
            class="bg-white border border-champagne shadow-soft overflow-hidden group hover:shadow-card transition-all duration-300 admin-product-card"
            data-name={(prod.name ?? '').toLowerCase()}
            data-brand={(prod.brand ?? '').toLowerCase()}
            data-type={prod.collections?.type ?? ''}
            data-features={JSON.stringify((prod.features ?? []).map((f: string) => f.toLowerCase()))}
          >
            <div class="aspect-[3/4] bg-linen overflow-hidden relative">
              {prod.images?.[0] ? (
                <img 
                  src={prod.images[0]} 
                  alt={prod.name} 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
              ) : (
                <div class="w-full h-full flex flex-col items-center justify-center gap-3 bg-linen">
                  <span class="text-4xl opacity-15">📷</span>
                  <p class="text-[9px] tracking-[0.2em] uppercase text-taupe-light font-body">Geen beelden</p>
                </div>
              )}
              <div class="absolute inset-0 bg-charcoal/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <a 
                  href={`/admin/product/${prod.id}/edit`} 
                  class="bg-white text-charcoal px-6 py-3 text-[10px] tracking-[0.2em] uppercase font-body font-semibold hover:bg-blush-deep hover:text-white transition-all shadow-xl"
                >
                  ✎ Bewerken
                </a>
              </div>
            </div>
            <div class="p-6 border-t border-champagne bg-[#fcfbf9]">
              <span class="text-[9px] tracking-[0.25em] uppercase text-blush-deep font-body font-semibold block mb-2">{prod.brand}</span>
              <h3 class="font-display font-normal text-charcoal text-lg leading-tight mb-3">{prod.name}</h3>
              <div class="flex items-center justify-between mt-auto pt-3 border-t border-linen">
                <p class="text-[10px] text-taupe font-body tracking-wider">{prod.collections?.title}</p>
                {prod.price_range && <p class="text-xs font-display text-charcoal">{prod.price_range}</p>}
              </div>
              <button
                class="delete-product-btn mt-3 text-[9px] uppercase tracking-widest font-body text-red-400 hover:underline"
                data-id={prod.id}
                data-name={prod.name}
              >Verwijderen</button>
            </div>
          </div>
        ))}

        {!products?.length && (
          <div class="col-span-full text-center py-24 bg-white border border-dashed border-champagne">
            <p class="font-display text-xl text-taupe italic">Geen producten geselecteerd voor dit overzicht.</p>
          </div>
        )}
      </div>
    </div>
  </div>
</AdminLayout>

<dialog id="delete-dialog" class="bg-white border border-champagne shadow-card p-8 max-w-sm w-full">
  <h2 class="font-display text-charcoal text-xl mb-3">Product verwijderen?</h2>
  <p id="delete-dialog-msg" class="text-sm font-body text-taupe mb-6"></p>
  <div class="flex gap-4">
    <button id="confirm-delete" class="btn-premium text-[10px]" style="background-color: rgb(239,68,68); border-color: rgb(239,68,68)">Verwijderen</button>
    <button id="cancel-delete" class="btn-gold text-[10px]">Annuleren</button>
  </div>
</dialog>

<script>
  // ── Filter logic ──────────────────────────────────────────────────────────
  const searchInput = document.getElementById('admin-search') as HTMLInputElement | null;
  const brandSelect = document.getElementById('admin-brand') as HTMLSelectElement | null;
  const styleSelect = document.getElementById('admin-style') as HTMLSelectElement | null;
  const resultCount = document.getElementById('admin-result-count');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.admin-product-card'));
  let activeType = '';

  function applyFilters() {
    const q = (searchInput?.value ?? '').trim().toLowerCase();
    const brand = (brandSelect?.value ?? '').toLowerCase();
    const style = (styleSelect?.value ?? '').toLowerCase();
    let visible = 0;

    cards.forEach((card) => {
      const name = card.dataset.name ?? '';
      const cardBrand = card.dataset.brand ?? '';
      const type = card.dataset.type ?? '';
      const features: string[] = JSON.parse(card.dataset.features ?? '[]');

      const matchSearch = !q || name.includes(q) || cardBrand.includes(q);
      const matchBrand = !brand || cardBrand === brand;
      const matchStyle = !style || features.includes(style);
      const matchType = !activeType || type === activeType;

      const show = matchSearch && matchBrand && matchStyle && matchType;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    if (resultCount) {
      resultCount.textContent = visible === cards.length ? '' : `${visible} van ${cards.length} producten`;
    }
  }

  searchInput?.addEventListener('input', applyFilters);
  brandSelect?.addEventListener('change', applyFilters);
  styleSelect?.addEventListener('change', applyFilters);

  document.querySelectorAll<HTMLButtonElement>('.admin-type-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      activeType = btn.dataset.type ?? '';
      document.querySelectorAll<HTMLButtonElement>('.admin-type-btn').forEach((b) => {
        const active = b.dataset.type === activeType;
        b.className = active
          ? 'admin-type-btn text-[10px] tracking-[0.2em] uppercase font-body px-4 py-2.5 border border-charcoal bg-charcoal text-white transition-colors'
          : 'admin-type-btn text-[10px] tracking-[0.2em] uppercase font-body px-4 py-2.5 border border-champagne text-taupe hover:border-charcoal hover:text-charcoal transition-colors';
      });
      applyFilters();
    });
  });

  // ── Delete logic ──────────────────────────────────────────────────────────
  const dialog = document.getElementById('delete-dialog') as HTMLDialogElement | null;
  const confirmBtn = document.getElementById('confirm-delete');
  const cancelBtn = document.getElementById('cancel-delete');
  const dialogMsg = document.getElementById('delete-dialog-msg');
  let pendingDeleteId: string | null = null;

  document.querySelectorAll<HTMLButtonElement>('.delete-product-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      pendingDeleteId = btn.getAttribute('data-id');
      const name = btn.getAttribute('data-name') ?? 'dit product';
      if (dialogMsg) dialogMsg.textContent = `Weet je zeker dat je "${name}" wilt verwijderen?`;
      dialog?.showModal();
    });
  });

  cancelBtn?.addEventListener('click', () => { dialog?.close(); pendingDeleteId = null; });
  dialog?.addEventListener('click', (e) => { if (e.target === dialog) { dialog.close(); pendingDeleteId = null; } });

  confirmBtn?.addEventListener('click', async () => {
    if (!pendingDeleteId) return;
    const id = pendingDeleteId;
    dialog?.close();
    const response = await fetch(`/api/admin/products/${id}`, { method: 'DELETE' });
    if (response.ok) {
      // Remove the card element (find by delete button's parent chain)
      document.querySelector(`.delete-product-btn[data-id="${id}"]`)?.closest('.admin-product-card')?.remove();
    } else {
      alert('Fout bij verwijderen. Probeer opnieuw.');
    }
    pendingDeleteId = null;
  });
</script>

<style>
  #delete-dialog { border: 1px solid var(--color-champagne); }
  #delete-dialog::backdrop { background: rgba(44,42,40,0.5); }
</style>
