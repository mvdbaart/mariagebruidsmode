---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getServiceRoleClient } from '../../lib/serverAuth';

const supabase = getServiceRoleClient();

const today = new Date().toISOString().slice(0, 10);

// Load all stats in parallel
const [
  { count: productCount },
  { count: collectionCount },
  { count: blogCount },
  { count: appointmentCount },
  { count: weddingCount },
  { count: formCount },
  { count: customerCount },
  { count: supplierCount },
  { count: pendingTaskCount },
  { count: landingPageCount },
  { data: recentAppointments },
  { data: recentProducts },
  { data: pendingTasks },
  { data: upcomingOrders },
  { count: todayAppointmentCount },
  { count: overdueTaskCount },
  { count: overdueOrderCount },
  { count: onlineOrderCount },
] = await Promise.all([
  supabase.from('products').select('*', { count: 'exact', head: true }),
  supabase.from('collections').select('*', { count: 'exact', head: true }),
  supabase.from('blog_posts').select('*', { count: 'exact', head: true }),
  supabase.from('appointments').select('*', { count: 'exact', head: true }),
  supabase.from('real_weddings').select('*', { count: 'exact', head: true }),
  supabase.from('forms').select('*', { count: 'exact', head: true }),
  supabase.from('customers').select('*', { count: 'exact', head: true }),
  supabase.from('suppliers').select('*', { count: 'exact', head: true }),
  supabase.from('customer_tasks').select('*', { count: 'exact', head: true }).is('completed_at', null),
  supabase.from('landing_pages').select('*', { count: 'exact', head: true }),
  supabase.from('appointments').select('*, employees(first_name, last_name)').gte('preferred_date', today).neq('status', 'cancelled').order('preferred_date', { ascending: true }).order('start_time', { ascending: true, nullsFirst: false }).limit(10),
  supabase.from('products').select('*, collections(title)').order('created_at', { ascending: false }).limit(5),
  supabase.from('customer_tasks').select('*, customers(first_name, last_name, id)').is('completed_at', null).order('due_date', { ascending: true, nullsFirst: false }).limit(5),
  supabase.from('orders').select('*, customers(first_name, last_name, id), suppliers(name)').in('status', ['besteld', 'verwacht']).order('expected_delivery_date', { ascending: true, nullsFirst: false }).limit(5),
  supabase.from('appointments').select('*', { count: 'exact', head: true }).eq('preferred_date', today),
  supabase.from('customer_tasks').select('*', { count: 'exact', head: true }).is('completed_at', null).lt('due_date', today),
  supabase.from('orders').select('*', { count: 'exact', head: true }).in('status', ['besteld', 'verwacht']).lt('expected_delivery_date', today),
  supabase.from('customer_orders').select('*', { count: 'exact', head: true }).eq('status', 'betaald'),
]);

const stats = [
  { label: 'Producten', value: productCount ?? 0, href: '/admin/producten', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><path d="M15 22v-4a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2v4"/><path d="M2 7h20"/><path d="M22 7v3a2 2 0 0 1-2 2v0a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 16 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 12 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 8 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 4 12v0a2 2 0 0 1-2-2V7"/></svg>` },
  { label: 'Collecties', value: collectionCount ?? 0, href: '/admin/collecties', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>` },
  { label: 'Afspraken', value: appointmentCount ?? 0, href: '/admin/afspraken', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 7.5V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-1.5"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/><path d="m16 21 2-2 4 4"/></svg>` },
  { label: 'Klanten', value: customerCount ?? 0, href: '/admin/klanten', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>` },
  { label: 'Inspiratie', value: weddingCount ?? 0, href: '/admin/inspiratie', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 2H8C4.69 2 2 4.69 2 8v8c0 3.31 2.69 6 6 6h8c3.31 0 6-2.69 6-6V8c0-3.31-2.69-6-6-6Z"/><path d="M12 18s4.5-3.5 4.5-5.5a4.5 4.5 0 0 0-9 0C7.5 14.5 12 18 12 18Z"/></svg>` },
  { label: 'Blog', value: blogCount ?? 0, href: '/admin/blog', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M8 7h6"/><path d="M8 11h8"/><path d="M8 15h6"/></svg>` },
  { label: 'Formulieren', value: formCount ?? 0, href: '/admin/formulieren', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>` }, // Placeholder icon
  { label: 'Leveranciers', value: supplierCount ?? 0, href: '/admin/leveranciers', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 11V7a5 5 0 0 1 10 0v4"/><path d="M12 18v4"/><path d="M2 11h20v4a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5v-4z"/></svg>` },
  { label: 'Medewerkers', value: pendingTaskCount ?? 0, href: '/admin/planner/medewerkers', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/><path d="M16 18h.01"/></svg>` },
  { label: 'Online bestellingen', value: onlineOrderCount ?? 0, href: '/admin/online-bestellingen', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" x2="21" y1="6" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>` },
];

const todayFormatted = new Date().toLocaleDateString('nl-NL', { weekday: 'long', day: 'numeric', month: 'long' });

const todayApps = recentAppointments?.filter(a => a.preferred_date === today) ?? [];
const upcomingApps = recentAppointments?.filter(a => a.preferred_date > today) ?? [];
const appTypeLabel: { [key: string]: string } = { vip: 'VIP', standard_bride: 'Bruid', standard_groom: 'Bruidegom' };
const appStatusColor: { [key: string]: string } = { pending: 'bg-amber-100 text-amber-800', confirmed: 'bg-green-100 text-green-800', cancelled: 'bg-gray-100 text-gray-400' };
---

<AdminLayout title="Dashboard">
  <div class="pb-24 bg-ivory min-h-screen">
    <div class="container mx-auto px-6 pt-8">
      <div class="flex items-center justify-between mb-8">
        <h1 class="font-display font-normal text-charcoal text-4xl italic">Mariage <span class="font-signature text-blush-deep text-5xl lowercase px-2">Control</span></h1>
      </div>

      <!-- General Dashboard Search -->
      <div class="sticky top-0 z-30 bg-ivory/90 backdrop-blur-md py-4 mb-4">
        <div class="relative max-w-2xl mx-auto shadow-sm">
          <span class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-taupe/40">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </span>
          <input 
            type="text" 
            id="dashboardSearch" 
            placeholder="Doorzoek het dashboard (producten, afspraken, taken...)" 
            class="block w-full pl-12 pr-4 py-4 border border-champagne rounded-full bg-white text-base font-body shadow-soft focus:outline-none focus:ring-2 focus:ring-blush-deep/20 focus:border-blush-deep transition-all"
          />
        </div>
      </div>

      <!-- Daily summary -->
      <div class="bg-white border border-champagne shadow-soft px-8 py-5 mb-8 flex flex-wrap items-center gap-x-8 gap-y-3 rounded-2xl">
        <p class="text-xs tracking-[0.2em] uppercase font-body text-taupe capitalize">{todayFormatted}</p>
        <div class="h-4 w-px bg-champagne hidden sm:block"></div>
        <a href="/admin/afspraken" class="flex items-center gap-2 group">
          <span class="text-xl font-display text-charcoal group-hover:text-blush-deep transition-colors">{todayAppointmentCount ?? 0}</span>
          <span class="text-[10px] tracking-[0.15em] uppercase font-body text-taupe-light">afspraken vandaag</span>
        </a>
        <div class="h-4 w-px bg-champagne hidden sm:block"></div>
        <a href="/admin/klanten" class="flex items-center gap-2 group">
          <span class:list={['text-xl font-display transition-colors', (overdueTaskCount ?? 0) > 0 ? 'text-red-500' : 'text-charcoal group-hover:text-blush-deep']}>{overdueTaskCount ?? 0}</span>
          <span class="text-[10px] tracking-[0.15em] uppercase font-body text-taupe-light">verlate taken</span>
        </a>
        <div class="h-4 w-px bg-champagne hidden sm:block"></div>
        <a href="/admin/bestellingen" class="flex items-center gap-2 group">
          <span class:list={['text-xl font-display transition-colors', (overdueOrderCount ?? 0) > 0 ? 'text-red-500' : 'text-charcoal group-hover:text-blush-deep']}>{overdueOrderCount ?? 0}</span>
          <span class="text-[10px] tracking-[0.15em] uppercase font-body text-taupe-light">verlate leveringen</span>
        </a>
        <div class="h-4 w-px bg-champagne hidden sm:block"></div>
        <a href="/admin/klanten" class="flex items-center gap-2 group">
          <span class:list={['text-xl font-display transition-colors', (pendingTaskCount ?? 0) > 0 ? 'text-amber-600' : 'text-charcoal group-hover:text-blush-deep']}>{pendingTaskCount ?? 0}</span>
          <span class="text-[10px] tracking-[0.15em] uppercase font-body text-taupe-light">open taken totaal</span>
        </a>
      </div>

      <!-- Main Tile Grid -->
      <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6 mb-16">
        {stats.map(stat => (
          <a href={stat.href} class="dashboard-tile bg-white border border-champagne p-8 shadow-soft hover:shadow-card transition-all duration-300 hover:-translate-y-1 group rounded-3xl flex flex-col items-center text-center relative overflow-hidden h-full">
            <div class="mb-5 p-4 bg-linen rounded-2xl text-taupe group-hover:bg-blush-deep group-hover:text-white transition-all duration-300" set:html={stat.icon} />
            <p class="text-4xl font-display text-charcoal mb-1">{stat.value}</p>
            <p class="text-[10px] tracking-[0.2em] uppercase text-taupe-light font-body font-medium">{stat.label}</p>
            
            <div class="absolute top-0 right-0 p-3 opacity-0 group-hover:opacity-100 transition-opacity">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blush-deep"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </a>
        ))}
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 mb-10">
        <!-- Openstaande Taken -->
        <div class="bg-white p-8 border border-champagne shadow-soft rounded-2xl">
          <div class="flex items-center justify-between mb-8 pb-4 border-b border-champagne">
            <h2 class="font-display text-charcoal text-xl italic">Openstaande Taken</h2>
            <span class="text-[10px] tracking-widest uppercase font-body text-taupe">{pendingTaskCount ?? 0} open</span>
          </div>
          <div class="space-y-4">
            {pendingTasks?.map((task) => (
              <div class="flex items-start gap-3">
                <div class="w-1.5 h-1.5 rounded-full bg-blush-deep mt-2 shrink-0"></div>
                <div class="min-w-0">
                  <p class="text-sm font-body font-medium text-charcoal truncate">{task.title}</p>
                  <div class="flex items-center gap-2">
                    {task.customers && (
                      <a href={`/admin/klanten/${task.customers.id}`} class="text-xs font-body text-blush-deep hover:underline">
                        {task.customers.first_name} {task.customers.last_name}
                      </a>
                    )}
                    {task.due_date && (
                      <span class={`text-xs font-body ${task.due_date < today ? 'text-red-500' : 'text-taupe'}`}>
                        {new Date(task.due_date).toLocaleDateString('nl-NL')}
                      </span>
                    )}
                  </div>
                </div>
              </div>
            ))}
            {!pendingTasks?.length && <p class="text-sm font-body text-taupe-light italic">Geen openstaande taken.</p>}
          </div>
        </div>

        <!-- Verwachte Leveringen -->
        <div class="bg-white p-8 border border-champagne shadow-soft rounded-2xl">
          <div class="flex items-center justify-between mb-8 pb-4 border-b border-champagne">
            <h2 class="font-display text-charcoal text-xl italic">Verwachte Leveringen</h2>
            <a href="/admin/bestellingen" class="text-[10px] tracking-widest uppercase text-blush-deep hover:underline font-body">Alle bekijken</a>
          </div>
          <div class="space-y-4">
            {upcomingOrders?.map((order) => {
              const isOverdue = order.expected_delivery_date && order.expected_delivery_date < today;
              return (
                <div class="flex items-start justify-between">
                  <div class="min-w-0">
                    <p class="text-sm font-body font-medium text-charcoal truncate">{order.product_description}</p>
                    <div class="flex items-center gap-2">
                      {order.customers && (
                        <a href={`/admin/klanten/${order.customers.id}`} class="text-xs font-body text-blush-deep hover:underline">
                          {order.customers.first_name} {order.customers.last_name}
                        </a>
                      )}
                      {order.suppliers && <span class="text-xs font-body text-taupe">· {order.suppliers.name}</span>}
                    </div>
                  </div>
                  {order.expected_delivery_date && (
                    <p class={`text-xs font-body shrink-0 ml-3 ${isOverdue ? 'text-red-500 font-medium' : 'text-taupe'}`}>
                      {new Date(order.expected_delivery_date).toLocaleDateString('nl-NL')}
                    </p>
                  )}
                </div>
              );
            })}
            {!upcomingOrders?.length && <p class="text-sm font-body text-taupe-light italic">Geen verwachte leveringen.</p>}
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        <!-- Medewerkers -->
        <div class="bg-white p-8 border border-champagne shadow-soft rounded-2xl">
          <div class="flex items-center justify-between mb-8 pb-4 border-b border-champagne">
            <h2 class="font-display text-charcoal text-xl italic">Medewerkers</h2>
            <a href="/admin/afspraken" class="text-[10px] tracking-widest uppercase text-blush-deep hover:underline font-body">Alle bekijken</a>
          </div>
          <div class="space-y-6">
            <!-- Vandaag -->
            <div>
              <p class="text-[9px] tracking-[0.3em] uppercase text-taupe font-body mb-3">Vandaag</p>
              {todayApps.length === 0 && <p class="text-sm font-body text-taupe-light italic">Geen afspraken vandaag.</p>}
              <div class="space-y-2">
                {todayApps.map(app => (
                  <div class={`flex items-center gap-3 px-3 py-2.5 rounded-sm ${app.appointment_type === 'vip' ? 'bg-gold/10' : 'bg-blush/10'}`}>
                    <span class="text-sm font-body font-medium text-charcoal tabular-nums w-14 shrink-0">
                      {app.start_time ? app.start_time.slice(0, 5) : '—'}
                    </span>
                    <span class="text-sm font-body text-charcoal flex-1 truncate">{app.full_name}</span>
                    <span class={`text-[9px] uppercase tracking-wider font-body px-1.5 py-0.5 shrink-0 ${app.appointment_type === 'vip' ? 'bg-gold/20 text-charcoal' : 'bg-champagne text-taupe'}`}>
                      {appTypeLabel[app.appointment_type] ?? 'Standaard'}
                    </span>
                    <span class={`text-[9px] uppercase tracking-wider font-body px-1.5 py-0.5 rounded-sm shrink-0 ${appStatusColor[app.status] ?? appStatusColor.pending}`}>
                      {app.status === 'pending' ? 'Afwachting' : app.status === 'confirmed' ? 'Bevestigd' : app.status}
                    </span>
                  </div>
                ))}
              </div>
            </div>
            <!-- Aankomend -->
            {upcomingApps.length > 0 && (
              <div>
                <p class="text-[9px] tracking-[0.3em] uppercase text-taupe font-body mb-3">Aankomend</p>
                <div class="space-y-3">
                  {upcomingApps.map(app => (
                    <div class="flex items-center gap-3">
                      <span class="text-xs font-body text-taupe w-24 shrink-0">
                        {new Date(app.preferred_date + 'T00:00:00').toLocaleDateString('nl-NL', { weekday: 'short', day: 'numeric', month: 'short' })}
                      </span>
                      {app.start_time && <span class="text-xs font-body text-taupe-light tabular-nums w-10 shrink-0">{app.start_time.slice(0, 5)}</span>}
                      <span class="text-sm font-body text-charcoal flex-1 truncate">{app.full_name}</span>
                      <span class={`text-[9px] uppercase tracking-wider font-body px-1.5 py-0.5 shrink-0 ${app.appointment_type === 'vip' ? 'bg-gold/20 text-charcoal' : 'bg-champagne text-taupe'}`}>
                        {appTypeLabel[app.appointment_type] ?? 'Standaard'}
                      </span>
                    </div>
                  ))}
                </div>
              </div>
            )}
            {!recentAppointments?.length && <p class="text-sm font-body text-taupe-light italic">Geen aankomende afspraken.</p>}
          </div>
        </div>

        <!-- Recent Products -->
        <div class="bg-white p-8 border border-champagne shadow-soft rounded-2xl">
          <div class="flex items-center justify-between mb-8 pb-4 border-b border-champagne">
            <h2 class="font-display text-charcoal text-xl italic">Nieuwste Producten</h2>
            <a href="/admin/producten" class="text-[10px] tracking-widest uppercase text-blush-deep hover:underline font-body">Alle bekijken</a>
          </div>
          <div class="space-y-5">
            {recentProducts?.map((prod) => (
              <div class="flex items-center gap-4">
                <a href={`/admin/product/${prod.id}/edit`} class="w-12 h-12 bg-linen overflow-hidden shrink-0 block hover:ring-1 hover:ring-blush-deep transition-all">
                  {prod.images?.[0] && <img src={prod.images[0]} alt={prod.name} onerror="this.onerror=null;this.src='/images/jurkvormen/a-lijn.png'" class="w-full h-full object-cover" />}
                  {!prod.images?.[0] && <div class="w-full h-full flex items-center justify-center bg-linen text-[8px] text-taupe-light">N.v.t.</div>}
                </a>
                <div class="min-w-0">
                  <p class="text-sm font-body font-medium text-charcoal truncate">{prod.name}</p>
                  <p class="text-xs font-body text-taupe-light">{prod.collections?.title} — {prod.brand}</p>
                </div>
                <a href={`/admin/product/${prod.id}/edit`} class="ml-auto text-[10px] uppercase tracking-wider font-body text-blush-deep hover:underline shrink-0">Bewerk</a>
              </div>
            ))}
            {!recentProducts?.length && <p class="text-sm font-body text-taupe-light italic">Geen producten gevonden.</p>}
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  const searchInput = document.getElementById('dashboardSearch') as HTMLInputElement;
  
  // Elements to filter
  const searchableElements = '.dashboard-tile, .bg-white.p-8, .space-y-4 > div, .space-y-5 > div, .flex.items-start.justify-between, .space-y-2 > div';
  const sectionContainers = document.querySelectorAll('.bg-white.p-8, .grid.grid-cols-2.lg\\:grid-cols-3');

  searchInput?.addEventListener('input', () => {
    const query = searchInput.value.toLowerCase().trim();

    if (!query) {
      document.querySelectorAll('.hidden').forEach(el => {
        if (el.closest('.container')) el.classList.remove('hidden');
      });
      return;
    }

    const allItems = document.querySelectorAll(searchableElements);
    allItems.forEach(el => {
      const text = el.textContent?.toLowerCase() || '';
      if (text.includes(query)) {
        el.classList.remove('hidden');
      } else {
        el.classList.add('hidden');
      }
    });

    sectionContainers.forEach(section => {
      const visibleChildren = section.querySelectorAll(`${searchableElements}:not(.hidden)`);
      if (visibleChildren.length === 0) {
        section.classList.add('hidden');
      } else {
        section.classList.remove('hidden');
      }
    });
  });
</script>
