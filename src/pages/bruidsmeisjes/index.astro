---
import Layout from '../../layouts/Layout.astro';

const stijlen = [
  { naam: 'Klassiek & Tijdloos', beschrijving: 'Elegante jurken in vloeiende stoffen voor een tijdloze uitstraling. Perfect voor een formele bruiloft.' },
  { naam: 'Romantisch & Bohemian', beschrijving: 'Luchtige jurken met kant en ruches voor een romantische sfeer. Ideaal voor een outdoor of lente-bruiloft.' },
  { naam: 'Modern & Minimalistisch', beschrijving: 'Strakke silhouetten in effen kleuren voor een moderne, samenhangende look.' },
];

const kleuren = ['Dusty Rose', 'Sage Groen', 'Hemelsblauw', 'Bordeaux', 'Champagne', 'Lavendel', 'Terracotta', 'Navy'];
---

<Layout title="Bruidsmeisjesjurken | Mariage Bruidsmode">

  <!-- Hero -->
  <section class="pt-40 pb-24 bg-ivory">
    <div class="container mx-auto px-6">
      <div class="max-w-3xl">
        <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-6">Bruidsmeisjes</p>
        <h1 class="font-display text-charcoal leading-tight mb-8" style="font-size: clamp(40px, 8vw, 72px); font-weight: 300;">
          Jurken voor jouw <br/><em class="italic font-light text-taupe">bruidsmeisjes</em>
        </h1>
        <p class="text-taupe font-light leading-relaxed text-base max-w-xl mb-10">
          Laat jouw bruidsmeisjes stralen op jouw grote dag. Wij helpen jullie bij het vinden van jurken die perfect bij de bruidslook en het thema van de bruiloft passen — van één jurk tot een complete bruidsmeisjesgroep.
        </p>
        <a href="https://nlmariage-kremen.savviihq.com/online-agenda/" target="_blank" rel="noopener" class="btn-premium">Afspraak maken</a>
      </div>
    </div>
  </section>

  <!-- Stijlen -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-6 max-w-5xl">
      <div class="text-center mb-16">
        <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-4">Collectie</p>
        <h2 class="font-display text-charcoal text-4xl mb-4">Stijlen voor <em class="italic font-light text-taupe">elke bruiloft</em></h2>
        <p class="text-taupe font-light max-w-xl mx-auto text-sm leading-relaxed">
          Van klassiek tot bohemian — wij hebben een ruime collectie bruidsmeisjesjurken in verschillende stijlen, lengtes en kleuren.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {stijlen.map(({ naam, beschrijving }) => (
          <div class="space-y-4 text-center">
            <div class="w-px h-12 bg-blush mx-auto"></div>
            <h3 class="font-display text-charcoal text-xl">{naam}</h3>
            <p class="text-taupe font-light text-sm leading-relaxed">{beschrijving}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Kleuren -->
  <section class="py-24 bg-ivory border-t border-champagne">
    <div class="container mx-auto px-6 max-w-4xl">
      <div class="text-center mb-12">
        <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-4">Kleurenpalet</p>
        <h2 class="font-display text-charcoal text-4xl mb-4">Kies uw <em class="italic font-light text-taupe">kleur</em></h2>
        <p class="text-taupe font-light max-w-lg mx-auto text-sm leading-relaxed">
          Wij bieden bruidsmeisjesjurken in een breed scala aan kleuren — van zachtroze tot diep bordeaux.
        </p>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {kleuren.map(kleur => (
          <span class="border border-champagne bg-white px-5 py-2.5 text-[10px] tracking-[0.2em] uppercase font-body text-taupe">{kleur}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Waarom Mariage -->
  <section class="py-24 bg-white border-t border-champagne">
    <div class="container mx-auto px-6 max-w-5xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-6">Onze aanpak</p>
          <h2 class="font-display text-charcoal text-4xl mb-6">Samen de <em class="italic font-light text-taupe">perfecte match</em></h2>
          <div class="space-y-4 text-taupe font-light text-sm leading-relaxed">
            <p>Wij begeleiden de bruid én haar bruidsmeisjes bij het vinden van jurken die bij elkaar passen — niet identiek, maar harmonieus. Dat kan variëren van dezelfde kleur in verschillende stijlen tot een complementair kleurenpalet.</p>
            <p>Kom langs voor een groepsafspraak zodat iedereen tegelijk kan passen. Wij nemen de tijd voor de hele groep en zorgen dat iedereen zich mooi en zeker voelt op de grote dag.</p>
          </div>
          <div class="mt-8">
            <a href="https://nlmariage-kremen.savviihq.com/online-agenda/" target="_blank" rel="noopener" class="btn-gold">Groepsafspraak plannen</a>
          </div>
        </div>
        <div class="space-y-4 text-sm font-body">
          {[
            'Persoonlijk advies per bruidsmeisje',
            'Groepsafspraken mogelijk',
            'Aansluiting op bruidslook',
            'Aanpassingen door eigen coupeuses',
            'Ruim aanbod maten',
          ].map(punt => (
            <div class="flex items-center gap-3 border-b border-champagne pb-4">
              <div class="w-1.5 h-1.5 rounded-full bg-blush-deep shrink-0"></div>
              <span class="text-charcoal">{punt}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-charcoal text-center">
    <div class="container mx-auto px-6 max-w-2xl">
      <p class="text-[10px] tracking-[0.4em] uppercase text-blush font-body mb-4">Aan de slag</p>
      <h2 class="font-display text-warm-white text-4xl mb-6">Klaar om te <em class="italic text-blush font-light">passen?</em></h2>
      <p class="text-warm-white/60 font-light mb-10 text-sm leading-relaxed">
        Maak een afspraak voor jullie bruidsmeisjesgroep en ontdek ons aanbod.
      </p>
      <a href="https://nlmariage-kremen.savviihq.com/online-agenda/" target="_blank" rel="noopener" class="btn-gold">Afspraak maken</a>
    </div>
  </section>

</Layout>
