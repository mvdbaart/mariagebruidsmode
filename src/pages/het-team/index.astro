---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';

const { data: employees } = await supabase
  .from('employees')
  .select('id, first_name, last_name, role, bio, profile_photo_url, specialisms, sort_order')
  .eq('is_active', true)
  .order('sort_order', { ascending: true, nullsFirst: true })
  .order('first_name', { ascending: true });

const activeEmployees = (employees ?? []) as Array<{
  id: string;
  first_name: string;
  last_name: string;
  role?: string;
  bio?: string;
  profile_photo_url?: string;
  specialisms?: string[];
  sort_order?: number;
}>;
---

<Layout title="Het Team | Mariage Bruidsmode">
  <!-- Hero -->
  <section class="pt-40 pb-24 bg-ivory">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
        <div>
          <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-6">Het Team</p>
          <h1 class="font-display text-charcoal leading-tight mb-8" style="font-size: clamp(40px, 8vw, 72px); font-weight: 300;">
            Onze gepassioneerde <br/><em class="italic font-light text-taupe">specialisten</em>
          </h1>
          <div class="space-y-4 font-light text-taupe leading-relaxed max-w-lg">
            <p>
              Achter Mariage Bruidsmode staat een team van professionals dat elke dag werkt aan een persoonlijke en zorgvuldige ervaring.
            </p>
            <p>
              Van styling en verkoop tot atelier en aanpassingen: iedereen draagt bij aan het vinden van de perfecte jurk en de beste pasvorm.
            </p>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/5] overflow-hidden shadow-soft grayscale hover:grayscale-0 transition-all duration-700 bg-white">
            {activeEmployees[0]?.profile_photo_url ? (
              <img
                src={activeEmployees[0].profile_photo_url}
                alt={`${activeEmployees[0].first_name} ${activeEmployees[0].last_name}`}
                class="w-full h-full object-cover scale-105 hover:scale-100 transition-transform duration-1000"
                loading="eager"
              />
            ) : (
              <img
                src="/images/jurkvormen/a-lijn.png"
                alt="Mariage Team"
                class="w-full h-full object-cover scale-105 hover:scale-100 transition-transform duration-1000"
                loading="eager"
              />
            )}
          </div>
          <div class="absolute -bottom-10 -left-10 bg-charcoal p-10 hidden md:block shadow-2xl">
            <p class="text-warm-white font-display italic text-2xl">Passie &amp;<br/>Vakmanschap</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team grid -->
  <section class="py-32 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-20">
        <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-4">Ons Team</p>
        <h2 class="font-display text-charcoal text-4xl mb-6">Ontmoet onze <em class="italic font-light text-taupe">mensen</em></h2>
        <p class="text-taupe max-w-2xl mx-auto font-light leading-relaxed">
          Onze specialisten werken met aandacht, ervaring en oog voor detail. Hieronder zie je wie er actief voor je klaarstaan.
        </p>
      </div>

      {activeEmployees.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6 md:gap-8">
          {activeEmployees.map((employee) => (
            <article class="group bg-ivory border border-champagne/60 rounded-[28px] p-6 shadow-soft hover:shadow-card transition-all duration-300">
              <div class="aspect-[4/5] overflow-hidden bg-white mb-5 rounded-[22px]">
                {employee.profile_photo_url ? (
                  <img
                    src={employee.profile_photo_url}
                    alt={`${employee.first_name} ${employee.last_name}`}
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-champagne/20">
                    <span class="text-4xl font-display text-charcoal/35">
                      {employee.first_name.charAt(0)}{employee.last_name.charAt(0)}
                    </span>
                  </div>
                )}
              </div>

              <div class="space-y-4">
                <div>
                  <p class="text-[10px] tracking-[0.3em] uppercase text-blush-deep font-body mb-2">
                    {employee.role || 'Teamlid'}
                  </p>
                  <h3 class="font-display text-2xl text-charcoal">
                    {employee.first_name} {employee.last_name}
                  </h3>
                </div>

                {employee.bio && (
                  <p class="text-taupe font-light leading-relaxed text-sm">
                    {employee.bio}
                  </p>
                )}

                {employee.specialisms && employee.specialisms.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {employee.specialisms.map((specialism) => (
                      <span class="inline-flex items-center rounded-full border border-blush-deep/15 bg-blush-deep/5 px-3 py-1 text-[9px] uppercase tracking-[0.18em] text-blush-deep">
                        {specialism}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-20 bg-ivory rounded-[28px] border border-dashed border-champagne">
          <p class="text-taupe font-light">Er zijn nog geen actieve medewerkers ingesteld.</p>
        </div>
      )}
    </div>
  </section>

  <!-- Expertise -->
  <section class="py-32 bg-ivory border-t border-champagne">
    <div class="container mx-auto px-6">
      <div class="text-center mb-20">
        <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-4">Onze expertise</p>
        <h2 class="font-display text-charcoal text-4xl mb-4">Wat wij voor jou <em class="italic font-light text-taupe">doen</em></h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-16 max-w-5xl mx-auto text-center">
        <div class="space-y-6">
          <div class="w-px h-12 bg-blush mx-auto"></div>
          <h3 class="font-display text-charcoal text-2xl">Bruidsstyling</h3>
          <p class="text-taupe font-light text-sm leading-relaxed">
            Persoonlijk advies bij het vinden van de stijl, pasvorm en details die bij jou passen.
          </p>
        </div>
        <div class="space-y-6">
          <div class="w-px h-12 bg-blush mx-auto"></div>
          <h3 class="font-display text-charcoal text-2xl">Trouwpakken</h3>
          <p class="text-taupe font-light text-sm leading-relaxed">
            Begeleiding voor bruidegoms en gasten die zoeken naar een verzorgde en eigentijdse look.
          </p>
        </div>
        <div class="space-y-6">
          <div class="w-px h-12 bg-blush mx-auto"></div>
          <h3 class="font-display text-charcoal text-2xl">Atelier &amp; Aanpassingen</h3>
          <p class="text-taupe font-light text-sm leading-relaxed">
            Zorgvuldige aanpassingen voor een perfecte pasvorm en een afwerking die klopt tot in detail.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-charcoal text-center">
    <div class="container mx-auto px-6 max-w-2xl">
      <p class="text-[10px] tracking-[0.4em] uppercase text-blush font-body mb-4">Maak kennis</p>
      <h2 class="font-display text-warm-white text-4xl mb-6">Wil je ons team <em class="italic text-blush font-light">ontmoeten?</em></h2>
      <p class="text-warm-white/60 font-light mb-10 leading-relaxed">
        Maak een afspraak en laat je persoonlijk begeleiden door een van onze specialisten.
      </p>
      <a href="https://nlmariage-kremen.savviihq.com/online-agenda/" target="_blank" rel="noopener" class="btn-gold">Afspraak maken</a>
    </div>
  </section>
</Layout>
