---
import Layout from '../../layouts/Layout.astro';

const teamImages = [
  "TKF_8811-scaled.jpg", "TKF_8818-scaled.jpg", "TKF_8994-scaled.jpg", "TKF_9004-scaled.jpg",
  "TKF_9016-scaled.jpg", "TKF_9043-scaled.jpg", "TKF_9054-1-scaled-scaled.jpg", "TKF_9055-1-scaled-e1704372521721.jpg",
  "TKF_9055-scaled-e1704372195953.jpg", "TKF_9055-scaled-e1704372242248.jpg", "TKF_9069-scaled-e1704371934815.jpg", "TKF_9080-scaled.jpg",
  "TKF_9092-scaled.jpg", "TKF_9208-scaled-scaled.jpg", "TKF_9250-scaled-scaled.jpg", "TKF_9276-scaled-scaled.jpg",
  "TKF_9303-scaled-scaled.jpg", "TKF_9331-scaled-scaled.jpg", "TKF_9422-scaled.jpg", "TKF_9432-scaled-scaled.jpg",
  "TKF_9452-scaled-e1704364640971.jpg", "TKF_9488-scaled-e1704364582984.jpg", "TKF_9528-scaled.jpg", "TKF_9597-scaled-scaled.jpg",
  "TKF_9637-scaled.jpg"
];

const expertises = [
  {
    titel: 'Bruidsstyling',
    beschrijving: 'Onze stylistes begeleiden je met een persoonlijk advies van begin tot eind. Ze kennen elke jurk in de collectie van binnen en buiten en weten precies wat bij jou past.',
  },
  {
    titel: 'Trouwpakken',
    beschrijving: 'Ons gespecialiseerde team voor herenmode helpt de bruidegom de perfecte look samen te stellen. Van klassiek tot modern — altijd met aandacht voor detail en pasvorm.',
  },
  {
    titel: 'Atelier & Aanpassingen',
    beschrijving: 'Onze ervaren coupeuses zorgen voor een perfecte pasvorm. Van kleine aanpassingen tot uitgebreide maatwerk — alles wordt met zorg uitgevoerd in ons eigen atelier.',
  },
];
---

<Layout title="Het Team | Mariage Bruidsmode">

  <!-- Hero -->
  <section class="pt-40 pb-24 bg-ivory">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
        <div>
          <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-6">Het Team</p>
          <h1 class="font-display text-charcoal leading-tight mb-8" style="font-size: clamp(40px, 8vw, 72px); font-weight: 300;">
            Onze gepassioneerde <br/><em class="italic font-light text-taupe">specialisten</em>
          </h1>
          <div class="space-y-4 font-light text-taupe leading-relaxed max-w-lg">
            <p>
              Achter Mariage Bruidsmode staat een team van gepassioneerde professionals die elke dag met liefde voor het vak werken. Van ervaren stylistes tot vakkundige coupeuses.
            </p>
            <p>
              Samen zorgen zij ervoor dat jouw bezoek aan onze winkel een onvergetelijke ervaring wordt — persoonlijk, warm en professioneel.
            </p>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/5] overflow-hidden shadow-soft grayscale hover:grayscale-0 transition-all duration-700">
            <img
              src="/images/team/TKF_9080-scaled.jpg"
              alt="Mariage Team"
              class="w-full h-full object-cover scale-105 hover:scale-100 transition-transform duration-1000"
            />
          </div>
          <div class="absolute -bottom-10 -left-10 bg-charcoal p-10 hidden md:block shadow-2xl">
            <p class="text-warm-white font-display italic text-2xl">Passie &<br/>Vakmanschap</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Teamfoto's grid -->
  <section class="py-32 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-20">
        <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-4">Ons Team</p>
        <h2 class="font-display text-charcoal text-4xl mb-6">Ontmoet onze <em class="italic font-light text-taupe">mensen</em></h2>
        <p class="text-taupe max-w-2xl mx-auto font-light leading-relaxed">
          Onze stylistes en coupeuses staan elke dag voor je klaar om jouw droom werkelijkheid te maken. Vakmanschap en passie staan bij ons centraal.
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 md:gap-8">
        {teamImages.map((img) => (
          <div class="group">
            <div class="aspect-[3/4] overflow-hidden bg-ivory mb-4 shadow-soft grayscale group-hover:grayscale-0 transition-all duration-500">
              <img
                src={`/images/team/${img}`}
                alt="Mariage Team Member"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <p class="text-[10px] tracking-widest uppercase text-charcoal font-medium">Mariage Specialiste</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Expertise -->
  <section class="py-32 bg-ivory border-t border-champagne">
    <div class="container mx-auto px-6">
      <div class="text-center mb-20">
        <p class="text-[10px] tracking-[0.4em] uppercase text-blush-deep font-body mb-4">Onze expertise</p>
        <h2 class="font-display text-charcoal text-4xl mb-4">Wat wij voor jou <em class="italic font-light text-taupe">doen</em></h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-16 max-w-5xl mx-auto text-center">
        {expertises.map(({ titel, beschrijving }) => (
          <div class="space-y-6">
            <div class="w-px h-12 bg-blush mx-auto"></div>
            <h3 class="font-display text-charcoal text-2xl">{titel}</h3>
            <p class="text-taupe font-light text-sm leading-relaxed">{beschrijving}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-charcoal text-center">
    <div class="container mx-auto px-6 max-w-2xl">
      <p class="text-[10px] tracking-[0.4em] uppercase text-blush font-body mb-4">Maak kennis</p>
      <h2 class="font-display text-warm-white text-4xl mb-6">Wil je ons team <em class="italic text-blush font-light">ontmoeten?</em></h2>
      <p class="text-warm-white/60 font-light mb-10 leading-relaxed">
        Maak een afspraak en laat je persoonlijk begeleiden door een van onze specialisten.
      </p>
      <a href="https://nlmariage-kremen.savviihq.com/online-agenda/" target="_blank" rel="noopener" class="btn-gold">Afspraak maken</a>
    </div>
  </section>

</Layout>
