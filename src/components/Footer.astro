---
const year = new Date().getFullYear();
---

<footer class="bg-[#e8bfae] text-white pt-20 pb-12 px-6">
  <div class="container mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <div class="col-span-1 md:col-span-1">
        <a href="/" class="flex flex-col mb-6">
          <span class="text-4xl font-display font-normal text-white leading-none mb-2">Mariage</span>
          <span class="text-[9px] font-body font-normal tracking-[0.35em] uppercase text-white/80">Bruidsmode</span>
        </a>
        <p class="text-white/90 font-light text-sm leading-relaxed mb-6">
          De meest exclusieve bruidsmode ervaring in de regio Eindhoven. Persoonlijk, eerlijk en magisch.
        </p>
      </div>

      <div>
        <h4 class="text-[10px] tracking-widest uppercase text-white/70 mb-8 font-semibold">Navigatie</h4>
        <ul class="space-y-4">
          <li><a href="/trouwjurken" class="text-white/90 hover:text-white transition-colors text-xs font-light tracking-widest uppercase">Trouwjurken</a></li>
          <li><a href="/trouwpakken" class="text-white/90 hover:text-white transition-colors text-xs font-light tracking-widest uppercase">Trouwpakken</a></li>
          <li><a href="/over-ons" class="text-white/90 hover:text-white transition-colors text-xs font-light tracking-widest uppercase">Over Mariage</a></li>
          <li><a href="/inspiratie" class="text-white/90 hover:text-white transition-colors text-xs font-light tracking-widest uppercase">Inspiratie</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-[10px] tracking-widest uppercase text-white/70 mb-8 font-semibold">Informatie</h4>
        <ul class="space-y-4">
          <li><a href="/blog" class="text-white/90 hover:text-white transition-colors text-xs font-light tracking-widest uppercase">Mariage Blog</a></li>
          <li><a href="/afspraak-maken" class="text-white/90 hover:text-white transition-colors text-xs font-light tracking-widest uppercase">Afspraak maken</a></li>
          <li><a href="/privacy" class="text-white/90 hover:text-white transition-colors text-xs font-light tracking-widest uppercase">Privacybeleid</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-[10px] tracking-widest uppercase text-white/70 mb-8 font-semibold">Contact</h4>
        <address class="not-italic text-white/90 text-sm font-light space-y-4">
          <p>Langstraat 128<br/>5664 GK Geldrop</p>
          <p>
            <a href="tel:+31402863673" class="hover:text-white transition-colors">040 286 3673</a><br/>
            <a href="mailto:info@mariagebruidsmode.nl" class="hover:text-white transition-colors">info@mariagebruidsmode.nl</a>
          </p>
        </address>
      </div>
    </div>

    <div class="pt-8 border-t border-white/20 flex flex-col md:flex-row justify-between items-center gap-4 text-[10px] tracking-[0.15em] uppercase text-white/80 font-body">
      <p>&copy; {year} Mariage Bruidsmode. <span class="text-white/50">Dutch Boutique Excellence.</span></p>
      <div class="flex gap-8">
        <a href="/privacy" class="hover:text-white">Privacy</a>
        <a href="/voorwaarden" class="hover:text-white">Voorwaarden</a>
      </div>
    </div>
  </div>
</footer>
