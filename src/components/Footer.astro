---
import { getSiteSettings } from '../lib/settings';
const settings = await getSiteSettings(Astro);

const logoUrl = settings?.logo_url ?? null;
const c = (settings?.contact_info ?? {}) as Record<string, string>;

const address   = c.address      || 'Langstraat 128';
const postal    = c.postal_code  || '5664 GK';
const city      = c.city         || 'Geldrop';
const phone     = c.phone        || '040 286 3673';
const phoneHref = 'tel:' + (c.phone || '+31402863673').replace(/\s/g, '');
const email     = c.email        || 'info@mariagebruidsmode.nl';
const year      = new Date().getFullYear();
---

<footer class="bg-charcoal text-warm-white pt-24 pb-12 px-6">
  <div class="container mx-auto max-w-6xl">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 mb-20">
      
      <!-- Contact Info -->
      <div>
        <h4 class="text-[11px] tracking-[0.2em] uppercase text-white/40 mb-8 font-body">Contact Info</h4>
        <div class="space-y-4 text-sm font-body font-light">
          <p class="text-lg font-display text-white">{phone}</p>
          <p class="text-white/60">{email}</p>
          <div class="flex gap-4 pt-4">
            <a href="#" class="text-white/40 hover:text-blush-deep transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </a>
            <a href="#" class="text-white/40 hover:text-blush-deep transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Location -->
      <div>
        <h4 class="text-[11px] tracking-[0.2em] uppercase text-white/40 mb-8 font-body">Location</h4>
        <div class="space-y-2 text-sm font-body font-light text-white/80">
          <p>{address}</p>
          <p>{postal} {city}</p>
          <p>The Netherlands</p>
          <a href="#" class="inline-block mt-4 text-[10px] tracking-widest uppercase border-b border-white/20 pb-1 hover:border-blush-deep transition-colors">Route plannen</a>
        </div>
      </div>

      <!-- Single-field appointment -->
      <div>
        <h4 class="text-[11px] tracking-[0.2em] uppercase text-white/40 mb-8 font-body">Single-field appointment request</h4>
        <form class="space-y-4">
          <input 
            type="email" 
            placeholder="Email" 
            class="w-full bg-white/5 border border-white/10 px-4 py-3 text-sm text-white placeholder:text-white/20 focus:outline-none focus:border-blush-deep transition-colors"
          />
          <button class="w-full bg-blush-deep text-white py-3 text-[10px] tracking-[0.3em] uppercase font-body hover:bg-opacity-90 transition-all">
            Verzenden
          </button>
        </form>
      </div>
    </div>

    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 text-[9px] tracking-[0.2em] uppercase text-white/30 font-body">
      <p>Copyright © {year} • Mariage • All Rights Reserved</p>
      <div class="flex gap-8">
        <a href="/privacy" class="hover:text-white transition-colors">Privacy</a>
        <a href="/voorwaarden" class="hover:text-white transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>
