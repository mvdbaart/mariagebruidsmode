---
import { getSiteSettings } from '../lib/settings';
const settings = await getSiteSettings(Astro);
const logoUrl = settings?.logo_url ?? null;
---
<header id="site-header" class="fixed left-0 right-0 z-50 bg-ivory/80 backdrop-blur-md border-b border-champagne transition-transform duration-300" style="top: var(--announcement-height, 0px)">
  <div class="container mx-auto px-6 h-[72px] flex items-center justify-between">

    <!-- Left: navigation links -->
    <nav class="hidden lg:flex items-center gap-10 h-full">

      <!-- Bruid dropdown -->
      <div class="relative group h-full flex items-center">
        <a href="/trouwjurken" class="text-[9px] font-body font-normal tracking-[0.25em] uppercase text-charcoal hover:opacity-60 transition-opacity flex items-center gap-1">
          Bruid
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform duration-200 group-hover:rotate-180"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </a>
        <div class="absolute top-full left-1/2 -translate-x-1/2 hidden group-hover:block pt-0">
          <div class="bg-white/90 backdrop-blur-lg border border-champagne shadow-card min-w-[200px] py-3 mt-1 rounded-sm">
            <a href="/trouwjurken" class="block px-6 py-2.5 text-[9px] font-body font-normal tracking-[0.2em] uppercase text-charcoal hover:bg-blush-deep/5 hover:text-blush-deep transition-colors">Trouwjurken</a>
            <a href="/bruidsmeisjes" class="block px-6 py-2.5 text-[9px] font-body font-normal tracking-[0.2em] uppercase text-charcoal hover:bg-blush-deep/5 hover:text-blush-deep transition-colors">Bruidsmeisjes</a>
            <a href="/kinderjurkjes" class="block px-6 py-2.5 text-[9px] font-body font-normal tracking-[0.2em] uppercase text-charcoal hover:bg-blush-deep/5 hover:text-blush-deep transition-colors">Kinderjurkjes</a>
            <a href="/bruid/accessoires" class="block px-6 py-2.5 text-[9px] font-body font-normal tracking-[0.2em] uppercase text-charcoal hover:bg-blush-deep/5 hover:text-blush-deep transition-colors">Accessoires</a>
            <a href="/bruidsschoenen" class="block px-6 py-2.5 text-[9px] font-body font-normal tracking-[0.2em] uppercase text-charcoal hover:bg-blush-deep/5 hover:text-blush-deep transition-colors">Bruidsschoenen</a>
            <a href="/merken" class="block px-6 py-2.5 text-[9px] font-body font-normal tracking-[0.2em] uppercase text-charcoal hover:bg-blush-deep/5 hover:text-blush-deep transition-colors">Onze Merken</a>
            <a href="/vip-arrangement" class="block px-6 py-2.5 text-[9px] font-body font-normal tracking-[0.2em] uppercase text-charcoal hover:bg-blush-deep/5 hover:text-blush-deep transition-colors">VIP Arrangement</a>
            <a href="/outlet" class="block px-6 py-2.5 text-[9px] font-body font-normal tracking-[0.2em] uppercase text-charcoal hover:bg-blush-deep/5 hover:text-blush-deep transition-colors">Outlet</a>
          </div>
        </div>
      </div>

      <!-- Bruidegom dropdown -->
      <div class="relative group h-full flex items-center">
        <a href="/trouwpakken" class="text-[9px] font-body font-normal tracking-[0.25em] uppercase text-charcoal hover:opacity-60 transition-opacity flex items-center gap-1">
          Bruidegom
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform duration-200 group-hover:rotate-180"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </a>
        <div class="absolute top-full left-1/2 -translate-x-1/2 hidden group-hover:block pt-0">
          <div class="bg-white/90 backdrop-blur-lg border border-champagne shadow-card min-w-[200px] py-3 mt-1 rounded-sm">
            <a href="/trouwpakken" class="block px-6 py-2.5 text-[9px] font-body font-normal tracking-[0.2em] uppercase text-charcoal hover:bg-blush-deep/5 hover:text-blush-deep transition-colors">Trouwkostuums</a>
            <a href="/bruidegom/accessoires" class="block px-6 py-2.5 text-[9px] font-body font-normal tracking-[0.2em] uppercase text-charcoal hover:bg-blush-deep/5 hover:text-blush-deep transition-colors">Accessoires</a>
            <a href="/trouwschoenen" class="block px-6 py-2.5 text-[9px] font-body font-normal tracking-[0.2em] uppercase text-charcoal hover:bg-blush-deep/5 hover:text-blush-deep transition-colors">Trouwschoenen</a>
          </div>
        </div>
      </div>

      <a href="/inspiratie" class="text-[9px] font-body font-normal tracking-[0.25em] uppercase text-charcoal hover:opacity-60 transition-opacity">Inspiratie</a>
      <!-- Over Ons dropdown -->
      <div class="relative group h-full flex items-center">
        <a href="/over-ons" class="text-[9px] font-body font-normal tracking-[0.25em] uppercase text-charcoal hover:opacity-60 transition-opacity flex items-center gap-1">
          Over Ons
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform duration-200 group-hover:rotate-180"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </a>
        <div class="absolute top-full left-1/2 -translate-x-1/2 hidden group-hover:block pt-0">
          <div class="bg-white/90 backdrop-blur-lg border border-champagne shadow-card min-w-[200px] py-3 mt-1 rounded-sm">
            <a href="/over-ons" class="block px-6 py-2.5 text-[9px] font-body font-normal tracking-[0.2em] uppercase text-charcoal hover:bg-blush-deep/5 hover:text-blush-deep transition-colors">Over Ons</a>
            <a href="/onze-winkel" class="block px-6 py-2.5 text-[9px] font-body font-normal tracking-[0.2em] uppercase text-charcoal hover:bg-blush-deep/5 hover:text-blush-deep transition-colors">Onze Winkel</a>
            <a href="/het-team" class="block px-6 py-2.5 text-[9px] font-body font-normal tracking-[0.2em] uppercase text-charcoal hover:bg-blush-deep/5 hover:text-blush-deep transition-colors">Het Team</a>
            <a href="/events" class="block px-6 py-2.5 text-[9px] font-body font-normal tracking-[0.2em] uppercase text-charcoal hover:bg-blush-deep/5 hover:text-blush-deep transition-colors">Events</a>
            <a href="/faq" class="block px-6 py-2.5 text-[9px] font-body font-normal tracking-[0.2em] uppercase text-charcoal hover:bg-blush-deep/5 hover:text-blush-deep transition-colors">FAQ</a>
            <a href="/vacatures" class="block px-6 py-2.5 text-[9px] font-body font-normal tracking-[0.2em] uppercase text-charcoal hover:bg-blush-deep/5 hover:text-blush-deep transition-colors">Vacatures</a>
            <a href="/contact" class="block px-6 py-2.5 text-[9px] font-body font-normal tracking-[0.2em] uppercase text-charcoal hover:bg-blush-deep/5 hover:text-blush-deep transition-colors">Contact</a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Mobile toggle (left on mobile) -->
    <button
      id="menu-toggle"
      aria-label="Menu openen"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="lg:hidden text-charcoal hover:text-blush-deep transition-colors p-2"
    >
      <span id="icon-menu" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </span>
      <span id="icon-close" class="hidden" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </span>
    </button>

    <!-- Center: logo -->
    <a href="/" class="absolute left-1/2 -translate-x-1/2 flex flex-col items-center">
      {logoUrl ? (
        <img src={logoUrl} alt="Mariage Bruidsmode" class="h-9 w-auto object-contain" />
      ) : (
        <>
          <span class="text-[20px] font-display font-normal text-charcoal leading-none tracking-[0.15em]">MARIAGE</span>
          <span class="text-[6px] font-body font-normal tracking-[0.5em] uppercase text-taupe-light mt-1">Bruidsmode</span>
        </>
      )}
    </a>

    <!-- Right: menu, blog, icons -->
    <div class="flex items-center gap-8">
      <a href="/blog" class="hidden lg:block text-[9px] font-body font-normal tracking-[0.25em] uppercase text-charcoal hover:opacity-60 transition-opacity">Blog</a>
      <a href="/verlanglijst" aria-label="Verlanglijst" class="hidden lg:flex items-center text-charcoal hover:text-blush-deep transition-colors" title="Verlanglijst">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </a>
      <a href="https://nlmariage-kremen.savviihq.com/online-agenda/" target="_blank" rel="noopener" class="btn-blush hidden lg:inline-flex text-[9px] tracking-[0.2em] py-2.5 px-5 whitespace-nowrap">
        Afspraak maken
      </a>
      <!-- Mobile: calendar icon for appointment booking -->
      <a
        href="https://nlmariage-kremen.savviihq.com/online-agenda/"
        target="_blank"
        rel="noopener"
        aria-label="Afspraak maken"
        class="lg:hidden text-charcoal hover:text-blush-deep transition-colors p-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
      </a>
    </div>
  </div>

  <!-- Mobile menu (hidden by default) -->
  <div
    id="mobile-menu"
    aria-hidden="true"
    class="hidden lg:hidden border-t border-champagne bg-white"
  >
    <nav class="flex flex-col py-6 px-8 gap-1">

      <!-- Bruid accordion -->
      <div data-accordion="bruid" class="border-b border-champagne">
        <div class="flex items-center justify-between">
          <a href="/trouwjurken" class="py-4 text-xs font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors">Bruid</a>
          <button
            data-accordion-toggle="bruid"
            aria-expanded="false"
            aria-label="Bruid submenu uitklappen"
            class="p-2 text-taupe hover:text-charcoal transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="accordion-chevron transition-transform duration-200"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
        </div>
        <div data-accordion-content="bruid" class="hidden pb-2 pl-4">
          <a href="/trouwjurken" class="block py-2.5 text-[10px] font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors">Trouwjurken</a>
          <a href="/kinderjurkjes" class="block py-2.5 text-[10px] font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors">Kinderjurkjes</a>
          <a href="/bruid/accessoires" class="block py-2.5 text-[10px] font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors">Accessoires</a>
          <a href="/bruidsschoenen" class="block py-2.5 text-[10px] font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors">Bruidsschoenen</a>
          <a href="/vip-arrangement" class="block py-2.5 text-[10px] font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors">VIP Arrangement</a>
        </div>
      </div>

      <!-- Bruidegom accordion -->
      <div data-accordion="bruidegom" class="border-b border-champagne">
        <div class="flex items-center justify-between">
          <a href="/trouwpakken" class="py-4 text-xs font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors">Bruidegom</a>
          <button
            data-accordion-toggle="bruidegom"
            aria-expanded="false"
            aria-label="Bruidegom submenu uitklappen"
            class="p-2 text-taupe hover:text-charcoal transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="accordion-chevron transition-transform duration-200"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
        </div>
        <div data-accordion-content="bruidegom" class="hidden pb-2 pl-4">
          <a href="/trouwpakken" class="block py-2.5 text-[10px] font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors">Trouwkostuums</a>
          <a href="/bruidegom/accessoires" class="block py-2.5 text-[10px] font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors">Accessoires</a>
          <a href="/trouwschoenen" class="block py-2.5 text-[10px] font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors">Trouwschoenen</a>
        </div>
      </div>

      <a href="/inspiratie" class="py-4 text-xs font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors border-b border-champagne">Inspiratie</a>
      <!-- Over Ons accordion -->
      <div data-accordion="over-ons" class="border-b border-champagne">
        <div class="flex items-center justify-between">
          <a href="/over-ons" class="py-4 text-xs font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors">Over Ons</a>
          <button
            data-accordion-toggle="over-ons"
            aria-expanded="false"
            aria-label="Over Ons submenu uitklappen"
            class="p-2 text-taupe hover:text-charcoal transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="accordion-chevron transition-transform duration-200"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
        </div>
        <div data-accordion-content="over-ons" class="hidden pb-2 pl-4">
          <a href="/over-ons" class="block py-2.5 text-[10px] font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors">Over Ons</a>
          <a href="/onze-winkel" class="block py-2.5 text-[10px] font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors">Onze Winkel</a>
          <a href="/het-team" class="block py-2.5 text-[10px] font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors">Het Team</a>
          <a href="/events" class="block py-2.5 text-[10px] font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors">Events</a>
          <a href="/faq" class="block py-2.5 text-[10px] font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors">FAQ</a>
          <a href="/vacatures" class="block py-2.5 text-[10px] font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors">Vacatures</a>
          <a href="/contact" class="block py-2.5 text-[10px] font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors">Contact</a>
        </div>
      </div>
      <a href="/blog" class="py-4 text-xs font-body font-normal tracking-[0.16em] uppercase text-taupe hover:text-charcoal transition-colors border-b border-champagne">Blog</a>
      <a href="https://nlmariage-kremen.savviihq.com/online-agenda/" target="_blank" rel="noopener" class="mt-4 btn-blush text-center justify-center">Afspraak plannen</a>
    </nav>
  </div>
</header>

<script>
  // --- Hamburger toggle ---
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  function closeMobileMenu() {
    menu?.classList.add('hidden');
    menu?.setAttribute('aria-hidden', 'true');
    iconMenu?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Menu openen');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    menu?.setAttribute('aria-hidden', String(isOpen));
    iconMenu?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-label', isOpen ? 'Menu openen' : 'Menu sluiten');
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close menu when a non-toggle link is clicked
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMobileMenu);
  });

  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape' || !menu || menu.classList.contains('hidden')) return;
    closeMobileMenu();
    toggle?.focus();
  });

  // --- Accordion toggles ---
  document.querySelectorAll<HTMLButtonElement>('[data-accordion-toggle]').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.getAttribute('data-accordion-toggle')!;
      const content = document.querySelector(`[data-accordion-content="${key}"]`);
      const chevron = btn.querySelector('.accordion-chevron') as SVGElement | null;
      const isOpen = !content?.classList.contains('hidden');

      content?.classList.toggle('hidden', isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
      chevron?.style.setProperty('transform', isOpen ? '' : 'rotate(180deg)');
    });
  });

  // Keep the header fixed and only close the mobile menu on scroll.
  const header = document.getElementById('site-header');
  let lastScroll = window.scrollY;
  window.addEventListener('scroll', () => {
    const current = window.scrollY;
    if (current > lastScroll && !menu?.classList.contains('hidden')) {
      closeMobileMenu();
    }
    lastScroll = current;
  }, { passive: true });

</script>
