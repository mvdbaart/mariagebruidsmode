---
interface Props {
  quote: string;
  name: string;
  image: string;
}

const { quote, name, image } = Astro.props;
---

<div class="flex flex-col md:flex-row items-center gap-12 bg-white p-6 md:p-12 shadow-sm border border-secondary/5">
  <div class="w-full md:w-1/2 aspect-square overflow-hidden">
    <img src={image} alt={name} class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700" />
  </div>
  <div class="w-full md:w-1/2 text-left">
    <div class="flex gap-1 text-secondary mb-6">
      <span class="text-xs">★</span><span class="text-xs">★</span><span class="text-xs">★</span><span class="text-xs">★</span><span class="text-xs">★</span>
    </div>
    <blockquote class="text-2xl font-serif italic text-accent mb-8 leading-relaxed">
      "{quote}"
    </blockquote>
    <div>
      <p class="font-medium tracking-widest uppercase text-sm text-accent">{name}</p>
      <p class="text-xs text-secondary tracking-widest uppercase mt-2">Real Mariage Bride</p>
    </div>
  </div>
</div>
