{
  "name": "mariagebruidsmode.nl",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "clean:cache": "node -e \"const fs=require('fs'); for (const p of ['.astro','node_modules/.vite']) fs.rmSync(p,{recursive:true,force:true}); console.log('cache cleared')\"",
    "dev:clean": "npm run clean:cache && npm run dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "setup:buckets": "node scripts/setup_buckets.js",
    "extract:site": "node scripts/extract_site_content.js",
    "mirror:extract": "node scripts/mirror_and_extract.js",
    "grant:admin": "node scripts/grant_admin_role.js",
    "images:dresses:map:dry": "node scripts/map_dress_images_to_products.js",
    "images:dresses:map:apply": "node scripts/map_dress_images_to_products.js --apply",
    "catalog:dresses:dry": "node scripts/import_dress_catalog_from_folders.js",
    "catalog:dresses:apply": "node scripts/import_dress_catalog_from_folders.js --apply"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/react": "^5.0.0",
    "@astrojs/sitemap": "^3.7.1",
    "@astrojs/vercel": "^10.0.0",
    "@supabase/supabase-js": "^2.99.1",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.0.4",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.4",
    "sanitize-html": "^2.17.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/jost": "^5.2.8",
    "@fontsource/playball": "^5.2.8",
    "@types/uuid": "^10.0.0"
  }
}
